+const GeckoTileHostCtx = struct {
+    host: ?*c.tsgt_host_t = null,
+    profile: [max_profile_len]u8 = undefined,
+    profile_len: usize = 0,
+    browser: [max_browser_len]u8 = undefined,
+    browser_len: usize = 0,
+    pane_id: [max_pane_id_len]u8 = undefined,
+    pane_id_len: usize = 0,
+    last_stream_ids: [c.TSGT_MAX_TILES]u64 = [_]u64{0} ** c.TSGT_MAX_TILES,
+    last_stream_count: usize = 0,
+    stop: std.atomic.Value(bool) = std.atomic.Value(bool).init(false),
+};
+
+// Thread owns GeckoTileHostCtx; no global registry needed for Exp4 v1.
+
+/// C present callback: log tiles + bridge to SurfaceView multi-tile present.
+export fn termsurfGeckoTilePresent(
+    ctx: ?*anyopaque,
+    tiles: ?*const c.tsgt_tile_t,
+    count: c_int,
+    pane_w_phys: c_int,
+    pane_h_phys: c_int,
+    scale: f64,
+) callconv(.c) void {
+    const host_ctx: *GeckoTileHostCtx = @ptrCast(@alignCast(ctx orelse return));
+    log.info(
+        "gecko_tiles_present=1 count={} pane_phys={}x{} scale={d:.1} profile={s} browser={s}",
+        .{
+            count,
+            pane_w_phys,
+            pane_h_phys,
+            scale,
+            host_ctx.profile[0..host_ctx.profile_len],
+            host_ctx.browser[0..host_ctx.browser_len],
+        },
+    );
+    const arr: [*]const c.tsgt_tile_t = if (tiles) |tptr| @ptrCast(tptr) else undefined;
+    const n: usize = if (count > 0) @intCast(count) else 0;
+    var streams: [c.TSGT_MAX_TILES]u64 = [_]u64{0} ** c.TSGT_MAX_TILES;
+    var stream_count: usize = 0;
+    var i: usize = 0;
+    while (i < n) : (i += 1) {
+        const t = arr[i];
+        if (t.live == 0 or t.stream_id == 0) continue;
+        var seen = false;
+        for (streams[0..stream_count]) |stream_id| {
+            if (stream_id == t.stream_id) {
+                seen = true;
+                break;
+            }
+        }
+        if (!seen and stream_count < streams.len) {
+            streams[stream_count] = t.stream_id;
+            stream_count += 1;
+        }
+    }
+
+    // Streams missing from the complete host snapshot were closed/reaped.
+    for (host_ctx.last_stream_ids[0..host_ctx.last_stream_count]) |old_stream| {
+        var still_live = false;
+        for (streams[0..stream_count]) |stream_id| {
+            if (stream_id == old_stream) {
+                still_live = true;
+                break;
+            }
+        }
+        if (!still_live) {
+            var pane_z: [max_pane_id_len + 1]u8 = undefined;
+            const pane_len = resolveGeckoStreamPane(host_ctx, old_stream, &pane_z) orelse continue;
+            termsurf_finish_gecko_tiles(pane_z[0..pane_len :0].ptr, null, 0);
+            log.info("gecko_tile_stream_cleared=1 stream_id={} pane_id={s}", .{ old_stream, pane_z[0..pane_len] });
+        }
+    }
+
+    // Present and reconcile each tab-owned stream independently.
+    for (streams[0..stream_count]) |stream_id| {
+        var pane_z: [max_pane_id_len + 1]u8 = undefined;
+        const pane_len = resolveGeckoStreamPane(host_ctx, stream_id, &pane_z) orelse continue;
+        var layer_ids: [c.TSGT_MAX_TILES]u64 = [_]u64{0} ** c.TSGT_MAX_TILES;
+        var layer_count: usize = 0;
+        i = 0;
+        while (i < n) : (i += 1) {
+            const t = arr[i];
+            if (t.live == 0 or t.iosurface == null or t.stream_id != stream_id) continue;
+            layer_ids[layer_count] = t.layer_id;
+            layer_count += 1;
+            termsurf_present_gecko_tile(
+                pane_z[0..pane_len :0].ptr,
+                t.iosurface,
+                t.layer_id,
+                t.generation,
+                t.pos_x,
+                t.pos_y,
+                t.disp_x,
+                t.disp_y,
+                t.disp_w,
+                t.disp_h,
+                pane_w_phys,
+                pane_h_phys,
+                scale,
+            );
+        }
+        termsurf_finish_gecko_tiles(
+            pane_z[0..pane_len :0].ptr,
+            if (layer_count > 0) layer_ids[0..layer_count].ptr else null,
+            @intCast(layer_count),
+        );
+        log.info(
+            "gecko_tile_stream_present=1 stream_id={} pane_id={s} layers={}",
+            .{ stream_id, pane_z[0..pane_len], layer_count },
+        );
+    }
+    @memcpy(host_ctx.last_stream_ids[0..stream_count], streams[0..stream_count]);
+    host_ctx.last_stream_count = stream_count;
+}
+
+fn resolveGeckoStreamPane(
+    host_ctx: *const GeckoTileHostCtx,
+    stream_id: u64,
+    pane_z: *[max_pane_id_len + 1]u8,
+) ?usize {
+    if (stream_id == 0 or stream_id > std.math.maxInt(i64)) return null;
+    state_mutex.lock();
+    defer state_mutex.unlock();
+    for (&panes) |*pane| {
+        if (!pane.in_use or pane.tab_id != @as(i64, @intCast(stream_id))) continue;
+        if (!std.mem.eql(u8, pane.profileName(), host_ctx.profile[0..host_ctx.profile_len]) or
+            !std.mem.eql(u8, pane.browserName(), host_ctx.browser[0..host_ctx.browser_len]))
+        {
+            continue;
+        }
+        const pane_id = pane.paneId();
+        @memcpy(pane_z[0..pane_id.len], pane_id);
+        pane_z[pane_id.len] = 0;
+        return pane_id.len;
+    }
+    return null;
+}
