+    /// Exp4: composite one Gecko tile into the pane with position + display_rect crop.
+    // swiftlint:disable:next function_parameter_count
+    func presentGeckoMultiTile(
+      surface: IOSurfaceRef,
+      layerID: UInt64,
+      generation: UInt64,
+      posX: Int32,
+      posY: Int32,
+      dispX: Int32,
+      dispY: Int32,
+      dispW: Int32,
+      dispH: Int32,
+      paneWPhys: Int32,
+      paneHPhys: Int32,
+      scale: Double
+    ) {
+      dispatchPrecondition(condition: .onQueue(.main))
+      wantsLayer = true
+      guard let surfaceLayer = layer else {
+        Unmanaged.passUnretained(surface).release()
+        return
+      }
+      let sc = scale > 0 ? scale : (window?.backingScaleFactor ?? 2.0)
+      let paneW = paneWPhys > 0 ? CGFloat(paneWPhys) / sc : bounds.width
+      let paneH = paneHPhys > 0 ? CGFloat(paneHPhys) / sc : bounds.height
+
+      CATransaction.begin()
+      CATransaction.setDisableActions(true)
+      defer { CATransaction.commit() }
+
+      let root =
+        geckoMultiTileRoot
+        ?? {
+          let layer = CALayer()
+          layer.name = "GeckoMultiTileRoot"
+          layer.isGeometryFlipped = true
+          layer.anchorPoint = .zero
+          layer.masksToBounds = true
+          surfaceLayer.addSublayer(layer)
+          geckoMultiTileRoot = layer
+          return layer
+        }()
+      root.frame = CGRect(x: 0, y: 0, width: max(paneW, bounds.width), height: max(paneH, bounds.height))
+      root.masksToBounds = true
+
+      if let existingGen = geckoMultiTileGenerations[layerID], generation < existingGen {
+        Unmanaged.passUnretained(surface).release()
+        return
+      }
+      if let prev = geckoMultiTileSurfaces[layerID] {
+        if prev !== surface {
+          Unmanaged.passUnretained(prev).release()
+        } else {
+          // The bridge retained this delivery. Keep the existing dictionary
+          // ownership and balance the duplicate retain.
+          Unmanaged.passUnretained(surface).release()
+        }
+      }
+      geckoMultiTileSurfaces[layerID] = surface
+      geckoMultiTileGenerations[layerID] = generation
+
+      let tileLayer =
+        geckoMultiTileLayers[layerID]
+        ?? {
+          let layer = CALayer()
+          layer.name = "GeckoTile-\(layerID)"
+          layer.anchorPoint = .zero
+          layer.contentsGravity = .resize
+          root.addSublayer(layer)
+          geckoMultiTileLayers[layerID] = layer
+          return layer
+        }()
+
+      let surfW = CGFloat(IOSurfaceGetWidth(surface))
+      let surfH = CGFloat(IOSurfaceGetHeight(surface))
+      let dw = dispW > 0 ? CGFloat(dispW) : surfW
+      let dh = dispH > 0 ? CGFloat(dispH) : surfH
+      let dx = CGFloat(dispX)
+      let dy = CGFloat(dispY)
+      // World origin = position + display origin (Gecko native-layer model), DIP.
+      let x = (CGFloat(posX) + dx) / sc
+      let y = (CGFloat(posY) + dy) / sc
+      let w = dw / sc
+      let h = dh / sc
+      // Geometry flipped root: y grows down from top in our flipped layer.
+      tileLayer.frame = CGRect(x: x, y: y, width: max(w, 0.5), height: max(h, 0.5))
+      tileLayer.contents = surface
+      tileLayer.contentsScale = sc
+      if surfW > 0, surfH > 0, dw > 0, dh > 0 {
+        let nx = dx / surfW
+        let ny = dy / surfH
+        let nw = dw / surfW
+        let nh = dh / surfH
+        // CALayer contentsRect is bottom-left; Gecko display is top-left.
+        let caY = 1.0 - ny - nh
+        tileLayer.contentsRect = CGRect(x: nx, y: caY, width: nw, height: nh)
+      } else {
+        tileLayer.contentsRect = CGRect(x: 0, y: 0, width: 1, height: 1)
+      }
+      fputs(
+        "Gecko multi-tile present pane_id=\(id.uuidString) layer_id=\(layerID) gen=\(generation) surface_id=\(IOSurfaceGetID(surface)) frame=\(NSStringFromRect(tileLayer.frame)) contentsRect=\(NSStringFromRect(tileLayer.contentsRect)) pane=\(Int(paneW))x\(Int(paneH))\n",
+        stderr)
+    }
+
+    /// Reconcile one complete Gecko stream snapshot and release removed tiles.
+    func finishGeckoMultiTileFrame(activeLayerIDs: [UInt64]) {
+      dispatchPrecondition(condition: .onQueue(.main))
+      let activeLayerSet = Set(activeLayerIDs)
+      let removed = Set(geckoMultiTileLayers.keys).subtracting(activeLayerSet)
+      for layerID in removed {
+        if let tileLayer = geckoMultiTileLayers.removeValue(forKey: layerID) {
+          tileLayer.contents = nil
+          tileLayer.removeFromSuperlayer()
+        }
+        if let surface = geckoMultiTileSurfaces.removeValue(forKey: layerID) {
+          Unmanaged.passUnretained(surface).release()
+        }
+        geckoMultiTileGenerations.removeValue(forKey: layerID)
+      }
+      for (order, layerID) in activeLayerIDs.enumerated() {
+        geckoMultiTileLayers[layerID]?.zPosition = CGFloat(order)
+      }
+      if activeLayerIDs.isEmpty {
+        geckoMultiTileRoot?.removeFromSuperlayer()
+        geckoMultiTileRoot = nil
+      }
+      let liveLayers = geckoMultiTileLayers.keys.sorted()
+      let liveSurfaces = liveLayers.compactMap { layerID -> String? in
+        guard let surface = geckoMultiTileSurfaces[layerID] else { return nil }
+        return "\(layerID):\(IOSurfaceGetID(surface))"
+      }
+      let liveGenerations = liveLayers.compactMap { layerID -> String? in
+        guard let generation = geckoMultiTileGenerations[layerID] else { return nil }
+        return "\(layerID):\(generation)"
+      }
+      fputs(
+        "Gecko multi-tile snapshot pane_id=\(id.uuidString) active=\(activeLayerIDs.count) removed=\(removed.count) retained=\(geckoMultiTileSurfaces.count) order=\(activeLayerIDs.map(String.init).joined(separator: ",")) layers=\(liveLayers.map(String.init).joined(separator: ",")) surfaces=\(liveSurfaces.joined(separator: ",")) generations=\(liveGenerations.joined(separator: ","))\n",
+        stderr)
+    }
