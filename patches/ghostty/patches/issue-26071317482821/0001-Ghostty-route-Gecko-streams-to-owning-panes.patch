+/// Exp4: present one Gecko multi-tile layer into the pane SurfaceView (CALayer + contentsRect).
+@_cdecl("termsurf_present_gecko_tile")
+// swiftlint:disable:next function_parameter_count
+func termsurf_present_gecko_tile(
+  _ paneIDPointer: UnsafePointer<CChar>?,
+  _ surfacePointer: UnsafeMutableRawPointer?,
+  _ layerID: UInt64,
+  _ generation: UInt64,
+  _ posX: Int32,
+  _ posY: Int32,
+  _ dispX: Int32,
+  _ dispY: Int32,
+  _ dispW: Int32,
+  _ dispH: Int32,
+  _ paneWPhys: Int32,
+  _ paneHPhys: Int32,
+  _ scale: Double
+) {
+  guard let paneIDPointer, let surfacePointer else { return }
+  let surface = Unmanaged<IOSurfaceRef>.fromOpaque(surfacePointer).takeUnretainedValue()
+  _ = Unmanaged.passUnretained(surface).retain()
+  let paneID = String(cString: paneIDPointer)
+  DispatchQueue.main.async {
+    guard let appDelegate = NSApplication.shared.delegate as? AppDelegate,
+          let uuid = UUID(uuidString: paneID),
+          let target = appDelegate.findSurface(forUUID: uuid)
+    else {
+      Unmanaged.passUnretained(surface).release()
+      return
+    }
+    target.presentGeckoMultiTile(
+      surface: surface,
+      layerID: layerID,
+      generation: generation,
+      posX: posX,
+      posY: posY,
+      dispX: dispX,
+      dispY: dispY,
+      dispW: dispW,
+      dispH: dispH,
+      paneWPhys: paneWPhys,
+      paneHPhys: paneHPhys,
+      scale: scale)
+  }
+}
+
+/// Reconcile the complete live layer set for one tab-owned Gecko stream.
+@_cdecl("termsurf_finish_gecko_tiles")
+func termsurf_finish_gecko_tiles(
+  _ paneIDPointer: UnsafePointer<CChar>?,
+  _ layerIDsPointer: UnsafePointer<UInt64>?,
+  _ count: Int32
+) {
+  guard let paneIDPointer, count >= 0 else { return }
+  let paneID = String(cString: paneIDPointer)
+  let layerIDs: [UInt64]
+  if let layerIDsPointer, count > 0 {
+    layerIDs = Array(UnsafeBufferPointer(start: layerIDsPointer, count: Int(count)))
+  } else {
+    layerIDs = []
+  }
+  DispatchQueue.main.async {
+    guard let appDelegate = NSApplication.shared.delegate as? AppDelegate,
+          let uuid = UUID(uuidString: paneID),
+          let target = appDelegate.findSurface(forUUID: uuid)
+    else { return }
+    target.finishGeckoMultiTileFrame(activeLayerIDs: layerIDs)
+  }
+}
