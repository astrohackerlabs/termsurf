+fn handleNavigate(req: ?*c.Termsurf__Navigate) void {
+    const navigate = req orelse {
+        log.warn("Navigate: missing payload", .{});
+        return;
+    };
+    const pane_id = cString(navigate.*.pane_id);
+    const url = cString(navigate.*.url);
+    if (pane_id.len == 0 or url.len == 0) {
+        log.warn("Navigate: invalid TUI request pane_id={s} url_len={}", .{ pane_id, url.len });
+        return;
+    }
+    const snapshot = snapshotBrowserInput(pane_id, false) orelse {
+        log.warn("Navigate: unknown or unready pane_id={s}", .{pane_id});
+        return;
+    };
+
+    var forwarded: c.Termsurf__Navigate = undefined;
+    c.termsurf__navigate__init(&forwarded);
+    forwarded.tab_id = snapshot.tab_id;
+    forwarded.url = navigate.*.url;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATE;
+    wrapper.unnamed_0.navigate = &forwarded;
+    sendProtobuf(snapshot.browser_fd, &wrapper) catch |err| {
+        log.warn(
+            "Navigate send failed pane_id={s} tab_id={} err={}",
+            .{ snapshot.paneId(), snapshot.tab_id, err },
+        );
+        return;
+    };
+    log.info(
+        "Navigate: pane_id={s} tab_id={} url={s}",
+        .{ snapshot.paneId(), snapshot.tab_id, url },
+    );
+}
