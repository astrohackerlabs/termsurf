+    struct TermSurfPointerCapture {
+      private(set) var mouseButtons: Set<Int> = []
+      private(set) var scrollOwned = false
+      private(set) var awaitingMomentum = false
+
+      var ownsMouseSequence: Bool { !mouseButtons.isEmpty }
+
+      mutating func beginMouse(button: Int, hit: Bool) -> Bool {
+        guard hit else { return false }
+        mouseButtons.insert(button)
+        return true
+      }
+
+      func ownsMouse(button: Int) -> Bool {
+        mouseButtons.contains(button)
+      }
+
+      mutating func endMouse(button: Int) {
+        mouseButtons.remove(button)
+      }
+
+      mutating func ownsScroll(hit: Bool, phase: UInt64, momentumPhase: UInt64) -> Bool {
+        if awaitingMomentum {
+          awaitingMomentum = false
+          if momentumPhase != 0 {
+            scrollOwned = true
+          } else {
+            scrollOwned = hit
+          }
+        }
+
+        let owned: Bool
+        if scrollOwned {
+          owned = true
+        } else if hit {
+          owned = true
+          scrollOwned = phase != 0 || momentumPhase != 0
+        } else {
+          owned = false
+        }
+
+        if owned {
+          if phase & (8 | 16) != 0 {
+            scrollOwned = false
+            awaitingMomentum = phase & 8 != 0
+          }
+          if momentumPhase & (8 | 16) != 0 {
+            scrollOwned = false
+            awaitingMomentum = false
+          }
+        }
+        return owned
+      }
+
+      mutating func reset() {
+        mouseButtons.removeAll()
+        scrollOwned = false
+        awaitingMomentum = false
+      }
+    }
+
+    static func termSurfShouldConsumeFocusTransferClick(
+      browserOwnsClick: Bool,
+      appActive: Bool,
+      windowKey: Bool
+    ) -> Bool {
+      !browserOwnsClick && appActive && windowKey
+    }
+
+    static func termSurfMouseButtonModifier(buttonNumber: Int) -> UInt64 {
+      switch buttonNumber {
+      case 0: return 64
+      case 1: return 256
+      case 2: return 128
+      default: return 0
+      }
+    }
