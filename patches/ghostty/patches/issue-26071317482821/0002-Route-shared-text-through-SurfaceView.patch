+private var termsurfRawDebugInputEnabled: Bool {
+  ProcessInfo.processInfo.environment["TERMSURF_TEST_SCRIPTED_BROWSER_INPUT"] == "1"
+}
+
+private var termsurfSurfaceTextInputEnabled: Bool {
+  ProcessInfo.processInfo.environment["TERMSURF_TEST_SURFACE_TEXT_INPUT"] == "1"
+}
+
+private func termsurfDebugInputRange(
+  _ userInfo: [AnyHashable: Any], prefix: String, defaultRange: NSRange
+) throws -> NSRange {
+  let locationKey = "\(prefix)_location"
+  let lengthKey = "\(prefix)_length"
+  guard userInfo[locationKey] != nil || userInfo[lengthKey] != nil else {
+    return defaultRange
+  }
+  let location = try termsurfDebugInputRequiredInt(userInfo[locationKey], name: locationKey)
+  let length = try termsurfDebugInputRequiredInt(userInfo[lengthKey], name: lengthKey)
+  guard location >= -1, length >= 0, location != -1 || length == 0 else {
+    throw TermSurfDebugInputError.missingOrInvalid("\(prefix) range")
+  }
+  return NSRange(location: location == -1 ? NSNotFound : location, length: length)
+}
+
+private func termsurfLogSurfaceTextInput(
+  kind: String,
+  paneID: String,
+  text: String,
+  selectedRange: NSRange,
+  replacementRange: NSRange
+) {
+  func describe(_ range: NSRange) -> String {
+    range.location == NSNotFound ? "-1:-1" : "\(range.location):\(range.length)"
+  }
+  termsurfLogGeometry(
+    "layer=bridge event=surface_text_input_seam scenario=\(termsurfGeometryScenario()) identity=\(termsurfGeometryIdentity(paneID: paneID)) visible=unknown note=kind=\(kind) utf8_len=\(text.utf8.count) selected=\(describe(selectedRange)) replacement=\(describe(replacementRange)) boundary=NSTextInputClient"
+  )
+}
+
 private func termsurfDebugInputDouble(_ value: Any?, name: String) throws -> Double {
   if let value = value as? Double { return value }
   if let value = value as? NSNumber { return value.doubleValue }
@@ -307,6 +416,32 @@ func termsurf_clear_overlay(_ paneIDPointer: UnsafePointer<CChar>?) {
