+@_cdecl("termsurf_surface_browsing_changed")
+func termsurf_surface_browsing_changed(
+  _ paneIDPointer: UnsafePointer<CChar>?, _ browsing: Int32
+) {
+  guard let paneIDPointer else {
+    termsurfLogOverlay("TermSurf browsing change rejected: missing pane id")
+    return
+  }
+  let paneID = String(cString: paneIDPointer)
+  let apply = {
+    guard let appDelegate = NSApplication.shared.delegate as? AppDelegate,
+      let uuid = UUID(uuidString: paneID),
+      let target = appDelegate.findSurface(forUUID: uuid)
+    else {
+      termsurfLogOverlay("TermSurf browsing change rejected: no surface pane_id=\(paneID)")
+      return
+    }
+    target.termSurfBrowsingDidChange(browsing != 0)
+  }
+  if Thread.isMainThread {
+    apply()
+  } else {
+    DispatchQueue.main.sync(execute: apply)
+  }
+}
