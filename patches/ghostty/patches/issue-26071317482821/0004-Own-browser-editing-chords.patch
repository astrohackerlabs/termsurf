+pub export fn termsurf_browser_tab_id_for_pane(pane_id: [*:0]const u8) i64 {
+    return termsurf.browserTabIdForPane(std.mem.span(pane_id));
+}
+
 pub export fn termsurf_forward_key_event(
     pane_id: [*:0]const u8,
     event_type: [*:0]const u8,
