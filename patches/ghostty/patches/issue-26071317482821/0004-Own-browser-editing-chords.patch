@@ -127,6 +127,68 @@ struct SurfaceViewAppKitTests {
         #expect(Ghostty.SurfaceView.termSurfMouseButtonModifier(buttonNumber: 3) == 0)
     }
 
+    @Test(arguments: [
+        (UInt16(0x00), UInt64(8)),
+        (UInt16(0x08), UInt64(8)),
+        (UInt16(0x07), UInt64(8)),
+        (UInt16(0x09), UInt64(8)),
+        (UInt16(0x06), UInt64(8)),
+        (UInt16(0x06), UInt64(9)),
+    ])
+    func browserEditingChordsAreExact(keyCode: UInt16, modifiers: UInt64) {
+        #expect(
+            Ghostty.SurfaceView.termSurfIsBrowserEditingKeyEquivalent(
+                keyCode: keyCode,
+                modifiers: modifiers,
+                focused: true,
+                browsing: true,
+                hasOverlay: true
+            )
+        )
+    }
+
+    @Test(arguments: [
+        (UInt16(0x00), UInt64(0)),
+        (UInt16(0x00), UInt64(9)),
+        (UInt16(0x08), UInt64(1)),
+        (UInt16(0x08), UInt64(10)),
+        (UInt16(0x07), UInt64(12)),
+        (UInt16(0x09), UInt64(8 | 64)),
+        (UInt16(0x01), UInt64(8)),
+    ])
+    func nonEditingChordsRemainOutsideBrowserInterceptor(
+        keyCode: UInt16,
+        modifiers: UInt64
+    ) {
+        #expect(
+            Ghostty.SurfaceView.termSurfIsBrowserEditingKeyEquivalent(
+                keyCode: keyCode,
+                modifiers: modifiers,
+                focused: true,
+                browsing: true,
+                hasOverlay: true
+            ) == false
+        )
+    }
+
+    @Test func browserEditingChordsRequireFocusedLiveOverlay() {
+        for state in [
+            (false, true, true),
+            (true, false, true),
+            (true, true, false),
+        ] {
+            #expect(
+                Ghostty.SurfaceView.termSurfIsBrowserEditingKeyEquivalent(
+                    keyCode: 0x08,
+                    modifiers: 8,
+                    focused: state.0,
+                    browsing: state.1,
+                    hasOverlay: state.2
+                ) == false
+            )
+        }
+    }
+
     @Test func geckoExternalGridUsesTopOriginForInputAndBottomOriginForAppKit() {
         let topOrigin = Ghostty.SurfaceView.termSurfGridFrame(
             col: 1,
diff --git a/src/apprt/termsurf.zig b/src/apprt/termsurf.zig
index af8da8fbc..6f73b8ace 100644
--- a/src/apprt/termsurf.zig
+++ b/src/apprt/termsurf.zig
@@ -3015,6 +3015,13 @@ pub fn forwardKeyEvent(
     return true;
 }
 
+pub fn browserTabIdForPane(pane_id: []const u8) i64 {
+    const pane_index = findPane(pane_id) orelse return 0;
+    const pane = &panes[pane_index];
+    if (!pane.browsing or pane.tab_id <= 0) return 0;
+    return pane.tab_id;
+}
+
 pub fn forwardTextInput(
     pane_id: []const u8,
     input_type: []const u8,
@@ -6744,7 +6751,13 @@ test "termsurf text input is exhaustive and tab owned" {
     panes[0].tab_id = 41;
     panes[1].tab_id = 73;
 
+    try testing.expectEqual(@as(i64, 41), browserTabIdForPane("pane-a"));
+    try testing.expectEqual(@as(i64, 73), browserTabIdForPane("pane-b"));
+    try testing.expectEqual(@as(i64, 0), browserTabIdForPane("missing"));
+
     try testing.expect(!forwardKeyEvent("pane-a", "insert", 65, "", 0));
+    try testing.expect(!forwardKeyEvent("pane-a", "select-all", 65, "", 8));
+    try testing.expect(!forwardKeyEvent("pane-a", "copy", 67, "", 8));
     try testing.expect(!forwardKeyEvent("pane-a", "down", 65, "a", 0));
     try testing.expect(forwardKeyEvent("pane-a", "down", 65, "", 0));
     const key = try readTestMessage(browser[1], testing.allocator);
diff --git a/src/main_c.zig b/src/main_c.zig
index f7b60a28e..d85b0c3e3 100644
--- a/src/main_c.zig
+++ b/src/main_c.zig
