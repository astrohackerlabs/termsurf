@@ -2392,6 +2392,24 @@ extension Ghostty {
         return false
       }
 
+      if isTermSurfBrowserEditingKeyEquivalent(event) {
+        let paneID = id.uuidString
+        let tabID = paneID.withCString { termsurf_browser_tab_id_for_pane($0) }
+        let windowsKeyCode = termSurfWindowsKeyCode(for: event)
+        let modifiers = termSurfModifiers(event.modifierFlags)
+        let forwarded = forwardTermSurfKeyDown(event)
+        termSurfLogGeometry(
+          event:
+            forwarded
+            ? "perform_key_equivalent_editing_forwarded"
+            : "perform_key_equivalent_editing_rejected",
+          browserTabID: String(tabID),
+          note:
+            "pane_id=\(paneID) tab_id=\(tabID) virtual_key_code=\(event.keyCode) windows_key_code=\(windowsKeyCode) modifiers=\(modifiers) binding=false menu=false current_url_copy=false terminal_fallback=false suppressed=\(!forwarded)"
+        )
+        return true
+      }
+
       if isTermSurfBrowserNavigationKeyEquivalent(event) {
         if forwardTermSurfKeyDown(event) {
           termSurfLogGeometry(
@@ -2651,6 +2669,24 @@ extension Ghostty {
       !browserOwnsClick && appActive && windowKey
     }
 
+    static func termSurfIsBrowserEditingKeyEquivalent(
+      keyCode: UInt16,
+      modifiers: UInt64,
+      focused: Bool,
+      browsing: Bool,
+      hasOverlay: Bool
+    ) -> Bool {
+      guard focused, browsing, hasOverlay else { return false }
+      switch keyCode {
+      case 0x00, 0x08, 0x07, 0x09:
+        return modifiers == 8
+      case 0x06:
+        return modifiers == 8 || modifiers == 9
+      default:
+        return false
+      }
+    }
+
     static func termSurfMouseButtonModifier(buttonNumber: Int) -> UInt64 {
       switch buttonNumber {
       case 0: return 64
@@ -2929,6 +2965,15 @@ extension Ghostty {
       }
     }
 
+    private func isTermSurfBrowserEditingKeyEquivalent(_ event: NSEvent) -> Bool {
+      Self.termSurfIsBrowserEditingKeyEquivalent(
+        keyCode: event.keyCode,
+        modifiers: termSurfModifiers(event.modifierFlags),
+        focused: focused,
+        browsing: termsurfBrowserBrowsing,
+        hasOverlay: termSurfScriptHasActiveOverlay)
+    }
+
     private func forwardTermSurfKeyEvent(
       _ event: NSEvent,
       type: String,
