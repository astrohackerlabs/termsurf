 .../Surface View/SurfaceView_AppKit.swift     | 45 ++++++++++++++
 .../Ghostty/SurfaceViewAppKitTests.swift      | 62 +++++++++++++++++++
 src/apprt/termsurf.zig                        | 13 ++++
 src/main_c.zig                                |  4 ++
 5 files changed, 125 insertions(+)

diff --git a/include/ghostty.h b/include/ghostty.h
