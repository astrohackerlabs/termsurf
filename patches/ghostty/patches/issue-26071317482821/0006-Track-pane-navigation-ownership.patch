+    struct TermSurfBrowserKeyState {
+      enum KeyUpOwnership: Equatable {
+        case browser
+        case product
+        case duplicate
+        case unowned
+      }
+
+      private var pressed: Set<UInt16> = []
+      private var productPressed: Set<UInt16> = []
+      private var released: Set<UInt16> = []
+
+      mutating func beginDown(_ keyCode: UInt16) {
+        released.remove(keyCode)
+      }
+
+      mutating func acceptDown(_ keyCode: UInt16) {
+        productPressed.remove(keyCode)
+        pressed.insert(keyCode)
+      }
+
+      mutating func acceptProductDown(_ keyCode: UInt16) {
+        released.remove(keyCode)
+        pressed.remove(keyCode)
+        productPressed.insert(keyCode)
+      }
+
+      func isPressed(_ keyCode: UInt16) -> Bool {
+        pressed.contains(keyCode)
+      }
+
+      mutating func claimUp(_ keyCode: UInt16) -> KeyUpOwnership {
+        if released.contains(keyCode) {
+          return .duplicate
+        }
+        if pressed.remove(keyCode) != nil {
+          released.insert(keyCode)
+          return .browser
+        }
+        if productPressed.remove(keyCode) != nil {
+          released.insert(keyCode)
+          return .product
+        }
+        return .unowned
+      }
+
+      mutating func reset() {
+        pressed.removeAll()
+        productPressed.removeAll()
+        released.removeAll()
+      }
+    }
+
