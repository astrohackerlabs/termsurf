         }
@@ -2919,20 +2991,20 @@ extension Ghostty {
             "key_code=\(event.keyCode) browsing=\(termsurfBrowserBrowsing) changed=\(changed != 0) terminal_fallback=false"
         )
         if changed != 0 {
-          termsurfPressedBrowserKeys.insert(event.keyCode)
+          termsurfBrowserKeyState.acceptDown(event.keyCode)
