       }
 
       let type: String
-      if event.isARepeat || termsurfPressedBrowserKeys.contains(event.keyCode) {
+      if event.isARepeat || termsurfBrowserKeyState.isPressed(event.keyCode) {
         type = "repeat"
       } else {
