       }
       let forwarded = forwardTermSurfKeyEvent(event, type: type, text: "")
       if forwarded {
-        termsurfPressedBrowserKeys.insert(event.keyCode)
+        termsurfBrowserKeyState.acceptDown(event.keyCode)
         let commandModifiers = event.modifierFlags.intersection([.command, .control])
