@@ -2942,22 +3014,37 @@ extension Ghostty {
     }
 
     private func forwardTermSurfKeyUp(_ event: NSEvent) -> Bool {
-      let browserOwned = termsurfPressedBrowserKeys.contains(event.keyCode)
-      let forwarded = forwardTermSurfKeyEvent(event, type: "up")
-      if forwarded {
-        termsurfPressedBrowserKeys.remove(event.keyCode)
+      switch termsurfBrowserKeyState.claimUp(event.keyCode) {
+      case .duplicate:
+        termSurfLogGeometry(
+          event: "key_up_browser_duplicate_suppressed",
+          note:
+            "key_code=\(event.keyCode) browsing=\(termsurfBrowserBrowsing) terminal_fallback=false"
+        )
         return true
-      }
-      if browserOwned {
-        termsurfPressedBrowserKeys.remove(event.keyCode)
+      case .product:
         termSurfLogGeometry(
-          event: "key_up_browser_owned_suppressed",
+          event: "key_up_product_owned_suppressed",
           note:
             "key_code=\(event.keyCode) browsing=\(termsurfBrowserBrowsing) terminal_fallback=false"
         )
         return true
+      case .unowned:
+        return false
+      case .browser:
+        break
       }
-      return false
+
+      let forwarded = forwardTermSurfKeyEvent(event, type: "up")
+      if forwarded {
+        return true
+      }
+      termSurfLogGeometry(
+        event: "key_up_browser_owned_suppressed",
+        note:
+          "key_code=\(event.keyCode) browsing=\(termsurfBrowserBrowsing) terminal_fallback=false"
+      )
+      return true
     }
 
