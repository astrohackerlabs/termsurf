+    @Test func browserKeyOwnershipSuppressesDuplicateReleaseUntilNextDown() {
+        var state = Ghostty.SurfaceView.TermSurfBrowserKeyState()
+
+        #expect(state.claimUp(0x09) == .unowned)
+        state.beginDown(0x09)
+        state.acceptDown(0x09)
+        #expect(state.isPressed(0x09))
+        #expect(state.claimUp(0x09) == .browser)
+        #expect(state.claimUp(0x09) == .duplicate)
+
+        state.beginDown(0x09)
+        state.acceptDown(0x09)
+        #expect(state.claimUp(0x09) == .browser)
+        state.reset()
+        #expect(state.claimUp(0x09) == .unowned)
+    }
+
+    @Test func productKeyOwnershipConsumesReleaseWithoutBrowserOwnership() {
+        var state = Ghostty.SurfaceView.TermSurfBrowserKeyState()
+
+        state.acceptProductDown(0x25)
+        #expect(!state.isPressed(0x25))
+        #expect(state.claimUp(0x25) == .product)
+        #expect(state.claimUp(0x25) == .duplicate)
+
+        state.beginDown(0x25)
+        state.acceptDown(0x25)
+        #expect(state.claimUp(0x25) == .browser)
+    }
