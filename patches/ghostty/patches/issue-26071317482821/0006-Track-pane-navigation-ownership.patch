+pub fn navigationActiveForPane(pane_id: []const u8) bool {
+    state_mutex.lock();
+    defer state_mutex.unlock();
+    const pane_index = findPane(pane_id) orelse return false;
+    const pane = &panes[pane_index];
+    return pane.tab_id > 0 and (pane.navigation_pending or pane.navigation_loading);
