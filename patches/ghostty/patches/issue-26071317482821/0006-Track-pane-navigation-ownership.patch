+fn snapshotNavigate(pane_id: []const u8) ?BrowserInputSnapshot {
+    state_mutex.lock();
+    defer state_mutex.unlock();
+
+    const pane_index = findPane(pane_id) orelse return null;
+    const pane = &panes[pane_index];
+    if (pane.tab_id <= 0) return null;
+    const server_index = findServer(pane.profileName(), pane.browserName()) orelse return null;
+    if (servers[server_index].attached_fd < 0) return null;
+
+    var snapshot: BrowserInputSnapshot = .{
+        .browser_fd = servers[server_index].attached_fd,
+        .tab_id = pane.tab_id,
+    };
+    if (!copyText(&snapshot.pane_id, &snapshot.pane_id_len, pane.paneId())) return null;
+    pane.navigation_pending = true;
+    return snapshot;
+}
+
+fn clearNavigationPending(pane_id: []const u8, tab_id: i64) void {
+    state_mutex.lock();
+    defer state_mutex.unlock();
+    const pane_index = findPane(pane_id) orelse return;
+    if (panes[pane_index].tab_id == tab_id) {
+        panes[pane_index].navigation_pending = false;
+    }
+}
+
+fn handleLoadingState(fd: std.posix.fd_t, req: ?*c.Termsurf__LoadingState) void {
+    const loading = req orelse {
+        log.warn("LoadingState: missing payload", .{});
+        return;
+    };
+    const state = cString(loading.*.state);
+
+    state_mutex.lock();
+    defer state_mutex.unlock();
+
+    const server_index = findServerByFd(fd) orelse {
+        log.warn("LoadingState: unknown browser fd={} tab_id={}", .{ fd, loading.*.tab_id });
+        return;
+    };
+    const profile = servers[server_index].profileName();
+    const browser = servers[server_index].browserName();
+    const lookup_index = findTabLookup(profile, browser, loading.*.tab_id) orelse {
+        log.warn(
+            "LoadingState: unknown tab key={s}/{s} tab_id={} state={s}",
+            .{ profile, browser, loading.*.tab_id, state },
+        );
+        return;
+    };
+    const pane_id = tab_lookups[lookup_index].paneId();
+    const pane_index = findPane(pane_id) orelse {
+        log.warn("LoadingState: tab maps to missing pane_id={s}", .{pane_id});
+        return;
+    };
+    const pane = &panes[pane_index];
+    if (std.mem.eql(u8, state, "loading") or std.mem.eql(u8, state, "progress")) {
+        pane.navigation_loading = true;
+    } else if (std.mem.eql(u8, state, "done") or std.mem.eql(u8, state, "error")) {
+        pane.navigation_pending = false;
+        pane.navigation_loading = false;
+    } else {
+        log.warn(
+            "LoadingState: unsupported state pane_id={s} tab_id={} state={s}",
+            .{ pane.paneId(), loading.*.tab_id, state },
+        );
+        return;
+    }
+    log.info(
+        "LoadingState: pane_id={s} tab_id={} state={s} progress={} pending={} loading={}",
+        .{ pane.paneId(), loading.*.tab_id, state, loading.*.progress, pane.navigation_pending, pane.navigation_loading },
+    );
+}
