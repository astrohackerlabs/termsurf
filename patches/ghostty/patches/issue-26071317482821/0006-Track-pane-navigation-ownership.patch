 pub fn browserTabIdForPane(pane_id: []const u8) i64 {
+    state_mutex.lock();
+    defer state_mutex.unlock();
     const pane_index = findPane(pane_id) orelse return 0;
     const pane = &panes[pane_index];
     if (!pane.browsing or pane.tab_id <= 0) return 0;
