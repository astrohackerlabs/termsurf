                 },
@@ -3459,6 +3479,53 @@ fn handleNavigate(req: ?*c.Termsurf__Navigate) void {
     );
 }
 
+fn handleNavigationAction(req: ?*c.Termsurf__NavigationAction) void {
+    const action_req = req orelse {
+        log.warn("NavigationAction: missing payload", .{});
+        return;
+    };
+    const pane_id = cString(action_req.*.pane_id);
+    const action = cString(action_req.*.action);
+    if (action_req.*.tab_id != 0 or pane_id.len == 0 or !validNavigationAction(action)) {
+        log.warn(
+            "NavigationAction: invalid TUI request pane_id={s} tab_id={} action={s}",
+            .{ pane_id, action_req.*.tab_id, action },
+        );
+        return;
+    }
+    const snapshot = snapshotNavigationAction(pane_id) orelse {
+        log.warn("NavigationAction: unknown or unready pane_id={s}", .{pane_id});
+        return;
+    };
+
+    var forwarded: c.Termsurf__NavigationAction = undefined;
+    c.termsurf__navigation_action__init(&forwarded);
+    forwarded.tab_id = snapshot.tab_id;
+    forwarded.action = action_req.*.action;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION;
+    wrapper.unnamed_0.navigation_action = &forwarded;
+    sendProtobuf(snapshot.browser_fd, &wrapper) catch |err| {
+        log.warn(
+            "NavigationAction send failed pane_id={s} tab_id={} action={s} err={}",
+            .{ snapshot.paneId(), snapshot.tab_id, action, err },
+        );
+        return;
+    };
+    log.info(
+        "NavigationAction: pane_id={s} tab_id={} action={s}",
+        .{ snapshot.paneId(), snapshot.tab_id, action },
+    );
+}
+
+fn validNavigationAction(action: []const u8) bool {
+    return std.mem.eql(u8, action, "back") or
+        std.mem.eql(u8, action, "forward") or
+        std.mem.eql(u8, action, "refresh");
+}
+
 fn snapshotNavigate(pane_id: []const u8) ?BrowserInputSnapshot {
     state_mutex.lock();
     defer state_mutex.unlock();
@@ -3478,6 +3545,24 @@ fn snapshotNavigate(pane_id: []const u8) ?BrowserInputSnapshot {
     return snapshot;
 }
 
+fn snapshotNavigationAction(pane_id: []const u8) ?BrowserInputSnapshot {
+    state_mutex.lock();
+    defer state_mutex.unlock();
+
+    const pane_index = findPane(pane_id) orelse return null;
+    const pane = &panes[pane_index];
+    if (pane.tab_id <= 0) return null;
+    const server_index = findServer(pane.profileName(), pane.browserName()) orelse return null;
+    if (servers[server_index].attached_fd < 0) return null;
+
+    var snapshot: BrowserInputSnapshot = .{
+        .browser_fd = servers[server_index].attached_fd,
+        .tab_id = pane.tab_id,
+    };
+    if (!copyText(&snapshot.pane_id, &snapshot.pane_id_len, pane.paneId())) return null;
+    return snapshot;
+}
+
 fn clearNavigationPending(pane_id: []const u8, tab_id: i64) void {
     state_mutex.lock();
     defer state_mutex.unlock();
@@ -3534,6 +3619,91 @@ fn handleLoadingState(fd: std.posix.fd_t, req: ?*c.Termsurf__LoadingState) void
     );
 }
 
+fn handleNavigationState(fd: std.posix.fd_t, req: ?*c.Termsurf__NavigationState) void {
+    const navigation_state = req orelse {
+        log.warn("NavigationState: missing payload", .{});
+        return;
+    };
+    if (navigation_state.*.tab_id == 0) {
+        log.warn("NavigationState: missing tab id", .{});
+        return;
+    }
+
+    var snapshot: ?NavigationStateSnapshot = null;
+
+    state_mutex.lock();
+    const server_index = findServerByFd(fd) orelse {
+        log.warn("NavigationState: unknown browser fd={} tab_id={}", .{ fd, navigation_state.*.tab_id });
+        state_mutex.unlock();
+        return;
+    };
+    const profile = servers[server_index].profileName();
+    const browser = servers[server_index].browserName();
+    const lookup_index = findTabLookup(profile, browser, navigation_state.*.tab_id) orelse {
+        log.warn(
+            "NavigationState: unknown tab key={s}/{s} tab_id={}",
+            .{ profile, browser, navigation_state.*.tab_id },
+        );
+        state_mutex.unlock();
+        return;
+    };
+    const pane_id = tab_lookups[lookup_index].paneId();
+    const pane_index = findPane(pane_id) orelse {
+        log.warn("NavigationState: tab maps to missing pane_id={s}", .{pane_id});
+        state_mutex.unlock();
+        return;
+    };
+    const pane = &panes[pane_index];
+    if (pane.tui_fd >= 0) {
+        var value: NavigationStateSnapshot = .{
+            .tui_fd = pane.tui_fd,
+            .tab_id = navigation_state.*.tab_id,
+            .can_go_back = navigation_state.*.can_go_back != 0,
+            .can_go_forward = navigation_state.*.can_go_forward != 0,
+            .can_refresh = navigation_state.*.can_refresh != 0,
+        };
+        if (copyText(&value.pane_id, &value.pane_id_len, pane.paneId())) {
+            snapshot = value;
+        }
+    }
+    log.info(
+        "NavigationState: pane_id={s} tab_id={} back={} forward={} refresh={}",
+        .{
+            pane.paneId(),
+            navigation_state.*.tab_id,
+            navigation_state.*.can_go_back != 0,
+            navigation_state.*.can_go_forward != 0,
+            navigation_state.*.can_refresh != 0,
+        },
+    );
+    state_mutex.unlock();
+
+    if (snapshot) |state_snapshot| {
+        sendNavigationStateToTui(&state_snapshot) catch |err| {
+            log.warn(
+                "NavigationState send failed pane_id={s} tab_id={} err={}",
+                .{ state_snapshot.paneId(), state_snapshot.tab_id, err },
+            );
+        };
+    }
+}
+
+fn sendNavigationStateToTui(snapshot: *const NavigationStateSnapshot) !void {
+    var state: c.Termsurf__NavigationState = undefined;
+    c.termsurf__navigation_state__init(&state);
+    state.tab_id = snapshot.tab_id;
+    state.can_go_back = if (snapshot.can_go_back) 1 else 0;
+    state.can_go_forward = if (snapshot.can_go_forward) 1 else 0;
+    state.can_refresh = if (snapshot.can_refresh) 1 else 0;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE;
+    wrapper.unnamed_0.navigation_state = &state;
+
+    try sendProtobuf(snapshot.tui_fd, &wrapper);
+}
+
 fn snapshotModeChanged(pane: *const PaneState, browsing: bool) ?ModeChangedSnapshot {
     if (pane.tui_fd < 0) return null;
 
