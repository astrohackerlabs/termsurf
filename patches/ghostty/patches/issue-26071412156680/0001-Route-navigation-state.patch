@@ -7807,6 +7979,79 @@ test "termsurf TUI navigate resolves pane to owning browser tab" {
     try testing.expect(!navigationActiveForPane("pane-unknown"));
 }
 
+test "termsurf TUI navigation action resolves pane to owning browser tab" {
+    const testing = std.testing;
+
+    resetTermsurfStateForTest();
+    defer resetTermsurfStateForTest();
+
+    var browser = try testSocketPair();
+    defer testCloseSocketPair(&browser);
+    var tui = try testSocketPair();
+    defer testCloseSocketPair(&tui);
+
+    try testSetPendingServer(0, "default", "webkit");
+    servers[0].attached_fd = browser[0];
+    try testSetPane(0, "pane-webkit", "default", "webkit", "https://old.test/", tui[0]);
+    panes[0].tab_id = 77;
+    _ = upsertTabLookup(&panes[0], 77);
+
+    var action: c.Termsurf__NavigationAction = undefined;
+    c.termsurf__navigation_action__init(&action);
+    action.pane_id = @constCast("pane-webkit");
+    action.action = @constCast("back");
+    handleNavigationAction(&action);
+
+    const forwarded = try readTestMessage(browser[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(forwarded, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION),
+        forwarded.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 77), forwarded.*.unnamed_0.navigation_action.*.tab_id);
+    try testing.expectEqualStrings("", cString(forwarded.*.unnamed_0.navigation_action.*.pane_id));
+    try testing.expectEqualStrings("back", cString(forwarded.*.unnamed_0.navigation_action.*.action));
+    try testing.expect(!panes[0].navigation_pending);
+    try testing.expect(!navigationActiveForPane("pane-webkit"));
+}
+
+test "termsurf browser navigation state relays only through owning pane" {
+    const testing = std.testing;
+
+    resetTermsurfStateForTest();
+    defer resetTermsurfStateForTest();
+
+    var browser = try testSocketPair();
+    defer testCloseSocketPair(&browser);
+    var tui = try testSocketPair();
+    defer testCloseSocketPair(&tui);
+
+    try testSetPendingServer(0, "default", "chromium");
+    servers[0].attached_fd = browser[0];
+    try testSetPane(0, "pane-chromium", "default", "chromium", "https://old.test/", tui[0]);
+    panes[0].tab_id = 88;
+    _ = upsertTabLookup(&panes[0], 88);
+
+    var state: c.Termsurf__NavigationState = undefined;
+    c.termsurf__navigation_state__init(&state);
+    state.tab_id = 88;
+    state.can_go_back = 1;
+    state.can_go_forward = 0;
+    state.can_refresh = 1;
+    handleNavigationState(browser[0], &state);
+
+    const relayed = try readTestMessage(tui[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(relayed, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE),
+        relayed.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 88), relayed.*.unnamed_0.navigation_state.*.tab_id);
+    try testing.expectEqual(@as(c_int, 1), relayed.*.unnamed_0.navigation_state.*.can_go_back);
+    try testing.expectEqual(@as(c_int, 0), relayed.*.unnamed_0.navigation_state.*.can_go_forward);
+    try testing.expectEqual(@as(c_int, 1), relayed.*.unnamed_0.navigation_state.*.can_refresh);
+}
+
 test "termsurf navigation send failure clears pending state" {
     const testing = std.testing;
 
