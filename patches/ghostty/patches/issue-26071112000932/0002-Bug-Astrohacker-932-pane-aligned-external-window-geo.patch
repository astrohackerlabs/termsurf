+test "appkit bottom left to top left dip conversion" {
+    const testing = std.testing;
+    // Main display: maxY=900, rect bottom-left y=100 height=200 → top-left y=600
+    const a = appKitBottomLeftToTopLeftDIP(10, 100, 200, 900);
+    try testing.expectEqual(@as(f64, 10), a.x);
+    try testing.expectEqual(@as(f64, 600), a.y);
+    // Secondary display above main (origin.y=900): rect at y=1000 h=100, mainMaxY=900
+    // Global top-left Y = 900 - (1000+100) = -200
+    const b = appKitBottomLeftToTopLeftDIP(50, 1000, 100, 900);
+    try testing.expectEqual(@as(f64, 50), b.x);
+    try testing.expectEqual(@as(f64, -200), b.y);
+}
