+/// Convert AppKit bottom-left global rect to top-left DIP using menu-bar display maxY.
+func termsurfAppKitBottomLeftToTopLeftDIP(
+  originX: CGFloat,
+  originY: CGFloat,
+  height: CGFloat,
+  mainMaxY: CGFloat
+) -> (x: CGFloat, y: CGFloat) {
+  (originX, mainMaxY - (originY + height))
+}
+
+@_cdecl("termsurf_present_external_window_geometry")
+func termsurf_present_external_window_geometry(
+  _ paneIDPointer: UnsafePointer<CChar>?,
+  _ col: UInt64,
+  _ row: UInt64,
+  _ width: UInt64,
+  _ height: UInt64
+) {
+  guard let paneIDPointer else {
+    termsurfLogOverlay("TermSurf external geometry rejected: missing pane id")
+    return
+  }
+  let paneID = String(cString: paneIDPointer)
+  termsurfLogOverlay(
+    "TermSurf external geometry request pane_id=\(paneID) grid=\(width)x\(height)+\(col)+\(row)"
+  )
+  DispatchQueue.main.async {
+    guard let appDelegate = NSApplication.shared.delegate as? AppDelegate else {
+      termsurfLogOverlay("TermSurf external geometry rejected: missing app delegate")
+      return
+    }
+    guard let uuid = UUID(uuidString: paneID) else {
+      termsurfLogOverlay("TermSurf external geometry rejected: invalid pane id \(paneID)")
+      return
+    }
+    guard let target = appDelegate.findSurface(forUUID: uuid) else {
+      termsurfLogOverlay("TermSurf external geometry rejected: no surface for pane id \(paneID)")
+      return
+    }
+    target.reportTermSurfExternalWindowGeometry(
+      col: col,
+      row: row,
+      width: width,
+      height: height)
+  }
+}
+
