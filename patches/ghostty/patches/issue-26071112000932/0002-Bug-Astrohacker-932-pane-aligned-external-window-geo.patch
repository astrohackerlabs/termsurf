+fn requestExternalWindowGeometry(pane_id: []const u8) void {
+    state_mutex.lock();
+    const pane_index = findPane(pane_id) orelse {
+        state_mutex.unlock();
+        return;
+    };
+    var pane_id_z_buf: [max_pane_id_len + 1]u8 = undefined;
+    const pane_id_z = std.fmt.bufPrintZ(&pane_id_z_buf, "{s}", .{pane_id}) catch {
+        state_mutex.unlock();
+        return;
+    };
+    const col = panes[pane_index].col;
+    const row = panes[pane_index].row;
+    const width = panes[pane_index].width;
+    const height = panes[pane_index].height;
+    state_mutex.unlock();
+    log.info(
+        "external_geometry_request pane_id={s} grid={}x{}+{}+{}",
+        .{ pane_id, width, height, col, row },
+    );
+    termsurf_present_external_window_geometry(pane_id_z.ptr, col, row, width, height);
+}
+
+/// Re-request external geometry for all live gecko panes (window-move follow).
+fn refreshAllGeckoExternalGeometry() void {
+    var ids: [max_panes][max_pane_id_len]u8 = undefined;
+    var lens: [max_panes]usize = undefined;
+    var n: usize = 0;
+    state_mutex.lock();
+    for (&panes) |*pane| {
+        if (!pane.in_use) continue;
+        if (!std.mem.eql(u8, pane.browserName(), "gecko")) continue;
+        if (pane.tab_id == 0) continue;
+        const id = pane.paneId();
+        @memcpy(ids[n][0..id.len], id);
+        lens[n] = id.len;
+        n += 1;
+    }
+    state_mutex.unlock();
+    var i: usize = 0;
+    while (i < n) : (i += 1) {
+        requestExternalWindowGeometry(ids[i][0..lens[i]]);
+    }
+}
+
+pub fn overlayPresentedScreenRect(
+    pane_id: []const u8,
+    screen_x: f64,
+    screen_y: f64,
+    screen_width: f64,
+    screen_height: f64,
+    screen_scale: f64,
+) void {
+    var resize_snapshot: ?ResizeSnapshot = null;
+    state_mutex.lock();
+    if (findPane(pane_id)) |pane_index| {
+        const scale = if (screen_scale > 0) screen_scale else 1.0;
+        const changed = !panes[pane_index].has_screen_rect or
+            @abs(panes[pane_index].screen_x - screen_x) > 0.5 or
+            @abs(panes[pane_index].screen_y - screen_y) > 0.5 or
+            @abs(panes[pane_index].screen_width - screen_width) > 0.5 or
+            @abs(panes[pane_index].screen_height - screen_height) > 0.5;
+        panes[pane_index].has_screen_rect = true;
+        panes[pane_index].screen_x = screen_x;
+        panes[pane_index].screen_y = screen_y;
+        panes[pane_index].screen_width = screen_width;
+        panes[pane_index].screen_height = screen_height;
+        panes[pane_index].screen_scale = scale;
+        if (changed) {
+            log.info(
+                "external_geometry_callback pane_id={s} screen={d},{d},{d},{d} scale={d}",
+                .{ pane_id, screen_x, screen_y, screen_width, screen_height, scale },
+            );
+            if (panes[pane_index].tab_id != 0) {
+                resize_snapshot = snapshotResize(&panes[pane_index]);
+            }
+        }
+    }
+    state_mutex.unlock();
+    if (resize_snapshot) |snapshot| {
+        sendResize(&snapshot) catch |err| {
+            log.warn("Resize after external geometry failed pane_id={s} err={}", .{ pane_id, err });
+        };
     }
 }
 
