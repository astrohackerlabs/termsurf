     }
 
     // swiftlint:disable:next function_parameter_count
+    /// Last external-window geometry grid (Gecko); re-reported on window move/resize/timer.
+    private var termsurfExternalGeometryGrid: (col: UInt64, row: UInt64, width: UInt64, height: UInt64)?
+    private var termsurfExternalGeometryObservers: [NSObjectProtocol] = []
+    private var termsurfExternalGeometryTimer: Timer?
+
+    /// Report pane screen DIP (top-left) for process-chrome engines (Gecko) without CALayerHost.
+    func reportTermSurfExternalWindowGeometry(
+      col: UInt64,
+      row: UInt64,
+      width: UInt64,
+      height: UInt64
+    ) {
+      dispatchPrecondition(condition: .onQueue(.main))
+      termsurfExternalGeometryGrid = (col, row, width, height)
+      installTermSurfExternalGeometryObserversIfNeeded()
+      startTermSurfExternalGeometryTimerIfNeeded()
+      reportTermSurfExternalWindowGeometryNow()
+    }
+
+    private func installTermSurfExternalGeometryObserversIfNeeded() {
+      guard termsurfExternalGeometryObservers.isEmpty, let window else { return }
+      let center = NotificationCenter.default
+      let reReport: (Foundation.Notification) -> Void = { [weak self] _ in
+        DispatchQueue.main.async { self?.reportTermSurfExternalWindowGeometryNow() }
+      }
+      termsurfExternalGeometryObservers = [
+        center.addObserver(
+          forName: NSWindow.didMoveNotification, object: window, queue: .main, using: reReport),
+        center.addObserver(
+          forName: NSWindow.didResizeNotification, object: window, queue: .main, using: reReport),
+      ]
+    }
+
+    private func startTermSurfExternalGeometryTimerIfNeeded() {
+      guard termsurfExternalGeometryTimer == nil else { return }
+      // Poll screen rect so process-chrome windows follow Ghostboard moves even if
+      // NSWindow.didMove is not delivered for System Events position changes.
+      let timer = Timer(timeInterval: 0.4, repeats: true) { [weak self] _ in
+        self?.reportTermSurfExternalWindowGeometryNow()
+      }
+      RunLoop.main.add(timer, forMode: .common)
+      termsurfExternalGeometryTimer = timer
+    }
+
+    private func reportTermSurfExternalWindowGeometryNow() {
+      dispatchPrecondition(condition: .onQueue(.main))
+      guard let grid = termsurfExternalGeometryGrid else { return }
+      let col = grid.col
+      let row = grid.row
+      let width = grid.width
+      let height = grid.height
+      let gridLabel = "\(width)x\(height)+\(col)+\(row)"
+      guard let window else {
+        AppDelegate.logger.warning("TermSurf external geometry rejected: no window grid=\(gridLabel)")
+        return
+      }
+      guard NSScreen.screens.count > 0 else {
+        AppDelegate.logger.warning("TermSurf external geometry rejected: no screens")
+        return
+      }
+      let cellWidth = cellSize.width > 0 ? cellSize.width : 10
+      let cellHeight = cellSize.height > 0 ? cellSize.height : 20
+      let backingScale = window.backingScaleFactor
+      let paddingLeft = surfaceSize.map { CGFloat($0.padding_left_px) / backingScale } ?? 0
+      let paddingTop = surfaceSize.map { CGFloat($0.padding_top_px) / backingScale } ?? 0
+      let viewFrame = CGRect(
+        x: paddingLeft + CGFloat(col) * cellWidth,
+        y: paddingTop + CGFloat(row) * cellHeight,
+        width: CGFloat(width) * cellWidth,
+        height: CGFloat(height) * cellHeight)
+      guard viewFrame.width > 0, viewFrame.height > 0 else {
+        AppDelegate.logger.warning("TermSurf external geometry rejected: empty frame grid=\(gridLabel)")
+        return
+      }
+      let windowRect = convert(viewFrame, to: nil)
+      let screenBottomLeft = window.convertToScreen(windowRect)
+      // Menu-bar display is screens[0]; global AppKit flip reference (not NSScreen.main).
+      let mainMaxY = NSScreen.screens[0].frame.maxY
+      let topLeft = termsurfAppKitBottomLeftToTopLeftDIP(
+        originX: screenBottomLeft.origin.x,
+        originY: screenBottomLeft.origin.y,
+        height: screenBottomLeft.size.height,
+        mainMaxY: mainMaxY)
+      let paneID = id.uuidString
+      paneID.withCString { cPaneID in
+        termsurf_overlay_presented_screen_rect(
+          cPaneID,
+          Double(topLeft.x),
+          Double(topLeft.y),
+          Double(screenBottomLeft.size.width),
+          Double(screenBottomLeft.size.height),
+          Double(backingScale))
+      }
+      AppDelegate.logger.info(
+        "TermSurf external geometry reported pane_id=\(paneID, privacy: .public) screen=\(topLeft.x),\(topLeft.y),\(screenBottomLeft.size.width),\(screenBottomLeft.size.height) scale=\(backingScale)"
+      )
+    }
+
