@@ -70,6 +70,7 @@ private struct TerminalSplitSubtreeView: View {
                     action(.resize(.init(node: node, ratio: $0)))
                 }),
                 dividerColor: ghostty.config.splitDividerColor,
+                paneGap: CGFloat(ghostty.config.splitPaneGap),
                 resizeIncrements: .init(width: 1, height: 1),
                 left: {
                     TerminalSplitSubtreeView(node: split.left, action: action)
diff --git a/macos/Sources/Ghostty/Ghostty.Config.swift b/macos/Sources/Ghostty/Ghostty.Config.swift
index 88297bfa0..7e449c7bd 100644
--- a/macos/Sources/Ghostty/Ghostty.Config.swift
+++ b/macos/Sources/Ghostty/Ghostty.Config.swift
@@ -650,6 +650,16 @@ extension Ghostty {
             return value
         }
 
+        /// Empty inter-pane margin in points (`split-pane-gap`). Default 2.
+        /// Does not thicken the painted divider hairline.
+        var splitPaneGap: Double {
+            guard let config = self.config else { return 2 }
+            var value: Double = 2
+            let key = "split-pane-gap"
+            _ = ghostty_config_get(config, &value, key, UInt(key.lengthOfBytes(using: .utf8)))
+            return value
+        }
+
         /// Corner radius for multi-pane split borders.
         ///
         /// - `nil` = `auto` (match window `_cornerRadius` / product fallback)
diff --git a/macos/Sources/Ghostty/Surface View/InspectorView.swift b/macos/Sources/Ghostty/Surface View/InspectorView.swift
index e7320c782..891e445f4 100644
--- a/macos/Sources/Ghostty/Surface View/InspectorView.swift	
+++ b/macos/Sources/Ghostty/Surface View/InspectorView.swift	
@@ -26,7 +26,12 @@ extension Ghostty {
                 if !surfaceView.inspectorVisible {
                     SurfaceWrapper(surfaceView: surfaceView, isSplit: isSplit)
                 } else {
-                    SplitView(.vertical, $split, dividerColor: ghostty.config.splitDividerColor, left: {
+                    SplitView(
+                        .vertical,
+                        $split,
+                        dividerColor: ghostty.config.splitDividerColor,
+                        paneGap: CGFloat(ghostty.config.splitPaneGap),
+                        left: {
                         SurfaceWrapper(surfaceView: surfaceView, isSplit: isSplit)
                     }, right: {
                         InspectorViewRepresentable(surfaceView: surfaceView)
diff --git a/src/config/Config.zig b/src/config/Config.zig
index b630b5eb3..5110c0f6c 100644
--- a/src/config/Config.zig
+++ b/src/config/Config.zig
@@ -1094,6 +1094,17 @@ palette: Palette = .{},
 /// Available since: 1.1.0
 @"split-divider-color": ?Color = null,
 
+/// Empty layout space between adjacent split panes on macOS, in points.
+///
+/// This is **margin / air** between pane frames so full split borders remain
+/// visible. It is **not** the thickness of the painted divider hairline (that
+/// stays ~1 pt and uses `split-divider-color`). Do not confuse with
+/// `split-border-width` (in-pane stroke).
+///
+/// Defaults to **2**. Set to `0` for the historical tight hairline-only seam.
+/// Values outside `0`…`20` are clamped.
+@"split-pane-gap": f64 = 2,
+
 /// The border color of the focused split pane. Specified as either hex
 /// (`#RRGGBB` or `RRGGBB`) or a named X11 color.
 ///
@@ -4779,6 +4790,9 @@ pub fn finalize(self: *Config) !void {
     // Clamp our split border width
     self.@"split-border-width" = @min(10.0, @max(0, self.@"split-border-width"));
 
+    // Clamp inter-pane empty gap (macOS layout margin)
+    self.@"split-pane-gap" = @min(20.0, @max(0, self.@"split-pane-gap"));
+
     // Clamp fixed split border corner radius (auto is unchanged)
     switch (self.@"split-border-corner-radius") {
         .auto => {},
