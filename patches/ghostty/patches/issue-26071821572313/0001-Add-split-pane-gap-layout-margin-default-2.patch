From 708d9bfbf53d1909bfac3f94fb8325711461ef9b Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 18 Jul 2026 17:14:16 -0500
Subject: [PATCH] Add split-pane-gap layout margin (default 2)

Reserve empty space between split panes so borders stay fully visible.
Keep the painted divider as a 1pt hairline; do not fill the gap with
split-divider-color (avoids Exp 1 black-bar failure).
---
 macos/Sources/Features/Splits/SplitView.swift | 67 ++++++++++++++-----
 .../Splits/TerminalSplitTreeView.swift        |  1 +
 macos/Sources/Ghostty/Ghostty.Config.swift    | 10 +++
 .../Ghostty/Surface View/InspectorView.swift  |  7 +-
 src/config/Config.zig                         | 14 ++++
 5 files changed, 80 insertions(+), 19 deletions(-)

diff --git a/macos/Sources/Features/Splits/SplitView.swift b/macos/Sources/Features/Splits/SplitView.swift
index a19fdca6a..a4f44ff42 100644
--- a/macos/Sources/Features/Splits/SplitView.swift
+++ b/macos/Sources/Features/Splits/SplitView.swift
@@ -3,15 +3,20 @@ import SwiftUI
 /// A split view shows a left and right (or top and bottom) view with a divider in the middle to do resizing.
 /// The terminlogy "left" and "right" is always used but for vertical splits "left" is "top" and "right" is "bottom".
 ///
-/// This view is purpose built for our use case and I imagine we'll continue to make it more configurable
-/// as time goes on. For example, the splitter divider size and styling is all hardcoded.
+/// Inter-pane **margin** is `paneGap` (`split-pane-gap`): empty layout space so
+/// pane borders stay fully visible. Painted divider stays a 1 pt hairline
+/// (`split-divider-color`) and must not fill the gap (Exp 1 Fail lesson).
 struct SplitView<L: View, R: View>: View {
     /// Direction of the split
     let direction: SplitViewDirection
 
-    /// Divider color
+    /// Divider hairline color
     let dividerColor: Color
 
+    /// Empty space between pane frames in points (`split-pane-gap`).
+    /// `0` keeps the historical tight hairline-only geometry.
+    let paneGap: CGFloat
+
     /// Minimum increment (in points) that this split can be resized by, in
     /// each direction. Both `height` and `width` should be whole numbers
     /// greater than or equal to 1.0
@@ -30,10 +35,27 @@ struct SplitView<L: View, R: View>: View {
     /// The current fractional width of the split view. 0.5 means L/R are equally sized, for example.
     @Binding var split: CGFloat
 
-    /// The visible size of the splitter, in points. The invisible size is a transparent hitbox that can still
-    /// be used for getting a resize handle. The total width/height of the splitter is the sum of both.
-    private let splitterVisibleSize: CGFloat = 1
-    private let splitterInvisibleSize: CGFloat = 6
+    /// Painted hairline only — never scales with `paneGap`.
+    private let splitterPaintSize: CGFloat = 1
+
+    /// Minimum drag hit thickness.
+    private let splitterHitMinimum: CGFloat = 6
+
+    /// Layout separation between pane frames.
+    /// gap == 0 → historical 1 pt paint reservation; gap > 0 → empty margin.
+    private var layoutSeparation: CGFloat {
+        paneGap > 0 ? paneGap : splitterPaintSize
+    }
+
+    private var splitterVisibleSize: CGFloat {
+        splitterPaintSize
+    }
+
+    /// Transparent hit beyond the hairline so total hit ≥ max(6, separation).
+    private var splitterInvisibleSize: CGFloat {
+        let hit = max(splitterHitMinimum, layoutSeparation)
+        return max(0, hit - splitterVisibleSize)
+    }
 
     var body: some View {
         GeometryReader { geo in
@@ -42,6 +64,7 @@ struct SplitView<L: View, R: View>: View {
             let splitterPoint = self.splitterPoint(for: geo.size, leftRect: leftRect)
 
             ZStack(alignment: .topLeading) {
+                // Empty gap shows host/window background — do not fill with divider color.
                 left
                     .frame(width: leftRect.size.width, height: leftRect.size.height)
                     .offset(x: leftRect.origin.x, y: leftRect.origin.y)
@@ -73,6 +96,7 @@ struct SplitView<L: View, R: View>: View {
         _ direction: SplitViewDirection,
         _ split: Binding<CGFloat>,
         dividerColor: Color,
+        paneGap: CGFloat = 2,
         resizeIncrements: NSSize = .init(width: 1, height: 1),
         @ViewBuilder left: (() -> L),
         @ViewBuilder right: (() -> R),
@@ -81,6 +105,7 @@ struct SplitView<L: View, R: View>: View {
         self.direction = direction
         self._split = split
         self.dividerColor = dividerColor
+        self.paneGap = max(0, paneGap)
         self.resizeIncrements = resizeIncrements
         self.left = left()
         self.right = right()
@@ -106,15 +131,16 @@ struct SplitView<L: View, R: View>: View {
     private func leftRect(for size: CGSize) -> CGRect {
         // Initially the rect is the full size
         var result = CGRect(x: 0, y: 0, width: size.width, height: size.height)
+        let half = layoutSeparation / 2
         switch direction {
         case .horizontal:
             result.size.width *= split
-            result.size.width -= splitterVisibleSize / 2
+            result.size.width -= half
             result.size.width -= result.size.width.truncatingRemainder(dividingBy: self.resizeIncrements.width)
 
         case .vertical:
             result.size.height *= split
-            result.size.height -= splitterVisibleSize / 2
+            result.size.height -= half
             result.size.height -= result.size.height.truncatingRemainder(dividingBy: self.resizeIncrements.height)
         }
 
@@ -125,31 +151,36 @@ struct SplitView<L: View, R: View>: View {
     private func rightRect(for size: CGSize, leftRect: CGRect) -> CGRect {
         // Initially the rect is the full size
         var result = CGRect(x: 0, y: 0, width: size.width, height: size.height)
+        // Full layoutSeparation between left trailing edge and right leading edge.
+        // (Historical tight path used paint/2 offsets; for gap==0 separation==paint so
+        // left+paint still leaves a 1pt hairline reservation matching prior feel.)
         switch direction {
         case .horizontal:
-            // For horizontal layouts we offset the starting X by the left rect
-            // and make the width fit the remaining space.
-            result.origin.x += leftRect.size.width
-            result.origin.x += splitterVisibleSize / 2
+            result.origin.x = leftRect.size.width + layoutSeparation
             result.size.width -= result.origin.x
 
         case .vertical:
-            result.origin.y += leftRect.size.height
-            result.origin.y += splitterVisibleSize / 2
+            result.origin.y = leftRect.size.height + layoutSeparation
             result.size.height -= result.origin.y
         }
 
         return result
     }
 
-    /// Calculates the point at which the splitter should be rendered.
+    /// Hairline centered in the layout gap between panes.
     private func splitterPoint(for size: CGSize, leftRect: CGRect) -> CGPoint {
         switch direction {
         case .horizontal:
-            return CGPoint(x: leftRect.size.width, y: size.height / 2)
+            return CGPoint(
+                x: leftRect.size.width + layoutSeparation / 2,
+                y: size.height / 2
+            )
 
         case .vertical:
-            return CGPoint(x: size.width / 2, y: leftRect.size.height)
+            return CGPoint(
+                x: size.width / 2,
+                y: leftRect.size.height + layoutSeparation / 2
+            )
         }
     }
 
diff --git a/macos/Sources/Features/Splits/TerminalSplitTreeView.swift b/macos/Sources/Features/Splits/TerminalSplitTreeView.swift
index 5fa12edeb..f8a46bc23 100644
