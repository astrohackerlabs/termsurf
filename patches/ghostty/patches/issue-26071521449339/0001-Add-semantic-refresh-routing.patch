+fn handleLoadingState(
+    browser_fd: std.posix.fd_t,
+    req: ?*c.Termsurf__LoadingState,
+) bool {
+    const loading_state = req orelse return false;
+    if (loading_state.*.tab_id <= 0) return false;
+
+    state_mutex.lock();
+    const server_index = findServerByFd(browser_fd) orelse {
+        state_mutex.unlock();
+        return false;
+    };
+    const server = &servers[server_index];
+    const lookup_index = findTabLookup(
+        server.profileName(),
+        server.browserName(),
+        loading_state.*.tab_id,
+    ) orelse {
+        state_mutex.unlock();
+        return false;
+    };
+    const pane_index = findPane(tab_lookups[lookup_index].paneId()) orelse {
+        state_mutex.unlock();
+        return false;
+    };
+    const tui_fd = panes[pane_index].tui_fd;
+    const exact_identity = panes[pane_index].tab_id == loading_state.*.tab_id;
+    state_mutex.unlock();
+    if (!exact_identity or tui_fd < 0) return false;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_LOADING_STATE;
+    wrapper.unnamed_0.loading_state = loading_state;
+    sendProtobuf(tui_fd, &wrapper) catch return false;
+    return true;
+}
