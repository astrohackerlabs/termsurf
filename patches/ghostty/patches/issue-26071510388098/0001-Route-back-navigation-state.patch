+size_t termsurf__navigation_state__pack_to_buffer
+                     (const Termsurf__NavigationState *message,
+                      ProtobufCBuffer *buffer)
+{
+  assert(message->base.descriptor == &termsurf__navigation_state__descriptor);
+  return protobuf_c_message_pack_to_buffer ((const ProtobufCMessage*)message, buffer);
