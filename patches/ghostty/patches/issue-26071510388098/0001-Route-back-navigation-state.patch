From a231b268e32100b9cfdc729706947365fb84f775 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Wed, 15 Jul 2026 07:51:44 -0500
Subject: [PATCH] Route Back by pane ownership

A pane points home, a tab replies,
False falls when its browser dies.
No Forward slips, Refresh stays out;
Back takes the owned and tested route.
---
 src/apprt/termsurf.zig       | 336 +++++++++++++++++++++++++++++++++++
 src/protobuf/termsurf.pb-c.c | 242 ++++++++++++++++++++++++-
 src/protobuf/termsurf.pb-c.h |  94 +++++++++-
 3 files changed, 664 insertions(+), 8 deletions(-)

diff --git a/src/apprt/termsurf.zig b/src/apprt/termsurf.zig
index 00e3099ff..7a49d42a4 100644
--- a/src/apprt/termsurf.zig
+++ b/src/apprt/termsurf.zig
@@ -266,6 +266,7 @@ const PaneState = struct {
     last_resize_pixel_width: u64 = 0,
     last_resize_pixel_height: u64 = 0,
     cursor_type: i64 = 0,
+    can_go_back: bool = false,
     tui_fd: std.posix.fd_t = -1,
 
     fn paneId(self: *const PaneState) []const u8 {
@@ -784,6 +785,18 @@ const TitleSnapshot = struct {
     }
 };
 
+const NavigationStateSnapshot = struct {
+    tui_fd: std.posix.fd_t = -1,
+    pane_id: [max_pane_id_len]u8 = undefined,
+    pane_id_len: usize = 0,
+    tab_id: i64 = 0,
+    can_go_back: bool = false,
+
+    fn paneId(self: *const NavigationStateSnapshot) []const u8 {
+        return self.pane_id[0..self.pane_id_len];
+    }
+};
+
 fn geometryTraceEnabled() bool {
     const value = std.posix.getenv(geometry_trace_env) orelse return false;
     return !std.mem.eql(u8, value, "0") and !std.mem.eql(u8, value, "false");
@@ -1173,6 +1186,12 @@ fn handleClient(fd: std.posix.fd_t, slot_index: usize) void {
                 c.TERMSURF__TERM_SURF_MESSAGE__MSG_TAB_READY => {
                     handleTabReady(msg.*.unnamed_0.tab_ready);
                 },
+                c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION => {
+                    _ = handleNavigationAction(fd, msg.*.unnamed_0.navigation_action);
+                },
+                c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE => {
+                    _ = handleNavigationState(fd, msg.*.unnamed_0.navigation_state);
+                },
                 c.TERMSURF__TERM_SURF_MESSAGE__MSG_CA_CONTEXT => {
                     handleCaContext(fd, msg.*.unnamed_0.ca_context);
                 },
@@ -3035,6 +3054,159 @@ fn snapshotBrowserInput(pane_id: []const u8, require_browsing: bool) ?BrowserInp
     return snapshot;
 }
 
+fn handleNavigationAction(
+    tui_fd: std.posix.fd_t,
+    req: ?*c.Termsurf__NavigationAction,
+) bool {
+    const action_req = req orelse {
+        log.warn("NavigationAction: missing payload", .{});
+        return false;
+    };
+    const pane_id = cString(action_req.*.pane_id);
+    const action = cString(action_req.*.action);
+    if (action_req.*.tab_id != 0 or pane_id.len == 0 or !std.mem.eql(u8, action, "back")) {
+        log.warn(
+            "NavigationAction: invalid TUI request pane_id={s} tab_id={} action={s}",
+            .{ pane_id, action_req.*.tab_id, action },
+        );
+        return false;
+    }
+
+    state_mutex.lock();
+    const pane_index = findPane(pane_id) orelse {
+        state_mutex.unlock();
+        log.warn("NavigationAction: unknown pane_id={s}", .{pane_id});
+        return false;
+    };
+    const pane = &panes[pane_index];
+    if (pane.tui_fd != tui_fd or pane.tab_id <= 0) {
+        state_mutex.unlock();
+        log.warn(
+            "NavigationAction: unowned or unready pane_id={s} tab_id={} fd={}",
+            .{ pane_id, pane.tab_id, tui_fd },
+        );
+        return false;
+    }
+    const server_index = findServer(pane.profileName(), pane.browserName()) orelse {
+        state_mutex.unlock();
+        return false;
+    };
+    if (servers[server_index].attached_fd < 0) {
+        state_mutex.unlock();
+        return false;
+    }
+    var snapshot: BrowserInputSnapshot = .{
+        .browser_fd = servers[server_index].attached_fd,
+        .tab_id = pane.tab_id,
+    };
+    if (!copyText(&snapshot.pane_id, &snapshot.pane_id_len, pane.paneId())) {
+        state_mutex.unlock();
+        return false;
+    }
+    state_mutex.unlock();
+
+    var forwarded: c.Termsurf__NavigationAction = undefined;
+    c.termsurf__navigation_action__init(&forwarded);
+    forwarded.tab_id = snapshot.tab_id;
+    forwarded.action = action_req.*.action;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION;
+    wrapper.unnamed_0.navigation_action = &forwarded;
+
+    sendProtobuf(snapshot.browser_fd, &wrapper) catch |err| {
+        log.warn(
+            "NavigationAction send failed pane_id={s} tab_id={} err={}",
+            .{ snapshot.paneId(), snapshot.tab_id, err },
+        );
+        return false;
+    };
+    log.info(
+        "NavigationAction: pane_id={s} tab_id={} action=back",
+        .{ snapshot.paneId(), snapshot.tab_id },
+    );
+    return true;
+}
+
+fn sendNavigationStateToTui(snapshot: *const NavigationStateSnapshot) !void {
+    var state: c.Termsurf__NavigationState = undefined;
+    c.termsurf__navigation_state__init(&state);
+    state.tab_id = snapshot.tab_id;
+    state.can_go_back = if (snapshot.can_go_back) 1 else 0;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE;
+    wrapper.unnamed_0.navigation_state = &state;
+    try sendProtobuf(snapshot.tui_fd, &wrapper);
+}
+
+fn handleNavigationState(
+    browser_fd: std.posix.fd_t,
+    req: ?*c.Termsurf__NavigationState,
+) bool {
+    const navigation_state = req orelse {
+        log.warn("NavigationState: missing payload", .{});
+        return false;
+    };
+    if (navigation_state.*.tab_id <= 0) {
+        log.warn("NavigationState: invalid tab_id={}", .{navigation_state.*.tab_id});
+        return false;
+    }
+
+    var snapshot: ?NavigationStateSnapshot = null;
+    state_mutex.lock();
+    const server_index = findServerByFd(browser_fd) orelse {
+        state_mutex.unlock();
+        log.warn("NavigationState: unknown browser fd={}", .{browser_fd});
+        return false;
+    };
+    const profile = servers[server_index].profileName();
+    const browser = servers[server_index].browserName();
+    const lookup_index = findTabLookup(profile, browser, navigation_state.*.tab_id) orelse {
+        state_mutex.unlock();
+        log.warn(
+            "NavigationState: wrong or unknown tab key={s}/{s} tab_id={}",
+            .{ profile, browser, navigation_state.*.tab_id },
+        );
+        return false;
+    };
+    const pane_id = tab_lookups[lookup_index].paneId();
+    const pane_index = findPane(pane_id) orelse {
+        state_mutex.unlock();
+        return false;
+    };
+    const pane = &panes[pane_index];
+    if (pane.tab_id != navigation_state.*.tab_id) {
+        state_mutex.unlock();
+        return false;
+    }
+    pane.can_go_back = navigation_state.*.can_go_back != 0;
+    if (pane.tui_fd >= 0) {
+        var value: NavigationStateSnapshot = .{
+            .tui_fd = pane.tui_fd,
+            .tab_id = pane.tab_id,
+            .can_go_back = pane.can_go_back,
+        };
+        if (copyText(&value.pane_id, &value.pane_id_len, pane.paneId())) {
+            snapshot = value;
+        }
+    }
+    state_mutex.unlock();
+
+    if (snapshot) |value| {
+        sendNavigationStateToTui(&value) catch |err| {
+            log.warn(
+                "NavigationState send failed pane_id={s} tab_id={} err={}",
+                .{ value.paneId(), value.tab_id, err },
+            );
+            return false;
+        };
+    }
+    return true;
+}
+
 fn snapshotModeChanged(pane: *const PaneState, browsing: bool) ?ModeChangedSnapshot {
     if (pane.tui_fd < 0) return null;
 
@@ -3157,6 +3329,7 @@ fn handleTabReady(req: ?*c.Termsurf__TabReady) void {
     };
 
     panes[pane_index].tab_id = tab_id;
+    panes[pane_index].can_go_back = false;
     const lookup_count = upsertTabLookup(&panes[pane_index], tab_id);
     if (panes[pane_index].inspected_tab_id == 0) {
         _ = copyText(&last_browser_pane, &last_browser_pane_len, pane_id);
@@ -4048,10 +4221,28 @@ fn releaseRenderReceivedSurface(side_channel: *RenderSideChannelState) void {
 
 fn cleanupBrowserConnection(fd: std.posix.fd_t) void {
     var server_shutdown: ?ServerShutdownSnapshot = null;
+    var navigation_states: [max_panes]NavigationStateSnapshot = undefined;
+    var navigation_state_count: usize = 0;
 
     state_mutex.lock();
     if (findServerByFd(fd)) |server_index| {
         const server = &servers[server_index];
+        for (&panes) |*pane| {
+            if (!pane.in_use or pane.tab_id <= 0 or pane.tui_fd < 0) continue;
+            if (!std.mem.eql(u8, pane.profileName(), server.profileName())) continue;
+            if (!std.mem.eql(u8, pane.browserName(), server.browserName())) continue;
+
+            pane.can_go_back = false;
+            var state: NavigationStateSnapshot = .{
+                .tui_fd = pane.tui_fd,
+                .tab_id = pane.tab_id,
+                .can_go_back = false,
+            };
+            if (copyText(&state.pane_id, &state.pane_id_len, pane.paneId())) {
+                navigation_states[navigation_state_count] = state;
+                navigation_state_count += 1;
+            }
+        }
         var snapshot: ServerShutdownSnapshot = .{
             .browser_fd = -1,
             .child_pid = server.child_pid,
@@ -4068,6 +4259,15 @@ fn cleanupBrowserConnection(fd: std.posix.fd_t) void {
     }
     state_mutex.unlock();
 
+    for (navigation_states[0..navigation_state_count]) |*state| {
+        sendNavigationStateToTui(state) catch |err| {
+            log.warn(
+                "NavigationState disconnect clear failed pane_id={s} tab_id={} err={}",
+                .{ state.paneId(), state.tab_id, err },
+            );
+        };
+    }
+
     if (server_shutdown) |*snapshot| {
         log.info(
             "Browser disconnect: detached browser server profile={s} browser={s} fd={}",
@@ -5489,6 +5689,7 @@ fn msgTypeName(msg_case: c.Termsurf__TermSurfMessage__MsgCase) []const u8 {
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_RESIZE => "Resize",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_CLOSE_TAB => "CloseTab",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATE => "Navigate",
+        c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION => "NavigationAction",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_MOUSE_EVENT => "MouseEvent",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_MOUSE_MOVE => "MouseMove",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_SCROLL_EVENT => "ScrollEvent",
@@ -5501,6 +5702,7 @@ fn msgTypeName(msg_case: c.Termsurf__TermSurfMessage__MsgCase) []const u8 {
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_RENDER_SURFACE => "RenderSurface",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_URL_CHANGED => "UrlChanged",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_LOADING_STATE => "LoadingState",
+        c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE => "NavigationState",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_TITLE_CHANGED => "TitleChanged",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_CURSOR_CHANGED => "CursorChanged",
         c.TERMSURF__TERM_SURF_MESSAGE__MSG_TARGET_URL_CHANGED => "TargetUrlChanged",
@@ -6808,3 +7010,137 @@ fn readExactTest(fd: std.posix.fd_t, buf: []u8) !void {
         offset += n;
     }
 }
+
+test "termsurf Back action and state preserve pane tab ownership" {
+    const testing = std.testing;
+
+    resetTermsurfStateForTest();
+    defer resetTermsurfStateForTest();
+
+    var browser_a = try testSocketPair();
+    defer testCloseSocketPair(&browser_a);
+    var browser_b = try testSocketPair();
+    defer testCloseSocketPair(&browser_b);
+    var tui_a = try testSocketPair();
+    defer testCloseSocketPair(&tui_a);
+    var tui_b = try testSocketPair();
+    defer testCloseSocketPair(&tui_b);
+
+    try testSetPendingServer(0, "default", "chromium");
+    servers[0].attached_fd = browser_a[0];
+    try testSetPendingServer(1, "default", "webkit");
+    servers[1].attached_fd = browser_b[0];
+    try testSetPane(0, "pane-a", "default", "chromium", "https://a.test/", tui_a[0]);
+    try testSetPane(1, "pane-b", "default", "webkit", "https://b.test/", tui_b[0]);
+    panes[0].tab_id = 77;
+    panes[0].can_go_back = true;
+    panes[1].tab_id = 88;
+    panes[1].can_go_back = false;
+    _ = upsertTabLookup(&panes[0], 77);
+    _ = upsertTabLookup(&panes[1], 88);
+
+    var action: c.Termsurf__NavigationAction = undefined;
+    c.termsurf__navigation_action__init(&action);
+    action.pane_id = @constCast("pane-a");
+    action.action = @constCast("back");
+    try testing.expect(handleNavigationAction(tui_a[0], &action));
+
+    const forwarded = try readTestMessage(browser_a[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(forwarded, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_ACTION),
+        forwarded.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 77), forwarded.*.unnamed_0.navigation_action.*.tab_id);
+    try testing.expectEqualStrings("", cString(forwarded.*.unnamed_0.navigation_action.*.pane_id));
+    try testing.expectEqualStrings("back", cString(forwarded.*.unnamed_0.navigation_action.*.action));
+    try testing.expect(panes[0].can_go_back);
+    try testing.expect(!panes[1].can_go_back);
+
+    action.action = @constCast("forward");
+    try testing.expect(!handleNavigationAction(tui_a[0], &action));
+    action.action = @constCast("refresh");
+    try testing.expect(!handleNavigationAction(tui_a[0], &action));
+    action.action = @constCast("unknown");
+    try testing.expect(!handleNavigationAction(tui_a[0], &action));
+    action.action = @constCast("back");
+    try testing.expect(!handleNavigationAction(tui_b[0], &action));
+    action.tab_id = 77;
+    try testing.expect(!handleNavigationAction(tui_a[0], &action));
+
+    var state: c.Termsurf__NavigationState = undefined;
+    c.termsurf__navigation_state__init(&state);
+    state.tab_id = 77;
+    state.can_go_back = 1;
+    try testing.expect(handleNavigationState(browser_a[0], &state));
+
+    const relayed = try readTestMessage(tui_a[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(relayed, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE),
+        relayed.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 77), relayed.*.unnamed_0.navigation_state.*.tab_id);
+    try testing.expectEqual(@as(c_int, 1), relayed.*.unnamed_0.navigation_state.*.can_go_back);
+    try testing.expect(panes[0].can_go_back);
+    try testing.expect(!panes[1].can_go_back);
+
+    try testing.expect(!handleNavigationState(browser_b[0], &state));
+    state.tab_id = 0;
+    try testing.expect(!handleNavigationState(browser_a[0], &state));
+    state.tab_id = 999;
+    try testing.expect(!handleNavigationState(browser_a[0], &state));
+
+    state.tab_id = 77;
+    state.can_go_back = 0;
+    try testing.expect(handleNavigationState(browser_a[0], &state));
+    const relayed_false = try readTestMessage(tui_a[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(relayed_false, null);
+    try testing.expectEqual(@as(c_int, 0), relayed_false.*.unnamed_0.navigation_state.*.can_go_back);
+    try testing.expect(!panes[0].can_go_back);
+    try testing.expect(!panes[1].can_go_back);
+}
+
+test "termsurf browser disconnect clears Back only for affected owners" {
+    const testing = std.testing;
+
+    resetTermsurfStateForTest();
+    defer resetTermsurfStateForTest();
+
+    var browser_a = try testSocketPair();
+    defer testCloseSocketPair(&browser_a);
+    var browser_b = try testSocketPair();
+    defer testCloseSocketPair(&browser_b);
+    var tui_a = try testSocketPair();
+    defer testCloseSocketPair(&tui_a);
+    var tui_b = try testSocketPair();
+    defer testCloseSocketPair(&tui_b);
+
+    try testSetPendingServer(0, "default", "chromium");
+    servers[0].attached_fd = browser_a[0];
+    try testSetPendingServer(1, "default", "webkit");
+    servers[1].attached_fd = browser_b[0];
+    try testSetPane(0, "pane-a", "default", "chromium", "https://a.test/", tui_a[0]);
+    try testSetPane(1, "pane-b", "default", "webkit", "https://b.test/", tui_b[0]);
+    panes[0].tab_id = 77;
+    panes[0].can_go_back = true;
+    panes[1].tab_id = 88;
+    panes[1].can_go_back = true;
+    _ = upsertTabLookup(&panes[0], 77);
+    _ = upsertTabLookup(&panes[1], 88);
+
+    cleanupBrowserConnection(browser_a[0]);
+
+    const cleared = try readTestMessage(tui_a[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(cleared, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_NAVIGATION_STATE),
+        cleared.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 77), cleared.*.unnamed_0.navigation_state.*.tab_id);
+    try testing.expectEqual(@as(c_int, 0), cleared.*.unnamed_0.navigation_state.*.can_go_back);
+    try testing.expect(!panes[0].can_go_back);
+    try testing.expect(panes[1].can_go_back);
+    try testing.expectEqual(@as(std.posix.fd_t, -1), servers[0].attached_fd);
+    try testing.expectEqual(browser_b[0], servers[1].attached_fd);
+}
