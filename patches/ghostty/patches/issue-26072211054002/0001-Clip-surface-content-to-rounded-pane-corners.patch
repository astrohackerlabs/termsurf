diff --git a/macos/Tests/Terminal/SurfaceContentClipTests.swift b/macos/Tests/Terminal/SurfaceContentClipTests.swift
new file mode 100644
index 000000000..dfe8f8e99
--- /dev/null
+++ b/macos/Tests/Terminal/SurfaceContentClipTests.swift
@@ -0,0 +1,53 @@
+import Testing
+@testable import Ghostty
+
+struct SurfaceContentClipTests {
+    @Test func splitConcentricInnerRadius() {
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: true,
+            effectiveRadius: 12,
+            borderWidth: 2)
+        #expect(r == 10)
+    }
+
+    @Test func splitRadiusZeroIsSquare() {
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: true,
+            effectiveRadius: 0,
+            borderWidth: 4)
+        #expect(r == 0)
+    }
+
+    @Test func splitBorderWiderThanRadiusClampsToZero() {
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: true,
+            effectiveRadius: 3,
+            borderWidth: 8)
+        #expect(r == 0)
+    }
+
+    @Test func singlePaneUsesFullWindowRadius() {
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: false,
+            effectiveRadius: 12,
+            borderWidth: 0)
+        #expect(r == 12)
+    }
+
+    @Test func singlePaneIgnoresBorderWidthForClip() {
+        // Single-pane does not draw split border chrome; content uses full R.
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: false,
+            effectiveRadius: 10,
+            borderWidth: 99)
+        #expect(r == 10)
+    }
+
+    @Test func singlePaneZeroRadiusIsSquare() {
+        let r = SurfaceContentClip.contentClipRadius(
+            isSplit: false,
+            effectiveRadius: 0,
+            borderWidth: 0)
+        #expect(r == 0)
+    }
+}
