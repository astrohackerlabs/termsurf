index 000000000..070d9f889
--- /dev/null
+++ b/macos/Sources/Ghostty/Surface View/SurfaceContentClip.swift	
@@ -0,0 +1,31 @@
+import CoreGraphics
+
+/// Content clip radius for terminal surface pixels (HTML `overflow: hidden`
+/// on a rounded box). Shared by SwiftUI chrome and AppKit layer clips.
+enum SurfaceContentClip {
+    /// Fallback when window `_cornerRadius` is unavailable (matches split border).
+    static let windowCornerRadiusFallback: CGFloat = 10
+
+    /// Radius used to clip surface content (not the outer border stroke alone).
+    ///
+    /// - Parameters:
+    ///   - isSplit: Multi-pane split surface.
+    ///   - effectiveRadius: Outer pane/window continuous radius (config auto/0/N).
+    ///   - borderWidth: Drawn split border width (0 for single-pane or no border).
+    /// - Returns: Clip radius for content. Split uses concentric `max(0, R - w)`;
+    ///   single-pane uses full window `R` so content cannot paint past the
+    ///   window curve. Zero `effectiveRadius` forces square (no clip rounding).
+    static func contentClipRadius(
+        isSplit: Bool,
+        effectiveRadius: CGFloat,
+        borderWidth: CGFloat
+    ) -> CGFloat {
+        if effectiveRadius <= 0 {
+            return 0
+        }
+        if isSplit {
+            return max(0, effectiveRadius - max(0, borderWidth))
+        }
+        return effectiveRadius
+    }
+}
diff --git a/macos/Sources/Ghostty/Surface View/SurfaceScrollView.swift b/macos/Sources/Ghostty/Surface View/SurfaceScrollView.swift
index c64fe920a..050c4a190 100644
--- a/macos/Sources/Ghostty/Surface View/SurfaceScrollView.swift	
+++ b/macos/Sources/Ghostty/Surface View/SurfaceScrollView.swift	
@@ -216,6 +216,34 @@ class SurfaceScrollView: NSView {
 
     // MARK: Scrolling
 
+
+    /// Clip terminal pixels to a rounded rect (overflow: hidden). Radius 0 = square.
+    func applyContentCornerRadius(_ radius: CGFloat) {
+        let r = max(0, radius)
+        wantsLayer = true
+        layer?.masksToBounds = r > 0
+        layer?.cornerRadius = r
+        if #available(macOS 10.15, *) {
+            layer?.cornerCurve = .continuous
+        }
+
+        scrollView.wantsLayer = true
+        scrollView.layer?.masksToBounds = r > 0
+        scrollView.layer?.cornerRadius = r
+        if #available(macOS 10.15, *) {
+            scrollView.layer?.cornerCurve = .continuous
+        }
+
+        // Clip the metal surface itself; SwiftUI clipShape alone may not
+        // constrain Metal CALayers in all configurations.
+        surfaceView.wantsLayer = true
+        surfaceView.layer?.masksToBounds = r > 0
+        surfaceView.layer?.cornerRadius = r
+        if #available(macOS 10.15, *) {
+            surfaceView.layer?.cornerCurve = .continuous
+        }
+    }
+
     private func synchronizeAppearance() {
         let scrollbarConfig = surfaceView.derivedConfig.scrollbar
         scrollView.hasVerticalScroller = scrollbarConfig != .never
