-    try testWithRestoredEnv(installed_surfari_path_env, testBrowserResolution);
+    try testWithRestoredEnv(installed_roamium_path_env, testBrowserResolution);
 }
 
 fn testBrowserResolution() !void {
     const testing = std.testing;
-    const surfari: [:0]const u8 = "webkit";
     const roamium: [:0]const u8 = "chromium";
     const fake_primary_chromium: [:0]const u8 = "/tmp/astrohacker-primary-chromium";
-    const fake_primary_webkit: [:0]const u8 = "/tmp/astrohacker-primary-webkit";
-    const fake_surfari_path: [:0]const u8 = "/tmp/termsurf-test-webkit";
     const fake_roamium_path: [:0]const u8 = "/tmp/termsurf-test-chromium";
