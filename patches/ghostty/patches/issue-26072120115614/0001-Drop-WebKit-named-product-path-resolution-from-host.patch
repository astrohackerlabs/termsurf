From 026e5ece937fa84f0a8e16f5796788ce16fffdaa Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Tue, 21 Jul 2026 16:14:52 -0500
Subject: [PATCH 1/2] Drop WebKit named product path resolution from host

Named webkit/env/opt install paths are no longer product targets.
Chromium remains the shipped logical engine; absolute paths still work.
---
 src/apprt/termsurf.zig | 131 ++++++-----------------------------------
 1 file changed, 19 insertions(+), 112 deletions(-)

diff --git a/src/apprt/termsurf.zig b/src/apprt/termsurf.zig
index 9da33e5c1..de3cf950a 100644
--- a/src/apprt/termsurf.zig
+++ b/src/apprt/termsurf.zig
@@ -40,23 +40,17 @@ const geometry_trace_env = "TERMSURF_GEOMETRY_TRACE";
 const browser_startup_trace_env = "TERMSURF_BROWSER_STARTUP_TRACE";
 const devtools_reservation_timeout_env = "TERMSURF_DEVTOOLS_RESERVATION_TIMEOUT_MS";
 const default_devtools_reservation_timeout_ms: i64 = 15_000;
-// Product primary engine path overrides (preferred).
+// Product primary engine path overrides (preferred). Chromium is the only
+// shipped logical engine family; WebKit/Ladybird named product paths are gone.
 const chromium_path_env = "ASTROHACKER_CHROMIUM_PATH";
-const webkit_path_env = "ASTROHACKER_WEBKIT_PATH";
 // Legacy dual-read aliases (deprecated codenames; still accepted one cycle).
 const chromium_path_env_legacy = "TERMSURF_ROAMIUM_PATH";
-const webkit_path_env_legacy = "TERMSURF_SURFARI_PATH";
 const chromium_path_env_legacy_installed = "TERMSURF_INSTALLED_ROAMIUM_PATH";
-const webkit_path_env_legacy_installed = "TERMSURF_INSTALLED_SURFARI_PATH";
 const installed_chromium_path = "/opt/homebrew/opt/astrohacker-terminal-ah-chromiumd/ah-chromiumd";
-const installed_webkit_path = "/opt/homebrew/opt/astrohacker-terminal-ah-webkitd/ah-webkitd";
 // Compat names used by older test helpers (same values as installed_*).
 const installed_roamium_path = installed_chromium_path;
-const installed_surfari_path = installed_webkit_path;
 const roamium_path_env = chromium_path_env_legacy;
-const surfari_path_env = webkit_path_env_legacy;
 const installed_roamium_path_env = chromium_path_env_legacy_installed;
-const installed_surfari_path_env = webkit_path_env_legacy_installed;
 
 const render_side_channel_receive_timeout_ms: u32 = 30_000;
 
@@ -1972,18 +1966,6 @@ fn resolveBrowserExecutableForBuild(browser: []const u8, is_debug: bool) ?[]cons
         );
     }
 
-    if (std.mem.eql(u8, browser, "webkit")) {
-        return resolveEnginePathFromEnv(
-            browser,
-            is_debug,
-            webkit_path_env,
-            webkit_path_env_legacy,
-            webkit_path_env_legacy_installed,
-            installed_webkit_path,
-        );
-    }
-
-
     log.warn("SetOverlay: named browser unsupported browser={s}", .{browser});
     return null;
 }
@@ -4474,27 +4456,11 @@ fn spawnBrowserProcess(
     };
     defer if (child_env) |*env| env.deinit();
     if (child_env) |*env| {
-        const inherited_framework_path = env.get("DYLD_FRAMEWORK_PATH");
-        if (inherited_framework_path) |framework_path| {
-            if (std.mem.eql(u8, browser_name_z, "webkit")) {
-                log.info(
-                    "browser spawn runtime env browser={s} inherited DYLD_FRAMEWORK_PATH={s}",
-                    .{ browser_name_z, framework_path },
-                );
-            }
-        } else if (shouldSupplySurfariRuntimeFrameworkPath(browser_name_z, inherited_framework_path)) {
-            const framework_path = surfariRuntimeFrameworkPath(browser_name_z, browser_executable_z).?;
-            env.put("DYLD_FRAMEWORK_PATH", framework_path) catch |err| {
-                log.warn(
-                    "browser spawn runtime env skipped browser={s} path={s} err={}",
-                    .{ browser_name_z, framework_path, err },
-                );
-            };
-            log.info(
-                "browser spawn runtime env browser={s} DYLD_FRAMEWORK_PATH={s}",
-                .{ browser_name_z, framework_path },
-            );
-        }
+        // Historical WebKit (Surfari) DYLD_FRAMEWORK_PATH injection removed with
+        // the shipped WebKit product engine. Absolute-path helpers must set their
+        // own runtime env if needed.
+        _ = browser_name_z;
+        _ = browser_executable_z;
         child.env_map = env;
     }
     traceBrowserStartup(
@@ -4651,15 +4617,6 @@ fn sanitizeRenderServiceComponent(buf: []u8, value: []const u8) []const u8 {
     return buf[0..len];
 }
 
-fn shouldSupplySurfariRuntimeFrameworkPath(browser: []const u8, inherited_framework_path: ?[]const u8) bool {
-    return std.mem.eql(u8, browser, "webkit") and inherited_framework_path == null;
-}
-
-fn surfariRuntimeFrameworkPath(browser: []const u8, browser_executable: []const u8) ?[]const u8 {
-    if (!std.mem.eql(u8, browser, "webkit")) return null;
-    return std.fs.path.dirname(browser_executable);
-}
-
 fn buildUserDataDir(buf: []u8, browser: []const u8, profile: []const u8) ?[:0]u8 {
     const home = std.posix.getenv("HOME") orelse {
         log.warn("browser spawn skipped: HOME is not set", .{});
@@ -4681,8 +4638,8 @@ fn buildUserDataDir(buf: []u8, browser: []const u8, profile: []const u8) ?[:0]u8
 }
 
 fn browserProfileDirName(browser: []const u8) []const u8 {
-    if (std.mem.eql(u8, browser, "webkit")) return "webkit-profiles";
-    if (std.mem.eql(u8, browser, default_browser)) return "chromium-profiles";
+    if (std.mem.eql(u8, browser, default_browser) or std.mem.eql(u8, browser, "chromium"))
+        return "chromium-profiles";
     return "browser-profiles";
 }
 
