     var webkit_data_dir_buf: [std.fs.max_path_bytes]u8 = undefined;
     const webkit_data_dir = buildUserDataDir(&webkit_data_dir_buf, webkit, profile) orelse return error.UserDataDirFailed;
-    try testing.expect(std.mem.indexOf(u8, webkit_data_dir, "webkit-profiles") != null);
+    // Non-chromium logical names use generic browser-profiles (WebKit not shipped).
+    try testing.expect(std.mem.indexOf(u8, webkit_data_dir, "browser-profiles") != null);
     try testing.expect(std.mem.indexOf(u8, webkit_data_dir, "chromium-profiles") == null);
 
     var chromium_data_dir_buf: [std.fs.max_path_bytes]u8 = undefined;
@@ -5553,116 +5511,66 @@ test "termsurf render surface accepts opaque absolute browser selector" {
 }
 
