+    /// Exp 7: when the pane is browse-forwardable and the key is a chrome
+    /// allowlist binding, keep the event on Ghostty (skip webview bulk forward).
+    private func shouldSkipTermSurfKeyForwardForBrowseChrome(_ event: NSEvent) -> Bool {
+      // Esc is already blocked inside forwardTermSurfKeyEvent.
+      guard event.keyCode != 0x35 else { return false }
+      let paneID = id.uuidString
+      let forwardable: Bool = paneID.withCString { termsurf_pane_browse_forwardable($0) != 0 }
+      guard forwardable else { return false }
+      guard let surfaceModel else { return false }
+      var ghosttyEvent = event.ghosttyKeyEvent(GHOSTTY_ACTION_PRESS)
+      return (event.characters ?? "").withCString { ptr in
+        ghosttyEvent.text = ptr
+        return surfaceModel.keyIsBrowseChrome(ghosttyEvent)
+      }
+    }
+
     private func forwardTermSurfKeyDown(_ event: NSEvent) -> Bool {
-      let type: String
-      if event.isARepeat || termsurfPressedBrowserKeys.contains(event.keyCode) {
-        type = "repeat"
-      } else {
-        type = "down"
+      // Exp 7: repeats only continue bulk-forward if press was browser-owned.
+      // Chrome host-steal never inserts into termsurfPressedBrowserKeys.
+      if event.isARepeat, !termsurfPressedBrowserKeys.contains(event.keyCode) {
+        return false
       }
+      let type: String =
+        (event.isARepeat || termsurfPressedBrowserKeys.contains(event.keyCode))
+        ? "repeat" : "down"
       let forwarded = forwardTermSurfKeyEvent(event, type: type)
       if forwarded {
         termsurfPressedBrowserKeys.insert(event.keyCode)
@@ -2518,10 +2539,13 @@ extension Ghostty {
     }
 
     private func forwardTermSurfKeyUp(_ event: NSEvent) -> Bool {
-      let forwarded = forwardTermSurfKeyEvent(event, type: "up")
-      if forwarded {
-        termsurfPressedBrowserKeys.remove(event.keyCode)
+      // Exp 7: only browser-owned presses get bulk-forward release.
+      // Unmatched / chrome-host keys: suppress webview up (return false → Ghostty RELEASE).
+      guard termsurfPressedBrowserKeys.contains(event.keyCode) else {
+        return false
       }
+      let forwarded = forwardTermSurfKeyEvent(event, type: "up")
+      termsurfPressedBrowserKeys.remove(event.keyCode)
       return forwarded
     }
 
