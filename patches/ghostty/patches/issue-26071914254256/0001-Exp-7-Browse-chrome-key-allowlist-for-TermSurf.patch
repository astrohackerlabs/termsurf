+/// Exp 7: true if this pane would accept browser key forward (no side effects).
+pub export fn termsurf_pane_browse_forwardable(pane_id: [*:0]const u8) c_int {
+    return if (termsurf.isBrowseForwardable(std.mem.span(pane_id))) 1 else 0;
+}
