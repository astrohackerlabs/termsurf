--- /dev/null
+++ b/src/input/browse_chrome.zig
@@ -0,0 +1,174 @@
+//! Browse-mode chrome key allowlist (Astrohacker Exp 7).
+//! When a TermSurf overlay is browse-forwardable, only these Ghostty actions
+//! should host-steal keys; everything else goes to the webview.
+const std = @import("std");
+const Binding = @import("Binding.zig");
+
+pub const BrowseKeyClass = enum(c_int) {
+    none = 0,
+    browse_chrome = 1,
+};
+
+/// Locked chrome action tags (Exp 7).
+pub fn isBrowseChromeAction(action: Binding.Action) bool {
+    return switch (action) {
+        .goto_split,
+        .new_split,
+        .resize_split,
+        .toggle_split_zoom,
+        .previous_tab,
+        .next_tab,
+        .move_tab,
+        .new_tab,
+        .close_tab,
+        .toggle_fullscreen,
+        .quit,
+        => true,
+        else => false,
+    };
+}
+
+/// True iff every action is chrome (empty slice is not chrome).
+pub fn isBrowseChromeActions(actions: []const Binding.Action) bool {
+    if (actions.len == 0) return false;
+    for (actions) |a| {
+        if (!isBrowseChromeAction(a)) return false;
+    }
+    return true;
+}
+
+/// Classify a set value from binding lookup (leaders are never chrome).
+pub fn classifySetValue(value: Binding.Set.Value) BrowseKeyClass {
+    return switch (value) {
+        .leader => .none,
+        .leaf => |leaf| if (isBrowseChromeAction(leaf.action)) .browse_chrome else .none,
+        .leaf_chained => |chained| if (isBrowseChromeActions(chained.actions.items))
+            .browse_chrome
+        else
+            .none,
+    };
+}
+
+test "chrome tags true" {
+    const testing = std.testing;
+    try testing.expect(isBrowseChromeAction(.{ .goto_split = .left }));
+    try testing.expect(isBrowseChromeAction(.{ .new_split = .right }));
+    try testing.expect(isBrowseChromeAction(.{ .resize_split = .{ .left, 80 } }));
+    try testing.expect(isBrowseChromeAction(.toggle_split_zoom));
+    try testing.expect(isBrowseChromeAction(.previous_tab));
+    try testing.expect(isBrowseChromeAction(.next_tab));
+    try testing.expect(isBrowseChromeAction(.{ .move_tab = 1 }));
+    try testing.expect(isBrowseChromeAction(.new_tab));
+    try testing.expect(isBrowseChromeAction(.{ .close_tab = .this }));
+    try testing.expect(isBrowseChromeAction(.toggle_fullscreen));
+    try testing.expect(isBrowseChromeAction(.quit));
+}
+
+test "non-chrome tags false" {
+    const testing = std.testing;
+    try testing.expect(!isBrowseChromeAction(.{ .copy_to_clipboard = .mixed }));
+    try testing.expect(!isBrowseChromeAction(.paste_from_clipboard));
+    try testing.expect(!isBrowseChromeAction(.{ .increase_font_size = 1 }));
+    try testing.expect(!isBrowseChromeAction(.open_config));
+    try testing.expect(!isBrowseChromeAction(.clear_screen));
+    try testing.expect(!isBrowseChromeAction(.new_window));
+}
+
+test "chain all chrome vs mixed" {
+    const testing = std.testing;
+    const all_chrome = [_]Binding.Action{
+        .{ .goto_split = .left },
+        .toggle_split_zoom,
+    };
+    try testing.expect(isBrowseChromeActions(&all_chrome));
+
+    const mixed = [_]Binding.Action{
+        .{ .goto_split = .left },
+        .{ .copy_to_clipboard = .mixed },
+    };
+    try testing.expect(!isBrowseChromeActions(&mixed));
+    try testing.expect(!isBrowseChromeActions(&.{}));
+}
+
+test "classifySetValue leaf and leader" {
+    const testing = std.testing;
+    const leaf_chrome: Binding.Set.Value = .{
+        .leaf = .{
+            .action = .{ .goto_split = .down },
+            .flags = .{},
+        },
+    };
+    try testing.expectEqual(BrowseKeyClass.browse_chrome, classifySetValue(leaf_chrome));
+
+    const leaf_copy: Binding.Set.Value = .{
+        .leaf = .{
+            .action = .{ .copy_to_clipboard = .mixed },
+            .flags = .{},
+        },
+    };
+    try testing.expectEqual(BrowseKeyClass.none, classifySetValue(leaf_copy));
+
+    var nested: Binding.Set = .{};
+    defer nested.deinit(testing.allocator);
+    const leader: Binding.Set.Value = .{ .leader = &nested };
+    try testing.expectEqual(BrowseKeyClass.none, classifySetValue(leader));
+}
+
+/// Exp 7 ownership helpers (pure) — bulk-forward only when browser owns the press.
+pub const BulkPhase = enum { press, repeat, release };
+
+/// Whether TermSurf bulk-forward is allowed for this phase given press ownership.
+/// Press: always try (unless host-steal preflight skipped the call).
+/// Repeat/release: only if press was accepted into browser-owned set.
+pub fn allowBrowserBulkForward(browser_owns_press: bool, phase: BulkPhase) bool {
+    return switch (phase) {
+        .press => true,
+        .repeat, .release => browser_owns_press,
+    };
+}
+
+/// Host-steal (skip bulk-forward) when browse-forwardable and chrome class.
+/// Esc is never bulk-forwarded elsewhere; this returns false for esc so callers
+/// do not double-special-case (AppKit still blocks Esc inside forward).
+pub fn shouldHostStealBrowseKey(browse_forwardable: bool, is_browse_chrome: bool) bool {
+    return browse_forwardable and is_browse_chrome;
+}
+
+test "bulk forward ownership phases" {
+    const testing = std.testing;
+    try testing.expect(allowBrowserBulkForward(false, .press));
+    try testing.expect(!allowBrowserBulkForward(false, .repeat));
+    try testing.expect(!allowBrowserBulkForward(false, .release));
+    try testing.expect(allowBrowserBulkForward(true, .press));
+    try testing.expect(allowBrowserBulkForward(true, .repeat));
+    try testing.expect(allowBrowserBulkForward(true, .release));
+}
+
+test "host steal only when forwardable and chrome" {
+    const testing = std.testing;
+    try testing.expect(shouldHostStealBrowseKey(true, true));
+    try testing.expect(!shouldHostStealBrowseKey(true, false));
+    try testing.expect(!shouldHostStealBrowseKey(false, true));
+    try testing.expect(!shouldHostStealBrowseKey(false, false));
+}
+
+test "classifySetValue leaf_chained all vs mixed" {
+    const testing = std.testing;
+    var all: std.ArrayList(Binding.Action) = .empty;
+    defer all.deinit(testing.allocator);
+    try all.append(testing.allocator, .{ .goto_split = .left });
+    try all.append(testing.allocator, .new_tab);
+    const v_all: Binding.Set.Value = .{
+        .leaf_chained = .{ .actions = all, .flags = .{} },
+    };
+    try testing.expectEqual(BrowseKeyClass.browse_chrome, classifySetValue(v_all));
+
+    var mixed: std.ArrayList(Binding.Action) = .empty;
+    defer mixed.deinit(testing.allocator);
+    try mixed.append(testing.allocator, .{ .goto_split = .left });
+    try mixed.append(testing.allocator, .{ .copy_to_clipboard = .mixed });
+    const v_mixed: Binding.Set.Value = .{
+        .leaf_chained = .{ .actions = mixed, .flags = .{} },
+    };
+    try testing.expectEqual(BrowseKeyClass.none, classifySetValue(v_mixed));
+}
