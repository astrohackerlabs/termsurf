+const GeckoTileHostCtx = struct {
+    host: ?*c.tsgt_host_t = null,
+    profile: [max_profile_len]u8 = undefined,
+    profile_len: usize = 0,
+    browser: [max_browser_len]u8 = undefined,
+    browser_len: usize = 0,
+    pane_id: [max_pane_id_len]u8 = undefined,
+    pane_id_len: usize = 0,
+    stop: std.atomic.Value(bool) = std.atomic.Value(bool).init(false),
+};
+
+// Thread owns GeckoTileHostCtx; no global registry needed for Exp4 v1.
+
+/// C present callback: log tiles + bridge to SurfaceView multi-tile present.
+export fn termsurfGeckoTilePresent(
+    ctx: ?*anyopaque,
+    tiles: ?*const c.tsgt_tile_t,
+    count: c_int,
+    pane_w_phys: c_int,
+    pane_h_phys: c_int,
+    scale: f64,
+) callconv(.c) void {
+    const host_ctx: *GeckoTileHostCtx = @ptrCast(@alignCast(ctx orelse return));
+    if (count <= 0) return;
+    log.info(
+        "gecko_tiles_present=1 count={} pane_phys={}x{} scale={d:.1} profile={s} browser={s}",
+        .{
+            count,
+            pane_w_phys,
+            pane_h_phys,
+            scale,
+            host_ctx.profile[0..host_ctx.profile_len],
+            host_ctx.browser[0..host_ctx.browser_len],
+        },
+    );
+    // Resolve pane_id for this gecko server and present via SurfaceView bridge.
+    state_mutex.lock();
+    var pane_z_buf: [max_pane_id_len + 1]u8 = undefined;
+    var have_pane = false;
+    if (host_ctx.pane_id_len > 0) {
+        @memcpy(pane_z_buf[0..host_ctx.pane_id_len], host_ctx.pane_id[0..host_ctx.pane_id_len]);
+        pane_z_buf[host_ctx.pane_id_len] = 0;
+        have_pane = true;
+    } else {
+        // Find first in-use pane for this profile/browser
+        for (&panes) |*pane| {
+            if (!pane.in_use) continue;
+            if (std.mem.eql(u8, pane.profileName(), host_ctx.profile[0..host_ctx.profile_len]) and
+                std.mem.eql(u8, pane.browserName(), host_ctx.browser[0..host_ctx.browser_len]))
+            {
+                const pid = pane.paneId();
+                @memcpy(pane_z_buf[0..pid.len], pid);
+                pane_z_buf[pid.len] = 0;
+                host_ctx.pane_id_len = pid.len;
+                @memcpy(host_ctx.pane_id[0..pid.len], pid);
+                have_pane = true;
+                break;
+            }
+        }
+    }
+    state_mutex.unlock();
+    if (!have_pane) return;
+    // Present every live tile into SurfaceView multi-tile layer stack.
+    if (tiles) |tptr| {
+        const arr: [*]const c.tsgt_tile_t = @ptrCast(tptr);
+        const n: usize = @intCast(count);
+        var i: usize = 0;
+        while (i < n) : (i += 1) {
+            const t = arr[i];
+            if (t.live == 0 or t.iosurface == null) continue;
+            termsurf_present_gecko_tile(
+                pane_z_buf[0..host_ctx.pane_id_len :0].ptr,
+                t.iosurface,
+                t.layer_id,
+                t.generation,
+                t.pos_x,
+                t.pos_y,
+                t.disp_x,
+                t.disp_y,
+                t.disp_w,
+                t.disp_h,
+                pane_w_phys,
+                pane_h_phys,
+                scale,
+            );
+        }
+    }
+}
+
+fn geckoTileHostThread(ctx: *GeckoTileHostCtx) void {
+    defer {
+        if (ctx.host) |h| {
+            var st: c.tsgt_stats_t = std.mem.zeroes(c.tsgt_stats_t);
+            c.tsgt_host_stats(h, &st);
+            log.info(
+                "gecko_tile_host_final_stats=1 updates={} acquired={} released={} acked={} removes={} max_live={} gen_monotonic_ok={} partial_tile_ok={} band_mask=0x{x} marker_changes={} exporter_pid={}",
+                .{
+                    st.updates,
+                    st.acquired,
+                    st.released,
+                    st.acked,
+                    st.removes,
+                    st.max_live,
+                    st.gen_monotonic_ok,
+                    st.partial_tile_ok,
+                    st.band_mask,
+                    st.marker_changes,
+                    st.exporter_pid,
+                },
+            );
+            c.tsgt_host_clear(h);
+            c.tsgt_host_stats(h, &st);
+            log.info(
+                "gecko_tile_host_after_clear=1 live={} acquired={} released={} acked={}",
+                .{ c.tsgt_host_live_count(h), st.acquired, st.released, st.acked },
+            );
+            c.tsgt_host_destroy(h);
+            ctx.host = null;
+        }
+        std.heap.c_allocator.destroy(ctx);
+    }
+    const host = ctx.host orelse return;
+    log.info("gecko_tile_host_thread=1 service={s}", .{c.tsgt_host_service(host)});
+    var sample_ticks: u32 = 0;
+    var idle_ms: u32 = 0;
+    var last_updates: u64 = 0;
+    while (!ctx.stop.load(.seq_cst)) {
+        const n = c.tsgt_host_poll(host, 100);
+        sample_ticks += 1;
+        var st: c.tsgt_stats_t = std.mem.zeroes(c.tsgt_stats_t);
+        c.tsgt_host_stats(host, &st);
+        if (n > 0 or st.updates != last_updates) {
+            idle_ms = 0;
+            last_updates = st.updates;
+        } else if (st.updates > 0) {
+            idle_ms += 100;
+        }
+        // Producer gone / stream idle: clear tile map for live=0 accounting.
+        if (idle_ms >= 3000) {
+            log.info("gecko_tile_host_idle_clear=1 updates={}", .{st.updates});
+            break;
+        }
+        if (sample_ticks % 25 == 0) {
+            c.tsgt_host_sample(host);
+            log.info(
+                "gecko_tile_host_stats=1 updates={} max_live={} acquired={} released={} acked={} live={} gen_monotonic_ok={} partial_tile_ok={}",
+                .{
+                    st.updates,
+                    st.max_live,
+                    st.acquired,
+                    st.released,
+                    st.acked,
+                    c.tsgt_host_live_count(host),
+                    st.gen_monotonic_ok,
+                    st.partial_tile_ok,
+                },
+            );
+        }
+    }
+}
+
+fn startGeckoTileHostThread(
+    profile: []const u8,
+    browser: []const u8,
+    service: []const u8,
+    child_pid: std.process.Child.Id,
+) void {
+    _ = child_pid;
+    var service_z_buf: [max_render_service_name_len + 1]u8 = undefined;
+    const service_z = std.fmt.bufPrintZ(&service_z_buf, "{s}", .{service}) catch {
+        log.warn("gecko tile host skipped: service name too long", .{});
+        return;
+    };
+    const ctx = std.heap.c_allocator.create(GeckoTileHostCtx) catch {
+        log.warn("gecko tile host ctx alloc failed", .{});
+        return;
+    };
+    ctx.* = .{};
+    if (!copyText(&ctx.profile, &ctx.profile_len, profile) or
+        !copyText(&ctx.browser, &ctx.browser_len, browser))
+    {
+        std.heap.c_allocator.destroy(ctx);
+        return;
+    }
+    const host = c.tsgt_host_create(service_z.ptr, termsurfGeckoTilePresent, ctx);
+    if (host == null) {
+        log.warn("gecko tile host create failed service={s}", .{service});
+        std.heap.c_allocator.destroy(ctx);
+        return;
+    }
+    ctx.host = host;
+    const thread = std.Thread.spawn(.{}, geckoTileHostThread, .{ctx}) catch |err| {
+        c.tsgt_host_destroy(host);
+        std.heap.c_allocator.destroy(ctx);
+        log.warn("gecko tile host thread spawn failed err={}", .{err});
+        return;
+    };
+    thread.detach();
+    log.info("gecko_tile_host_started=1 service={s} profile={s}", .{ service, profile });
+}
