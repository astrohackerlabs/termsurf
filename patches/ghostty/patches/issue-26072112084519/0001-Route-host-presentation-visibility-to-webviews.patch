+test "SetPresentationVisible preserves pre-TabReady state and edge transitions" {
+    const testing = std.testing;
+
+    resetTermsurfStateForTest();
+    defer resetTermsurfStateForTest();
+
+    var browser = try testSocketPair();
+    defer testCloseSocketPair(&browser);
+    var tui = try testSocketPair();
+    defer testCloseSocketPair(&tui);
+
+    try testSetPendingServer(0, "default", "webkit");
+    servers[0].attached_fd = browser[0];
+    try testSetPane(0, "pane-live", "default", "webkit", "https://example.test", tui[0]);
+
+    presentationVisibilityChanged("pane-live", true);
+    try testing.expect(panes[0].presentation_visible);
+    try testing.expect(panes[0].last_sent_presentation_visible == null);
+
+    var ready: c.Termsurf__TabReady = undefined;
+    c.termsurf__tab_ready__init(&ready);
+    ready.tab_id = 47;
+    ready.pane_id = @constCast("pane-live");
+    handleTabReady(&ready);
+
+    const browser_ready = try readTestMessage(tui[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(browser_ready, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_BROWSER_READY),
+        browser_ready.*.msg_case,
+    );
+
+    const visible = try readTestMessage(browser[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(visible, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_SET_PRESENTATION_VISIBLE),
+        visible.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 47), visible.*.unnamed_0.set_presentation_visible.*.tab_id);
+    try testing.expectEqual(@as(c_int, 1), visible.*.unnamed_0.set_presentation_visible.*.visible);
+
+    presentationVisibilityChanged("pane-live", false);
+    const hidden = try readTestMessage(browser[1], testing.allocator);
+    defer c.termsurf__term_surf_message__free_unpacked(hidden, null);
+    try testing.expectEqual(
+        @as(c.Termsurf__TermSurfMessage__MsgCase, c.TERMSURF__TERM_SURF_MESSAGE__MSG_SET_PRESENTATION_VISIBLE),
+        hidden.*.msg_case,
+    );
+    try testing.expectEqual(@as(i64, 47), hidden.*.unnamed_0.set_presentation_visible.*.tab_id);
+    try testing.expectEqual(@as(c_int, 0), hidden.*.unnamed_0.set_presentation_visible.*.visible);
+}
