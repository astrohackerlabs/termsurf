+    private var isTermSurfPresentationVisible: Bool {
+      guard let window else { return false }
+      guard isTermSurfSelectedTab else { return false }
+      guard !isHiddenOrHasHiddenAncestor else { return false }
+      guard window.isVisible, !window.isMiniaturized else { return false }
+      guard window.occlusionState.contains(.visible) else { return false }
+      return termsurfOverlayHostLayer?.superlayer != nil
+        && termsurfOverlayRootLayer?.superlayer != nil
+    }
+
+    private func syncTermSurfPresentationVisibility(reason: String) {
+      dispatchPrecondition(condition: .onQueue(.main))
+      let visible = isTermSurfPresentationVisible
+      termSurfLogGeometry(
+        event: "presentation_visibility",
+        visible: visible,
+        note: reason)
+      id.uuidString.withCString { paneIDPointer in
+        termsurf_presentation_visibility_changed(paneIDPointer, visible ? 1 : 0)
+      }
+    }
