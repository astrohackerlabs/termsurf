+pub fn presentationVisibilityChanged(pane_id: []const u8, visible: bool) void {
+    var snapshot: ?PresentationVisibleSnapshot = null;
+
+    state_mutex.lock();
+    if (findPane(pane_id)) |pane_index| {
+        var pane = &panes[pane_index];
+        pane.presentation_visible = visible;
+        snapshot = snapshotPresentationVisible(pane);
+        if (snapshot != null)
+            pane.last_sent_presentation_visible = visible;
+    } else {
+        log.warn("SetPresentationVisible ignored: no pane pane_id={s} visible={}", .{ pane_id, visible });
+    }
+    state_mutex.unlock();
+
+    if (snapshot) |value| {
+        sendPresentationVisible(&value) catch |err| {
+            state_mutex.lock();
+            if (findPane(value.paneId())) |pane_index| {
+                if (panes[pane_index].last_sent_presentation_visible == value.visible)
+                    panes[pane_index].last_sent_presentation_visible = null;
+            }
+            state_mutex.unlock();
+            log.warn(
+                "SetPresentationVisible send failed pane_id={s} tab_id={} visible={} err={}",
+                .{ value.paneId(), value.tab_id, value.visible, err },
+            );
+        };
+    }
+}
+
+fn snapshotPresentationVisible(pane: *const PaneState) ?PresentationVisibleSnapshot {
+    if (pane.tab_id == 0) return null;
+    if (pane.last_sent_presentation_visible == pane.presentation_visible) return null;
+    const server_index = findServer(pane.profileName(), pane.browserName()) orelse return null;
+    if (servers[server_index].attached_fd < 0) return null;
+
+    var snapshot: PresentationVisibleSnapshot = .{
+        .browser_fd = servers[server_index].attached_fd,
+        .tab_id = pane.tab_id,
+        .visible = pane.presentation_visible,
+    };
+    if (!copyText(&snapshot.pane_id, &snapshot.pane_id_len, pane.paneId())) return null;
+    return snapshot;
+}
+
+fn sendPresentationVisible(snapshot: *const PresentationVisibleSnapshot) !void {
+    var visible: c.Termsurf__SetPresentationVisible = undefined;
+    c.termsurf__set_presentation_visible__init(&visible);
+    visible.tab_id = snapshot.tab_id;
+    visible.visible = if (snapshot.visible) 1 else 0;
+
+    var wrapper: c.Termsurf__TermSurfMessage = undefined;
+    c.termsurf__term_surf_message__init(&wrapper);
+    wrapper.msg_case = c.TERMSURF__TERM_SURF_MESSAGE__MSG_SET_PRESENTATION_VISIBLE;
+    wrapper.unnamed_0.set_presentation_visible = &visible;
+
+    try sendProtobuf(snapshot.browser_fd, &wrapper);
+    log.info(
+        "SetPresentationVisible: pane_id={s} tab_id={} visible={}",
+        .{ snapshot.paneId(), snapshot.tab_id, snapshot.visible },
+    );
+}
+
