+            effectiveRadius
         }
 
         /// Inner content/dim clip: max(0, R - borderWidth) for concentric stroke.
-        private func innerBorderRadius(windowRadius: CGFloat, borderWidth: CGFloat) -> CGFloat {
-            max(0, windowRadius - borderWidth)
+        /// When R is 0, returns 0 (square clip / no rounding).
+        private func innerBorderRadius(effectiveRadius: CGFloat, borderWidth: CGFloat) -> CGFloat {
+            max(0, effectiveRadius - borderWidth)
         }
 
         var body: some View {
