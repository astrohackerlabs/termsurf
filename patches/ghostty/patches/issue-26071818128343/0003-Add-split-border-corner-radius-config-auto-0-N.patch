diff --git a/src/config/Config.zig b/src/config/Config.zig
index 158fdd527..b630b5eb3 100644
--- a/src/config/Config.zig
+++ b/src/config/Config.zig
@@ -1112,6 +1112,17 @@ palette: Palette = .{},
 /// windows show borders without config. Set to 0 to disable borders.
 @"split-border-width": f64 = 2,
 
+/// Corner radius of multi-pane split borders, in points.
+///
+/// - `auto` (default): match the macOS window corner radius when available
+///   (private `_cornerRadius`), otherwise a modest product fallback (10).
+/// - `0`: square corners (no rounding).
+/// - positive number: fixed continuous radius on all four corners of each pane.
+///
+/// Independent of `split-border-width`: width `0` still disables border chrome;
+/// radius `0` keeps a square border when width is positive.
+@"split-border-corner-radius": SplitBorderCornerRadius = .auto,
+
 /// The color saturation of unfocused split panes. 1.0 is full color, 0.0 is
 /// full grayscale. Only applies when in a split layout.
 @"unfocused-split-saturation": f64 = 1.0,
@@ -4768,6 +4779,14 @@ pub fn finalize(self: *Config) !void {
     // Clamp our split border width
     self.@"split-border-width" = @min(10.0, @max(0, self.@"split-border-width"));
 
+    // Clamp fixed split border corner radius (auto is unchanged)
+    switch (self.@"split-border-corner-radius") {
+        .auto => {},
+        .fixed => |v| self.@"split-border-corner-radius" = .{
+            .fixed = @min(40.0, @max(0, v)),
+        },
+    }
+
     // Clamp our split saturation
     self.@"unfocused-split-saturation" = @min(1.0, @max(0, self.@"unfocused-split-saturation"));
 
@@ -9819,6 +9838,80 @@ pub const AutoUpdate = enum {
     download,
 };
 
+/// See split-border-corner-radius
+pub const SplitBorderCornerRadius = union(enum) {
+    /// Match macOS window `_cornerRadius` (or product fallback) on all corners.
+    auto,
+    /// Fixed continuous radius in points. `0` means square (no rounding).
+    fixed: f64,
+
+    pub fn parseCLI(self: *SplitBorderCornerRadius, input: ?[]const u8) !void {
+        const input_ = input orelse {
+            self.* = .auto;
+            return;
+        };
+
+        if (std.mem.eql(u8, input_, "auto")) {
+            self.* = .auto;
+            return;
+        }
+
+        const value = std.fmt.parseFloat(f64, input_) catch return error.InvalidValue;
+        if (!std.math.isFinite(value) or value < 0) return error.InvalidValue;
+        self.* = .{ .fixed = value };
+    }
+
+    /// C bridge: negative sentinel means auto; non-negative is fixed points.
+    pub fn cval(self: SplitBorderCornerRadius) f64 {
+        return switch (self) {
+            .auto => -1,
+            .fixed => |v| v,
+        };
+    }
+
+    pub fn formatEntry(
+        self: SplitBorderCornerRadius,
+        formatter: anytype,
+    ) !void {
+        switch (self) {
+            .auto => try formatter.formatEntry([]const u8, "auto"),
+            .fixed => |v| try formatter.formatEntry(f64, v),
+        }
+    }
+
+    test "parse SplitBorderCornerRadius" {
+        const testing = std.testing;
+        var v: SplitBorderCornerRadius = undefined;
+
+        try v.parseCLI(null);
+        try testing.expectEqual(SplitBorderCornerRadius.auto, v);
+
+        try v.parseCLI("auto");
+        try testing.expectEqual(SplitBorderCornerRadius.auto, v);
+
+        try v.parseCLI("0");
+        try testing.expectEqual(@as(f64, 0), v.fixed);
+
+        try v.parseCLI("12");
+        try testing.expectEqual(@as(f64, 12), v.fixed);
+
+        try v.parseCLI("6.5");
+        try testing.expectEqual(@as(f64, 6.5), v.fixed);
+
+        try testing.expectError(error.InvalidValue, v.parseCLI(""));
+        try testing.expectError(error.InvalidValue, v.parseCLI("aaaa"));
+        try testing.expectError(error.InvalidValue, v.parseCLI("-1"));
+        try testing.expectError(error.InvalidValue, v.parseCLI("inf"));
+    }
+
+    test "cval SplitBorderCornerRadius" {
+        const testing = std.testing;
+        try testing.expectEqual(@as(f64, -1), (SplitBorderCornerRadius{ .auto = {} }).cval());
+        try testing.expectEqual(@as(f64, 0), (SplitBorderCornerRadius{ .fixed = 0 }).cval());
+        try testing.expectEqual(@as(f64, 12), (SplitBorderCornerRadius{ .fixed = 12 }).cval());
+    }
+};
+
 /// See background-blur
 pub const BackgroundBlur = union(enum) {
     false,
diff --git a/src/config/c_get.zig b/src/config/c_get.zig
index 2b7dd1005..4a0a847aa 100644
--- a/src/config/c_get.zig
+++ b/src/config/c_get.zig
@@ -266,3 +266,30 @@ test "c_get: split-preserve-zoom" {
     try testing.expect(get(&c, .@"split-preserve-zoom", @ptrCast(&bits)));
     try testing.expectEqual(@as(c_uint, 1), bits);
 }
+
+test "c_get: split-border-corner-radius" {
+    const testing = std.testing;
+    const alloc = testing.allocator;
+
+    var c = try Config.default(alloc);
+    defer c.deinit();
+
+    {
+        // Default is auto → sentinel -1
+        var cval: f64 = undefined;
+        try testing.expect(get(&c, .@"split-border-corner-radius", @ptrCast(&cval)));
+        try testing.expectEqual(@as(f64, -1), cval);
+    }
+    {
+        c.@"split-border-corner-radius" = .{ .fixed = 0 };
+        var cval: f64 = undefined;
+        try testing.expect(get(&c, .@"split-border-corner-radius", @ptrCast(&cval)));
+        try testing.expectEqual(@as(f64, 0), cval);
+    }
+    {
+        c.@"split-border-corner-radius" = .{ .fixed = 12 };
+        var cval: f64 = undefined;
+        try testing.expect(get(&c, .@"split-border-corner-radius", @ptrCast(&cval)));
+        try testing.expectEqual(@as(f64, 12), cval);
+    }
+}
