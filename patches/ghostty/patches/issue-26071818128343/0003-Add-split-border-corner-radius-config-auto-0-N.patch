@@ -331,10 +350,17 @@ extension Ghostty {
                             borderWidth: borderWidth,
                             colorKey: colorKey
                         )
-                        let outerR = outerBorderRadius(windowRadius: windowR)
-                        RoundedRectangle(cornerRadius: outerR, style: .continuous)
-                            .strokeBorder(color, lineWidth: CGFloat(borderWidth))
