From 79f6b04703ea537507599c7ba9116ac97e3ce2ca Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 18 Jul 2026 13:43:30 -0500
Subject: [PATCH] Add split-border-corner-radius config (auto|0|N)

Configurable all-corner pane radius: auto matches the window
_cornerRadius (Exp 1 default), 0 forces square stroke/clip, and a
positive fixed radius pins continuous rounding on every corner.
---
 macos/Sources/Ghostty/Ghostty.Config.swift    | 20 ++++
 .../Ghostty/Surface View/SurfaceView.swift    | 62 +++++++++----
 src/config/Config.zig                         | 93 +++++++++++++++++++
 src/config/c_get.zig                          | 27 ++++++
 4 files changed, 184 insertions(+), 18 deletions(-)

diff --git a/macos/Sources/Ghostty/Ghostty.Config.swift b/macos/Sources/Ghostty/Ghostty.Config.swift
index a3ea6f3bf..ad2b62b95 100644
--- a/macos/Sources/Ghostty/Ghostty.Config.swift
+++ b/macos/Sources/Ghostty/Ghostty.Config.swift
@@ -639,6 +639,26 @@ extension Ghostty {
             return value
         }
 
+        /// Corner radius for multi-pane split borders.
+        ///
+        /// - `nil` = `auto` (match window `_cornerRadius` / product fallback)
+        /// - `0` = square corners
+        /// - `>0` = fixed continuous radius in points
+        ///
+        /// Zig uses cval sentinel `-1` for auto.
+        var splitBorderCornerRadius: Double? {
+            guard let config = self.config else { return nil }
+            var value: Double = -1
+            let key = "split-border-corner-radius"
+            guard ghostty_config_get(config, &value, key, UInt(key.lengthOfBytes(using: .utf8))) else {
+                return nil
+            }
+            if value < 0 {
+                return nil
+            }
+            return value
+        }
+
         var unfocusedSplitSaturation: Double {
             guard let config = self.config else { return 1.0 }
             var value: Double = 1.0
