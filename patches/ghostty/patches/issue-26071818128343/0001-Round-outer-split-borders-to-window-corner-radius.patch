--- a/macos/Sources/Ghostty/Surface View/SurfaceView.swift	
+++ b/macos/Sources/Ghostty/Surface View/SurfaceView.swift	
@@ -42,6 +42,9 @@ extension Ghostty {
         // we know whether to dim the surface out of focus.
         var isSplit: Bool = false
 
+        /// Edges of this pane that touch the window chrome (outer corner rounding).
+        var windowEdges: Edge.Set = [.top, .bottom, .leading, .trailing]
+
         // Maintain whether our view has focus or not
         @FocusState private var surfaceFocus: Bool
 
@@ -93,6 +96,47 @@ extension Ghostty {
 #endif
         }
 
+
+        /// Fallback when `_cornerRadius` is unavailable (pre-Tahoe / private API).
+        /// Modest continuous radius so Sequoia-class windows still improve slightly.
+        private static let splitBorderCornerRadiusFallback: CGFloat = 10
+
+        /// System window corner radius via private `_cornerRadius` (same source as
+        /// TerminalViewContainer.glass), with product fallback.
+        private var resolvedWindowCornerRadius: CGFloat {
+#if canImport(AppKit)
+            if let window = surfaceView.window,
+               window.responds(to: Selector(("_cornerRadius"))),
+               let radius = window.value(forKey: "_cornerRadius") as? CGFloat,
+               radius > 0 {
+                return radius
+            }
+#endif
+            return Self.splitBorderCornerRadiusFallback
+        }
+
+        /// Outer stroke radii: window R only on corners that touch the window edge.
+        private func outerCornerRadii(windowRadius: CGFloat) -> RectangleCornerRadii {
+            let r = windowRadius
+            return RectangleCornerRadii(
+                topLeading: (windowEdges.contains(.top) && windowEdges.contains(.leading)) ? r : 0,
+                bottomLeading: (windowEdges.contains(.bottom) && windowEdges.contains(.leading)) ? r : 0,
+                bottomTrailing: (windowEdges.contains(.bottom) && windowEdges.contains(.trailing)) ? r : 0,
+                topTrailing: (windowEdges.contains(.top) && windowEdges.contains(.trailing)) ? r : 0
+            )
+        }
+
+        /// Inner content/dim clip radii: max(0, R - borderWidth) on the same outer corners.
+        private func innerCornerRadii(windowRadius: CGFloat, borderWidth: CGFloat) -> RectangleCornerRadii {
+            let r = max(0, windowRadius - borderWidth)
+            return RectangleCornerRadii(
+                topLeading: (windowEdges.contains(.top) && windowEdges.contains(.leading)) ? r : 0,
+                bottomLeading: (windowEdges.contains(.bottom) && windowEdges.contains(.leading)) ? r : 0,
+                bottomTrailing: (windowEdges.contains(.bottom) && windowEdges.contains(.trailing)) ? r : 0,
+                topTrailing: (windowEdges.contains(.top) && windowEdges.contains(.trailing)) ? r : 0
+            )
+        }
+
         var body: some View {
             let center = NotificationCenter.default
 
