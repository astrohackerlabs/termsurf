+fn testSocketPair() ![2]std.posix.fd_t {
+    var fds: [2]c_int = undefined;
+    if (c.socketpair(c.AF_UNIX, c.SOCK_STREAM, 0, &fds) != 0) return error.SocketPairFailed;
+    return .{ fds[0], fds[1] };
+}
