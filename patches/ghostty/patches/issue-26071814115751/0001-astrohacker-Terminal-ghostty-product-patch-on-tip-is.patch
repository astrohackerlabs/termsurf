+fn testCloseSocketPair(fds: *[2]std.posix.fd_t) void {
+    if (fds[0] >= 0) {
+        std.posix.close(fds[0]);
+        fds[0] = -1;
+    }
+    if (fds[1] >= 0) {
+        std.posix.close(fds[1]);
+        fds[1] = -1;
+    }
+}
