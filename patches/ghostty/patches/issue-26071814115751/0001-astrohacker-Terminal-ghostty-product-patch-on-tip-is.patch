+    if (std.mem.eql(u8, browser, default_browser) or std.mem.eql(u8, browser, "chromium")) {
+        return resolveEnginePathFromEnv(
+            browser,
+            is_debug,
+            chromium_path_env,
+            chromium_path_env_legacy,
+            chromium_path_env_legacy_installed,
+            installed_chromium_path,
+        );
+    }
+
+    if (std.mem.eql(u8, browser, "webkit")) {
+        return resolveEnginePathFromEnv(
+            browser,
+            is_debug,
+            webkit_path_env,
+            webkit_path_env_legacy,
+            webkit_path_env_legacy_installed,
+            installed_webkit_path,
+        );
+    }
+
+    if (std.mem.eql(u8, browser, "ladybird")) {
+        return resolveEnginePathFromEnv(
+            browser,
+            is_debug,
+            ladybird_path_env,
+            ladybird_path_env_legacy,
