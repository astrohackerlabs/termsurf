+fn buildBrowserSpawnArgv(
+    out: *BrowserSpawnArgv,
+    browser_executable: []const u8,
+    browser_name: []const u8,
+    profile: []const u8,
+    gui_socket: []const u8,
+    listen_socket: []const u8,
+    ghostboard_pid: i32,
+) ?[]const []const u8 {
