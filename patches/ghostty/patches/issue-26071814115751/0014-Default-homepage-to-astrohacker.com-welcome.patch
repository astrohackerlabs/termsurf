From 0b0e85b30fb19513a5a86bdcb3a161cb09211f1b Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 18 Jul 2026 06:05:01 -0500
Subject: [PATCH 14/17] Default homepage to astrohacker.com/welcome

Product default for Config.homepage, HelloReply fallback, and Swift
config bridge now open https://astrohacker.com/welcome instead of
termsurf.com/welcome when no URL is supplied.
---
 macos/Sources/Ghostty/Ghostty.Config.swift | 2 +-
 src/apprt/termsurf.zig                     | 2 +-
 src/config/Config.zig                      | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/macos/Sources/Ghostty/Ghostty.Config.swift b/macos/Sources/Ghostty/Ghostty.Config.swift
index 383f27133..a3ea6f3bf 100644
--- a/macos/Sources/Ghostty/Ghostty.Config.swift
+++ b/macos/Sources/Ghostty/Ghostty.Config.swift
@@ -182,7 +182,7 @@ extension Ghostty {
         }
 
         var homepage: String {
-            let defaultValue = "https://termsurf.com/welcome"
+            let defaultValue = "https://astrohacker.com/welcome"
             guard let config = self.config else { return defaultValue }
             var v: UnsafePointer<Int8>?
             let key = "homepage"
diff --git a/src/apprt/termsurf.zig b/src/apprt/termsurf.zig
index f915f15e7..200360dbc 100644
--- a/src/apprt/termsurf.zig
+++ b/src/apprt/termsurf.zig
@@ -39,7 +39,7 @@ const max_health_response_len: usize = 2048;
 const max_homepage_len: usize = max_url_len;
 const max_listen_socket_len: usize = std.fs.max_path_bytes;
 const default_browser = "chromium";
-const default_homepage = "https://termsurf.com/welcome";
+const default_homepage = "https://astrohacker.com/welcome";
 const fallback_cell_width: u64 = 10;
 const fallback_cell_height: u64 = 20;
 const geometry_trace_env = "TERMSURF_GEOMETRY_TRACE";
diff --git a/src/config/Config.zig b/src/config/Config.zig
index 80da71155..158fdd527 100644
--- a/src/config/Config.zig
+++ b/src/config/Config.zig
@@ -1345,7 +1345,7 @@ command: ?Command = null,
 env: RepeatableStringMap = .{},
 
 /// The default homepage URL opened by `web` when no URL is supplied.
-homepage: [:0]const u8 = "https://termsurf.com/welcome",
+homepage: [:0]const u8 = "https://astrohacker.com/welcome",
 
 /// The browser names advertised to `web`.
 ///
-- 
