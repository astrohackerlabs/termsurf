+fn snapshotEnabledBackAction(
+    pane_id: []const u8,
+    required_tui_fd: ?std.posix.fd_t,
+) ?BrowserInputSnapshot {
+    state_mutex.lock();
+    defer state_mutex.unlock();
+
+    const pane_index = findPane(pane_id) orelse {
+        log.warn("NavigationAction: unknown pane_id={s}", .{pane_id});
+        return null;
+    };
+    const pane = &panes[pane_index];
+    if (required_tui_fd) |tui_fd| {
+        if (pane.tui_fd != tui_fd) {
+            log.warn(
+                "NavigationAction: unowned pane_id={s} tab_id={} fd={}",
+                .{ pane_id, pane.tab_id, tui_fd },
+            );
+            return null;
+        }
+    }
+    if (pane.tab_id <= 0 or !pane.can_go_back) {
+        log.info(
+            "NavigationAction disabled pane_id={s} tab_id={} action=back",
+            .{ pane_id, pane.tab_id },
+        );
+        return null;
+    }
+    const server_index = findServer(pane.profileName(), pane.browserName()) orelse return null;
+    if (servers[server_index].attached_fd < 0) return null;
+
+    var snapshot: BrowserInputSnapshot = .{
+        .browser_fd = servers[server_index].attached_fd,
+        .tab_id = pane.tab_id,
+    };
+    if (!copyText(&snapshot.pane_id, &snapshot.pane_id_len, pane.paneId())) return null;
+    return snapshot;
