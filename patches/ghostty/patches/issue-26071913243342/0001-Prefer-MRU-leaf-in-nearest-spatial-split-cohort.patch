diff --git a/macos/Tests/Splits/SplitTreeTests.swift b/macos/Tests/Splits/SplitTreeTests.swift
index 8b1974022..9922ba945 100644
--- a/macos/Tests/Splits/SplitTreeTests.swift
+++ b/macos/Tests/Splits/SplitTreeTests.swift
@@ -171,8 +171,232 @@ struct SplitTreeTests {
         #expect(target === view1)
     }
 
+    // MARK: - Spatial MRU / nearest primary-axis cohort (issue 26071913243342 exp-0001)
+
+    /// L | (TR / BR): horizontal split, then vertical split on the right.
+    static func makeNestedRightSplit() throws -> (
+        tree: SplitTree<MockView>,
+        left: MockView,
+        topRight: MockView,
+        bottomRight: MockView
+    ) {
+        let left = MockView()
+        let topRight = MockView()
+        let bottomRight = MockView()
+        var tree = SplitTree<MockView>(view: left)
+        tree = try tree.inserting(view: topRight, at: left, direction: .right)
+        tree = try tree.inserting(view: bottomRight, at: topRight, direction: .down)
+        return (tree, left, topRight, bottomRight)
+    }
+
+    @Test func spatialMRURestoresBottomRightAfterLeavingNestedSplit() throws {
+        let (tree, left, topRight, bottomRight) = try Self.makeNestedRightSplit()
+        // Empty history: geometry prefers top-right (top-left distance from L).
+        let empty = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [])
+        #expect(empty === topRight)
+        // History after BR → L: MRU among nearest right cohort restores BR.
+        let restored = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [left.id, bottomRight.id, topRight.id])
+        #expect(restored === bottomRight)
+    }
+
+    @Test func spatialEmptyHistoryReturnsGeometryWinnerNotArbitraryLeaf() throws {
+        let (tree, left, topRight, _) = try Self.makeNestedRightSplit()
+        let target = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [])
+        #expect(target === topRight)
+    }
+
+    @Test func spatialMRUIgnoresOutOfCohortHistory() throws {
+        let (tree, left, topRight, bottomRight) = try Self.makeNestedRightSplit()
+        // Far history that is not a right-side candidate should not matter.
+        let outsider = MockView()
+        let target = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [outsider.id, left.id])
+        #expect(target === topRight)
+        // BR preferred when in history and in cohort.
+        let withBR = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [left.id, bottomRight.id])
+        #expect(withBR === bottomRight)
+    }
+
+    @Test func spatialMRUSkipsRemovedPreferredLeaf() throws {
+        let (tree, left, topRight, bottomRight) = try Self.makeNestedRightSplit()
+        // Prefer closed/removed id first, then fall back to live cohort/geometry.
+        let gone = UUID()
+        let target = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [gone, bottomRight.id, topRight.id])
+        #expect(target === bottomRight)
+        let onlyGone = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [gone])
+        #expect(onlyGone === topRight)
+    }
+
+    @Test func spatialNearerBandBeatsFartherRecentHistory() throws {
+        // L | Mid | Far — three horizontal columns.
+        let left = MockView()
+        let mid = MockView()
+        let far = MockView()
+        var tree = SplitTree<MockView>(view: left)
+        tree = try tree.inserting(view: mid, at: left, direction: .right)
+        tree = try tree.inserting(view: far, at: mid, direction: .right)
+        // History prefers far, but nearest right band is Mid only.
+        let target = tree.focusTarget(
+            for: .spatial(.right),
+            from: .leaf(view: left),
+            recentFocusIDs: [far.id, mid.id, left.id])
+        #expect(target === mid)
+    }
+
+    @Test(
+        arguments: [
+            SplitTree<MockView>.Spatial.Direction.right,
+            .left,
+            .down,
+            .up,
+        ]
+    )
+    func spatialMRUFourDirectionsInBand(
+        direction: SplitTree<MockView>.Spatial.Direction
+    ) throws {
+        // Build a 2×2 grid: insert right then down on each column.
+        // A | B
+        // C | D
+        let a = MockView()
+        let b = MockView()
+        let c = MockView()
+        let d = MockView()
+        var tree = SplitTree<MockView>(view: a)
+        tree = try tree.inserting(view: b, at: a, direction: .right)
+        tree = try tree.inserting(view: c, at: a, direction: .down)
+        tree = try tree.inserting(view: d, at: b, direction: .down)
+
+        // From each origin, the two leaves in `direction` share a nearest band;
+        // prefer the "secondary" leaf via MRU.
+        switch direction {
+        case .right:
+            // From C, right cohort is D (and possibly others in that column).
+            let t = tree.focusTarget(
+                for: .spatial(.right),
+                from: .leaf(view: c),
+                recentFocusIDs: [d.id, c.id])
+            #expect(t === d)
+            // Farther history cannot apply if we only have right neighbors in band —
+            // with only D to the right of C, still D.
+            let empty = tree.focusTarget(
+                for: .spatial(.right),
+                from: .leaf(view: c),
+                recentFocusIDs: [])
+            #expect(empty === d || empty === b) // geometry may pick B or D by distance
+        case .left:
+            let t = tree.focusTarget(
+                for: .spatial(.left),
+                from: .leaf(view: d),
+                recentFocusIDs: [c.id, d.id])
+            #expect(t === c)
+        case .down:
+            // From A, down cohort: C (same column). Prefer C via MRU.
+            let t = tree.focusTarget(
+                for: .spatial(.down),
+                from: .leaf(view: a),
+                recentFocusIDs: [c.id, a.id])
+            #expect(t === c)
+        case .up:
+            let t = tree.focusTarget(
+                for: .spatial(.up),
+                from: .leaf(view: c),
+                recentFocusIDs: [a.id, c.id])
+            #expect(t === a)
+        }
+    }
+
+    @Test(
+        arguments: [
+            SplitTree<MockView>.Spatial.Direction.right,
+            .left,
+            .down,
+            .up,
+        ]
+    )
+    func spatialNearerBandBeatsFarHistoryFourDirections(
+        direction: SplitTree<MockView>.Spatial.Direction
+    ) throws {
+        // Three leaves in a line along the primary axis of `direction`.
+        let near = MockView()
+        let mid = MockView()
+        let far = MockView()
+        var tree = SplitTree<MockView>(view: near)
+        switch direction {
+        case .right:
+            tree = try tree.inserting(view: mid, at: near, direction: .right)
+            tree = try tree.inserting(view: far, at: mid, direction: .right)
+            let t = tree.focusTarget(
+                for: .spatial(.right),
+                from: .leaf(view: near),
+                recentFocusIDs: [far.id, mid.id, near.id])
+            #expect(t === mid)
+        case .left:
+            tree = try tree.inserting(view: mid, at: near, direction: .left)
+            tree = try tree.inserting(view: far, at: mid, direction: .left)
+            let t = tree.focusTarget(
+                for: .spatial(.left),
+                from: .leaf(view: near),
+                recentFocusIDs: [far.id, mid.id, near.id])
+            #expect(t === mid)
+        case .down:
+            tree = try tree.inserting(view: mid, at: near, direction: .down)
+            tree = try tree.inserting(view: far, at: mid, direction: .down)
+            let t = tree.focusTarget(
+                for: .spatial(.down),
+                from: .leaf(view: near),
+                recentFocusIDs: [far.id, mid.id, near.id])
+            #expect(t === mid)
+        case .up:
+            tree = try tree.inserting(view: mid, at: near, direction: .up)
+            tree = try tree.inserting(view: far, at: mid, direction: .up)
+            let t = tree.focusTarget(
+                for: .spatial(.up),
+                from: .leaf(view: near),
+                recentFocusIDs: [far.id, mid.id, near.id])
+            #expect(t === mid)
+        }
+    }
+
+    @Test func previousNextIgnoreSpatialMRUHistory() throws {
+        let (tree, view1, view2) = try makeHorizontalSplit()
+        let view3 = MockView()
+        let tree3 = try tree.inserting(view: view3, at: view2, direction: .right)
+        // Non-empty MRU must not alter tree-order previous/next.
+        let next = tree3.focusTarget(
+            for: .next,
+            from: .leaf(view: view1),
+            recentFocusIDs: [view3.id, view2.id, view1.id])
+        #expect(next === view2)
+        let prev = tree3.focusTarget(
+            for: .previous,
+            from: .leaf(view: view2),
+            recentFocusIDs: [view3.id, view1.id, view2.id])
+        #expect(prev === view1)
+    }
+
     // MARK: - Equalized
 
+
     @Test func equalizedAdjustsRatioByLeafCount() throws {
         let view1 = MockView()
         let view2 = MockView()
