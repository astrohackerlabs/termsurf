From 05f6a4d599ea42bf598d031bbeae02b2dc61e7a4 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sun, 19 Jul 2026 08:41:20 -0500
Subject: [PATCH] Prefer MRU leaf in nearest spatial split cohort

Spatial goto_split left/right/up/down now restores the most recently
focused leaf among the nearest primary-axis cohort, fixing nested split
return (bottom-right after left then right). previous/next stay tree-order.

Issue 26071913243342 exp-0001.
---
 macos/Sources/Features/Splits/SplitTree.swift |  75 +++++-
 .../Terminal/BaseTerminalController.swift     |  38 ++-
 macos/Sources/Ghostty/Ghostty.App.swift       |   7 +-
 macos/Tests/Splits/SplitTreeTests.swift       | 224 ++++++++++++++++++
 4 files changed, 329 insertions(+), 15 deletions(-)

diff --git a/macos/Sources/Features/Splits/SplitTree.swift b/macos/Sources/Features/Splits/SplitTree.swift
index 30caae0da..8200a27ab 100644
--- a/macos/Sources/Features/Splits/SplitTree.swift
+++ b/macos/Sources/Features/Splits/SplitTree.swift
@@ -173,8 +173,16 @@ extension SplitTree {
         return .init(root: newRoot, zoomed: newZoomed)
     }
 
-    /// Find the next view to focus based on the current focused node and direction
-    func focusTarget(for direction: FocusDirection, from currentNode: Node) -> ViewType? {
+    /// Find the next view to focus based on the current focused node and direction.
+    ///
+    /// - Parameter recentFocusIDs: Most-recently-focused leaf IDs first (spatial only).
+    ///   Used to restore the last active leaf within the **nearest primary-axis cohort**
+    ///   in the requested direction. Empty list preserves pure geometry selection.
+    func focusTarget(
+        for direction: FocusDirection,
+        from currentNode: Node,
+        recentFocusIDs: [ViewType.ID] = []
+    ) -> ViewType? {
         guard let root else { return nil }
 
         switch direction {
@@ -200,7 +208,11 @@ extension SplitTree {
             return allLeaves[index]
 
         case .spatial(let spatialDirection):
-            // Get spatial representation and find best candidate
+            // Spatial navigation:
+            // 1) Directional leaf candidates (geometry half-plane)
+            // 2) Nearest primary-axis cohort (locality)
+            // 3) MRU among that cohort (recentFocusIDs)
+            // 4) Else geometry fallback (top-left distance / leftmost·rightmost)
             let spatial = root.spatial()
             let nodes = spatial.slots(in: spatialDirection, from: currentNode)
 
@@ -210,24 +222,67 @@ extension SplitTree {
                 return nil
             }
 
-            // Extract the view from the best candidate node. The best candidate
-            // node is the closest leaf node. If we have no leaves (impossible?)
-            // just use the first node.
+            // Geometry fallback winner (historical behavior).
             let bestNode = nodes.first(where: {
                 if case .leaf = $0.node { return true } else { return false }
             }) ?? nodes[0]
-            switch bestNode.node {
+            let geometryWinner: ViewType = switch bestNode.node {
             case .leaf(let view):
-                return view
-
+                view
             case .split:
                 // If the best candidate is a split node, use its the leaf/rightmost
                 // depending on our spatial direction.
-                return switch spatialDirection {
+                switch spatialDirection {
                 case .up, .left: bestNode.node.leftmostLeaf()
                 case .down, .right: bestNode.node.rightmostLeaf()
                 }
             }
+
+            // Leaf slots only for cohort + MRU (stable bounds from spatial map).
+            let leafSlots: [(view: ViewType, bounds: CGRect)] = nodes.compactMap { slot in
+                if case .leaf(let view) = slot.node {
+                    return (view, slot.bounds)
+                }
+                return nil
+            }
+            if leafSlots.isEmpty {
+                return geometryWinner
+            }
+
+            // Primary-axis key: nearest band for this direction.
+            func primaryKey(_ bounds: CGRect) -> Double {
+                switch spatialDirection {
+                case .right: return bounds.minX
+                case .left: return bounds.maxX
+                case .down: return bounds.minY
+                case .up: return bounds.maxY
+                }
+            }
+            let keys = leafSlots.map { primaryKey($0.bounds) }
+            let nearestKey: Double = switch spatialDirection {
+            case .right, .down: keys.min()!
+            case .left, .up: keys.max()!
+            }
+            // Epsilon so stacked panes sharing an edge form one cohort.
+            let epsilon = 1e-6
+            let cohort = leafSlots.filter {
+                abs(primaryKey($0.bounds) - nearestKey) <= epsilon
+            }
+
+            // Prefer most recently focused leaf still in the nearest cohort.
+            if !recentFocusIDs.isEmpty {
+                var cohortByID: [ViewType.ID: ViewType] = [:]
+                for item in cohort {
+                    cohortByID[item.view.id] = item.view
+                }
+                for id in recentFocusIDs {
+                    if let view = cohortByID[id] {
+                        return view
+                    }
+                }
+            }
+
+            return geometryWinner
         }
     }
 
diff --git a/macos/Sources/Features/Terminal/BaseTerminalController.swift b/macos/Sources/Features/Terminal/BaseTerminalController.swift
