+++ b/browser/components/astrohacker/components.conf
@@ -12,4 +12,13 @@ Classes = [
         "esModule": "resource:///modules/astrohacker/AstrohackerWindowlessProbe.sys.mjs",
         "constructor": "CommandLineHandler",
     },
+    {
+        "cid": "{a932e007-0932-4007-8000-000000000007}",
+        "contract_ids": ["@astrohacker.org/visible-window-clh;1"],
+        "categories": {
+            "command-line-handler": "l-astrohacker-visible",
+        },
+        "esModule": "resource:///modules/astrohacker/AstrohackerVisibleWindow.sys.mjs",
+        "constructor": "CommandLineHandler",
+    },
 ]
diff --git a/browser/components/astrohacker/moz.build b/browser/components/astrohacker/moz.build
index 59f745ede9c6..9407e128e832 100644
--- a/browser/components/astrohacker/moz.build
+++ b/browser/components/astrohacker/moz.build
@@ -3,6 +3,7 @@
