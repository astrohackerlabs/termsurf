From 291e1c9e54791b70ca7c3631f85dc0f00a3d3474 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 11 Jul 2026 20:43:20 -0500
Subject: [PATCH 6/6] Bug Astrohacker 932: require real STATE_STOP for
 windowless probe

Complete load only on network+window STATE_STOP; log location changes
separately. Document HiddenFrame as createWindowlessBrowser wrapper.
---
 .../AstrohackerWindowlessProbe.sys.mjs        | 61 ++++++++++---------
 1 file changed, 32 insertions(+), 29 deletions(-)

diff --git a/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs b/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
index b671ab9d1bbb..b9e91df8292a 100644
--- a/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
+++ b/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
@@ -4,7 +4,9 @@
 
 /**
  * Private Astrohacker Exp4 probe: --astrohacker-windowless-probe=<url>
- * Uses HiddenFrame + remote <browser> (same pattern as HeadlessShell).
+ *
+ * Uses HiddenFrame (nsIAppShellService::createWindowlessBrowser under the
+ * hood) + remote <browser>, same product pattern as HeadlessShell.
  */
 
 import { HiddenFrame } from "resource://gre/modules/HiddenFrame.sys.mjs";
@@ -66,6 +68,10 @@ function resolveURI(url) {
   return Services.io.newURI(url);
 }
 
+/**
+ * Wait for real STATE_STOP (NETWORK + WINDOW) on a committed non-blank
+ * document. LOCATION_CHANGE is logged only; it does not complete the load.
+ */
 function loadContentWindow(browser, url) {
   let uri = resolveURI(url);
   const principal = Services.scriptSecurityManager.getSystemPrincipal();
@@ -74,6 +80,20 @@ function loadContentWindow(browser, url) {
     browser.loadURI(uri, loadURIOptions);
     let { webProgress } = browser;
     let settled = false;
+    let lastLocation = "";
+
+    let finish = loc => {
+      if (settled) {
+        return;
+      }
+      settled = true;
+      progressListeners.delete(progressListener);
+      try {
+        webProgress.removeProgressListener(progressListener);
+      } catch (e) {}
+      resolve(loc);
+    };
+
     let progressListener = {
       onLocationChange(progress, _request, location, flags) {
         if (!progress.isTopLevel) {
@@ -88,28 +108,18 @@ function loadContentWindow(browser, url) {
         ) {
           return;
         }
-        if (settled) {
-          return;
-        }
-        settled = true;
-        dump("STATE_STOP\n");
-        dump("load_complete=1\n");
-        dump(`location=${location.spec}\n`);
-        progressListeners.delete(progressListener);
-        try {
-          webProgress.removeProgressListener(progressListener);
-        } catch (e) {}
-        resolve(location.spec);
+        lastLocation = location.spec;
+        dump(`location_change=${location.spec}\n`);
       },
       onStateChange(progress, _request, stateFlags, _status) {
         if (!progress.isTopLevel) {
           return;
         }
-        const nsIWebProgressListener = Ci.nsIWebProgressListener;
+        const L = Ci.nsIWebProgressListener;
         if (
-          !(stateFlags & nsIWebProgressListener.STATE_STOP) ||
-          !(stateFlags & nsIWebProgressListener.STATE_IS_NETWORK) ||
-          !(stateFlags & nsIWebProgressListener.STATE_IS_WINDOW)
+          !(stateFlags & L.STATE_STOP) ||
+          !(stateFlags & L.STATE_IS_NETWORK) ||
+          !(stateFlags & L.STATE_IS_WINDOW)
         ) {
           return;
         }
@@ -119,25 +129,17 @@ function loadContentWindow(browser, url) {
         ) {
           return;
         }
-        let loc = "";
+        let loc = lastLocation;
         try {
-          loc = browser.currentURI?.spec || "";
+          loc = browser.currentURI?.spec || loc;
         } catch (e) {}
         if (!loc || loc === "about:blank") {
           return;
         }
-        if (settled) {
-          return;
-        }
-        settled = true;
         dump("STATE_STOP\n");
         dump("load_complete=1\n");
         dump(`location=${loc}\n`);
-        progressListeners.delete(progressListener);
-        try {
-          webProgress.removeProgressListener(progressListener);
-        } catch (e) {}
-        resolve(loc);
+        finish(loc);
       },
       QueryInterface: ChromeUtils.generateQI([
         "nsIWebProgressListener",
@@ -147,7 +149,7 @@ function loadContentWindow(browser, url) {
     progressListeners.add(progressListener);
     webProgress.addProgressListener(
       progressListener,
-      Ci.nsIWebProgress.NOTIFY_LOCATION | Ci.nsIWebProgress.NOTIFY_STATE_WINDOW
+      Ci.nsIWebProgress.NOTIFY_LOCATION | Ci.nsIWebProgress.NOTIFY_STATE_ALL
     );
     let timer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
     timer.initWithCallback(
@@ -170,6 +172,7 @@ function loadContentWindow(browser, url) {
 
 async function runProbe(urlStr) {
   dump("state=create_hidden_frame\n");
+  dump("windowless_api=HiddenFrame.createWindowlessBrowser\n");
   let frame = new HiddenFrame();
   let windowlessBrowser = await frame.get();
   dump("init_ok=1\n");
