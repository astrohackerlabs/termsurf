Subject: [PATCH 1/6] Bug Astrohacker 932: windowless probe CLI for Exp4

Add --astrohacker-windowless-probe=<url> command-line handler that
creates a windowless browser, loads the URL, dumps markers, and quits.
---
 .../AstrohackerWindowlessProbe.sys.mjs        | 150 ++++++++++++++++++
 .../components/astrohacker/components.conf    |  15 ++
 browser/components/astrohacker/moz.build      |  11 ++
 browser/components/moz.build                  |   1 +
 4 files changed, 177 insertions(+)
 create mode 100644 browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
 create mode 100644 browser/components/astrohacker/components.conf
 create mode 100644 browser/components/astrohacker/moz.build

diff --git a/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs b/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
new file mode 100644
index 000000000000..ed059a4d1837
--- /dev/null
+++ b/browser/components/astrohacker/AstrohackerWindowlessProbe.sys.mjs
@@ -0,0 +1,150 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/**
+ * Private Astrohacker Exp4 probe: --astrohacker-windowless-probe=<url>
+ * Creates a windowless browser, loads URL, dumps markers to stdout, quits.
+ */
+
+export class CommandLineHandler {
+  static classID = Components.ID("{a932e004-0932-4004-8000-000000000004}");
+  static contractID = "@astrohacker.org/windowless-probe-clh;1";
+
+  QueryInterface = ChromeUtils.generateQI([Ci.nsICommandLineHandler]);
+
+  get helpInfo() {
+    return "  --astrohacker-windowless-probe <url>  Astrohacker windowless load probe\n";
+  }
+
+  handle(aCmdLine) {
+    let urlParam = aCmdLine.handleFlagWithParam(
+      "astrohacker-windowless-probe",
+      false
+    );
+    if (!urlParam) {
+      return;
+    }
+
+    aCmdLine.preventDefault = true;
+    dump("init_ok=1\n");
+    dump("main_thread=1\n");
+    dump("flag=--astrohacker-windowless-probe\n");
+    dump("profile_probe_start=1\n");
+
+    Services.startup.enterLastWindowClosingSurvivalArea();
+    runWindowlessProbe(urlParam)
+      .catch(err => {
+        dump(`probe_error=${err}\n`);
+        dump("windowless_load_ok=0\n");
+      })
+      .finally(() => {
+        try {
+          Services.startup.exitLastWindowClosingSurvivalArea();
+        } catch (e) {}
+        Services.startup.quit(Ci.nsIAppStartup.eForceQuit);
+      });
+  }
+}
+
+async function runWindowlessProbe(urlStr) {
+  dump("state=create_windowless\n");
+  let wl = Services.appShell.createWindowlessBrowser(/* isChrome */ false);
+  let docShell = wl.docShell;
+  let webNav = docShell.QueryInterface(Ci.nsIWebNavigation);
+  let webProgress = docShell
+    .QueryInterface(Ci.nsIInterfaceRequestor)
+    .getInterface(Ci.nsIWebProgress);
+
+  let loadDone = new Promise(resolve => {
+    let listener = {
+      QueryInterface: ChromeUtils.generateQI([
+        Ci.nsIWebProgressListener,
+        Ci.nsISupportsWeakReference,
+      ]),
+      onStateChange(aWebProgress, _aRequest, aStateFlags, _aStatus) {
+        const L = Ci.nsIWebProgressListener;
+        if (!(aStateFlags & L.STATE_STOP)) {
+          return;
+        }
+        if (!(aStateFlags & L.STATE_IS_NETWORK)) {
+          return;
+        }
+        if (!aWebProgress.isTopLevel) {
+          return;
+        }
+        dump("STATE_STOP\n");
+        dump("load_complete=1\n");
+        try {
+          webProgress.removeProgressListener(listener);
+        } catch (e) {}
+        resolve();
+      },
+      onLocationChange() {},
+      onProgressChange() {},
+      onStatusChange() {},
+      onSecurityChange() {},
+      onContentBlockingEvent() {},
+    };
+    webProgress.addProgressListener(
+      listener,
+      Ci.nsIWebProgress.NOTIFY_STATE_NETWORK
+    );
+  });
+
+  let uri = Services.io.newURI(urlStr);
+  dump(`load_uri=${uri.spec}\n`);
+  let loadURIOptions = {
+    triggeringPrincipal:
+      Services.scriptSecurityManager.getSystemPrincipal(),
+  };
+  webNav.loadURI(uri, loadURIOptions);
+
+  // Bound wait 60s
+  let timedOut = false;
+  let timer = new Promise(resolve => {
+    // eslint-disable-next-line mozilla/no-arbitrary-setTimeout
+    setTimeout(() => {
+      timedOut = true;
+      resolve();
+    }, 60000);
+  });
+  await Promise.race([loadDone, timer]);
+  if (timedOut) {
+    dump("timeout=1\n");
+    dump("windowless_load_ok=0\n");
+    try {
+      wl.close();
+    } catch (e) {}
+    return;
+  }
+
+  let finalUri = webNav.currentURI ? webNav.currentURI.spec : "";
+  dump(`final_uri=${finalUri}\n`);
+  let title = "";
+  try {
+    title = wl.document?.title || "";
+  } catch (e) {
+    title = "";
+  }
+  dump(`title=${title}\n`);
+  if (title.includes("EXP3_FIXTURE_OK") || title === "EXP3_FIXTURE_OK") {
+    dump("EXP3_FIXTURE_OK\n");
+    dump("fixture_marker=1\n");
+  } else {
+    dump("fixture_marker=0\n");
+  }
+
+  try {
+    wl.close();
+  } catch (e) {}
+  dump("teardown_ok=1\n");
+  if (
+    finalUri &&
+    (title.includes("EXP3_FIXTURE_OK") || title === "EXP3_FIXTURE_OK")
+  ) {
+    dump("windowless_load_ok=1\n");
+  } else {
+    dump("windowless_load_ok=0\n");
+  }
+}
