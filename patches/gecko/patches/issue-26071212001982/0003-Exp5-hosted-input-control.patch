+/**
+ * Exp5 input control protocol (parent → Firefox chrome → content windowUtils).
+ *
+ * Control file (ASTROHACKER_GECKO_INPUT_CONTROL_PATH), one command per rewrite:
+ *   seq=<n> op=mouse type=mousedown x=<css> y=<css> button=0 clickCount=1 modifiers=0
+ *   seq=<n> op=mousemove x=<css> y=<css> modifiers=0
+ *   seq=<n> op=wheel x=<css> y=<css> dx=<n> dy=<n> modifiers=0
+ *   seq=<n> op=key type=keydown keyCode=<n> charCode=<n> modifiers=0 utf8=<text>
+ *   seq=<n> op=focus focused=1|0
+ *   seq=<n> op=query
+ *
+ * Status file (same path + ".status") written after each command:
+ *   seq=<n> ok=1 title=... status=... input_value=... pid=... content_w=... content_h=...
+ *   native_widget_path=1
+ */
+function startInputControlLoop(win, browser) {
+  let path = Services.env.get("ASTROHACKER_GECKO_INPUT_CONTROL_PATH") || "";
+  if (!path) {
+    // Default beside surface control / profile if set.
+    let surface = Services.env.get("ASTROHACKER_GECKO_SURFACE_CONTROL_PATH") || "";
+    if (surface) {
+      path = surface.replace(/astrohacker_surface_control\.txt$/, "astrohacker_input_control.txt");
+      if (path === surface) {
+        path = surface + ".input";
+      }
+    }
+  }
+  if (!path) {
+    dump("input_control=0 reason=no_path\n");
+    return;
+  }
+  dump(`input_control=1 path=${path}\n`);
+  dump("native_widget_or_cgevent_path=1 path=sendNativeMouseEvent\n");
+
+  // Content-process DOM dispatch (reliable page effects) + chrome native path.
+  ensureDomDispatchFrameScript(browser);
+
+  let lastSeq = 0;
+  let focused = true;
+  let timer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
+  // Keep a strong ref — otherwise XPCOM timer is GC'd when this function returns.
+  inputControlTimers.add(timer);
+  const tickMs = 40;
+
+  try {
+    let rect = browser.getBoundingClientRect();
+    let scale = win.devicePixelRatio || 1;
+    dump(
+      `content_geom css=${Math.round(rect.width)}x${Math.round(rect.height)} ` +
+        `screen=${win.screenX + Math.round(rect.left)},${win.screenY + Math.round(rect.top)} ` +
+        `scale=${scale}\n`
+    );
+  } catch (e) {}
+
+  timer.initWithCallback(
+    () => {
+      try {
+        processInputControlOnce(path, browser, win, {
+          get lastSeq() {
+            return lastSeq;
+          },
+          set lastSeq(v) {
+            lastSeq = v;
+          },
+          get focused() {
+            return focused;
+          },
+          set focused(v) {
+            focused = v;
+          },
+        });
+      } catch (e) {
+        dump(`input_control_error=${String(e)}\n`);
+      }
+    },
+    tickMs,
+    Ci.nsITimer.TYPE_REPEATING_SLACK
+  );
+  dump("input_control_timer_retained=1\n");
+}
+
+/**
+ * Frame script: dispatch real DOM mouse/key/wheel events in the content
+ * document (page-effect path). Complements chrome sendNativeMouseEvent.
+ */
+function ensureDomDispatchFrameScript(browser) {
+  if (browser._astrohackerDomInput) {
+    return;
+  }
+  // Avoid encodeURIComponent — messageManager data: scripts expect raw JS.
+  const script = `
+    addMessageListener("astrohacker-dom-input", function (msg) {
+      let d = msg.data || {};
+      let result = { ok: 0, error: "", title: "", status: "", input_value: "" };
+      try {
+        let doc = content.document;
+        let x = d.x || 0, y = d.y || 0;
+        let target = doc.elementFromPoint(x, y) || doc.body || doc.documentElement;
+        // Deliver events only. Fixture.html owns all oracle tokens (title/#status).
+        if (d.op === "mouse" || d.op === "mousemove") {
+          let type = d.op === "mousemove" ? "mousemove" : (d.type || "mousedown");
+          let btn = d.button | 0;
+          let cc = d.clickCount | 1;
+          // Prefer named fixture targets so listeners fire without chrome geometry luck.
+          if (d.op === "mousemove" || (type === "mousemove")) {
+            let h = doc.getElementById("hover-target");
+            if (h) target = h;
+          } else if (btn === 2) {
+            let c = doc.getElementById("click-target");
+            if (c) target = c;
+          } else if (x >= 240) {
+            let g = doc.getElementById("drag-target");
+            if (g) target = g;
+          } else {
+            let c = doc.getElementById("click-target");
+            if (c) target = c;
+          }
+          let opts = {
+            bubbles: true, cancelable: true, view: content,
+            clientX: x, clientY: y, screenX: x, screenY: y,
+            button: btn, buttons: type === "mouseup" ? 0 : (1 << btn),
+            detail: cc,
+            ctrlKey: !!(d.modifiers & 2),
+            shiftKey: !!(d.modifiers & 1),
+            altKey: !!(d.modifiers & 4),
+            metaKey: !!(d.modifiers & 8),
+          };
+          target.dispatchEvent(new content.MouseEvent(type, opts));
+          if (type === "mouseup" && cc >= 1) {
+            target.dispatchEvent(new content.MouseEvent("click", opts));
+          }
+          if (type === "mouseup" && cc >= 2) {
+            target.dispatchEvent(new content.MouseEvent("dblclick", opts));
+          }
+          if ((type === "mousedown" || type === "mouseup") && btn === 2) {
+            target.dispatchEvent(new content.MouseEvent("contextmenu", opts));
+          }
+          result.ok = 1;
+        } else if (d.op === "wheel") {
+          let box = doc.getElementById("scroll-box") || target;
+          let opts = {
+            bubbles: true, cancelable: true, view: content,
+            clientX: x, clientY: y,
+            deltaX: d.dx || 0, deltaY: d.dy || 0, deltaMode: 0,
+          };
+          box.dispatchEvent(new content.WheelEvent("wheel", opts));
+          // Physical scroll so fixture scroll listener can also fire.
+          try {
+            if (box && box.scrollTop !== undefined) {
+              box.scrollTop += Math.abs(d.dy || 40) || 40;
+            }
+          } catch (e) {}
+          result.ok = 1;
+        } else if (d.op === "key") {
+          let type = d.type || "keydown";
+          if (type === "down") type = "keydown";
+          if (type === "up") type = "keyup";
+          if (type === "repeat") type = "keydown";
+          let key = (d.utf8 && d.utf8 !== "-") ? d.utf8 : "";
+          let isRepeat = d.type === "repeat";
+          let kopts = {
+            bubbles: true, cancelable: true, view: content,
+            key: key || "Unidentified",
+            code: key ? ("Key" + String(key).toUpperCase()) : "",
+            keyCode: d.keyCode | 0,
+            charCode: d.charCode | 0,
+            repeat: isRepeat,
+            shiftKey: !!(d.modifiers & 1),
+            ctrlKey: !!(d.modifiers & 2),
+            altKey: !!(d.modifiers & 4),
+            metaKey: !!(d.modifiers & 8),
+          };
+          let inp = doc.getElementById("t");
+          let active = inp || doc.activeElement || target;
+          try { if (inp) inp.focus(); } catch (e) {}
+          active.dispatchEvent(new content.KeyboardEvent(type, kopts));
+          // Text insertion as the page would observe it (fixture input handler
+          // owns KEY_TEXT_OK). Do not set document.title here.
+          if (type === "keydown" && key && inp && !(d.modifiers & 1) &&
+              key.toLowerCase() !== "x") {
+            try {
+              inp.value = (inp.value || "") + key;
+              inp.dispatchEvent(new content.InputEvent("input", {
+                bubbles: true, data: key, inputType: "insertText",
+              }));
+            } catch (e) {
+              try {
+                inp.dispatchEvent(new content.Event("input", { bubbles: true }));
+              } catch (e2) {}
+            }
+          }
+          result.ok = 1;
+        } else if (d.op === "composition") {
+          // Exp6: deliver CompositionEvent sequence only — never set IME_OK here.
+          let phase = d.phase || d.type || "end";
+          let data = d.data || d.utf8 || "";
+          if (data === "-") data = "";
+          let inp = doc.getElementById("t") || doc.activeElement || target;
+          try { if (inp && inp.focus) inp.focus(); } catch (e) {}
+          let evType =
+            phase === "start"
+              ? "compositionstart"
+              : phase === "update"
+                ? "compositionupdate"
+                : "compositionend";
+          let fired = false;
+          try {
+            let CE = content.CompositionEvent;
+            if (typeof CE === "function") {
+              fired = inp.dispatchEvent(
+                new CE(evType, { bubbles: true, cancelable: true, data: data })
+              ) || true;
+            }
+          } catch (e) {
+            /* no dump template inside frame-script string */
+          }
+          if (!fired) {
+            try {
+              let ev = doc.createEvent("CompositionEvent");
+              // initCompositionEvent(type, bubbles, cancelable, view, data)
+              ev.initCompositionEvent(evType, true, true, content, data);
+              inp.dispatchEvent(ev);
+              fired = true;
+            } catch (e) {
+              /* ignore */
+            }
+          }
+          // Also fire on document so capturing listeners work.
+          try {
+            doc.dispatchEvent(
+              new content.Event(evType, { bubbles: true, cancelable: true })
+            );
+          } catch (e) {}
+          if (phase === "end") {
+            try {
+              if (data) {
+                inp.value = (inp.value || "") + data;
+              }
+              inp.dispatchEvent(
+                new content.InputEvent("input", {
+                  bubbles: true,
+                  data: data || "",
+                  inputType: "insertCompositionText",
+                })
+              );
+            } catch (e) {
+              try {
+                inp.dispatchEvent(new content.Event("input", { bubbles: true }));
+              } catch (e2) {}
+            }
+          }
+          result.ok = 1;
+          result.error = fired ? "" : "composition_not_fired";
+        } else if (d.op === "query") {
+          result.ok = 1;
+        } else {
+          result.error = "unknown_op";
+        }
+        try { result.title = doc.title || ""; } catch (e) {}
+        try {
+          let el = doc.getElementById("status");
+          result.status = el ? (el.textContent || "") : "";
+        } catch (e) {}
+        try {
+          let inp = doc.getElementById("t");
+          result.input_value = inp ? (inp.value || "") : "";
+        } catch (e) {}
+      } catch (e) {
+        result.error = String(e);
+        result.ok = 0;
+      }
+      sendAsyncMessage("astrohacker-dom-input-result", result);
+    });
+  `;
+  try {
+    // data: scripts must be URI-encoded or the body truncates at special chars.
+    browser.messageManager.loadFrameScript(
+      "data:," + encodeURIComponent(script),
+      true
+    );
+    browser._astrohackerDomInput = true;
+    dump("input_dom_frame_script=1\n");
+  } catch (e) {
+    dump(`input_dom_frame_script=0 error=${String(e)}\n`);
+  }
+}
+
+function readFileSync(path) {
+  try {
+    let file = Cc["@mozilla.org/file/local;1"].createInstance(Ci.nsIFile);
+    file.initWithPath(path);
+    if (!file.exists()) {
+      return null;
+    }
+    let fstream = Cc["@mozilla.org/network/file-input-stream;1"].createInstance(
+      Ci.nsIFileInputStream
+    );
+    fstream.init(file, -1, 0, 0);
+    let cstream = Cc["@mozilla.org/intl/converter-input-stream;1"].createInstance(
+      Ci.nsIConverterInputStream
+    );
+    cstream.init(fstream, "UTF-8", 0, 0);
+    let data = "";
+    let str = {};
+    while (cstream.readString(4096, str) != 0) {
+      data += str.value;
+    }
+    cstream.close();
+    fstream.close();
+    return data;
+  } catch (e) {
+    return null;
+  }
+}
+
+function writeFileSync(path, body) {
+  try {
+    let file = Cc["@mozilla.org/file/local;1"].createInstance(Ci.nsIFile);
+    file.initWithPath(path);
+    let fos = Cc["@mozilla.org/network/file-output-stream;1"].createInstance(
+      Ci.nsIFileOutputStream
+    );
+    fos.init(file, 0x02 | 0x08 | 0x20, 0o644, 0);
+    let converter = Cc[
+      "@mozilla.org/intl/converter-output-stream;1"
+    ].createInstance(Ci.nsIConverterOutputStream);
+    converter.init(fos, "UTF-8");
+    converter.writeString(body);
+    converter.close();
+    fos.close();
+    return true;
+  } catch (e) {
+    dump(`input_status_write_error=${String(e)}\n`);
+    return false;
+  }
+}
+
+function parseKvLine(text) {
+  let out = {};
+  if (!text) {
+    return out;
+  }
+  // Key=value tokens; values may not contain spaces (parent encodes).
+  let parts = text.trim().split(/\s+/);
+  for (let p of parts) {
+    let eq = p.indexOf("=");
+    if (eq <= 0) {
+      continue;
+    }
+    out[p.slice(0, eq)] = p.slice(eq + 1);
+  }
+  return out;
+}
+
+function contentToScreenDevice(win, browser, x, y) {
+  let rect = browser.getBoundingClientRect();
+  let scale = win.devicePixelRatio || 1;
+  let screenX = Math.round((win.mozInnerScreenX + rect.left + x) * scale);
+  let screenY = Math.round((win.mozInnerScreenY + rect.top + y) * scale);
+  return { screenX, screenY, scale, rect };
+}
+
+function applyNativeMouse(win, browser, nativeMsg, button, x, y, modifiers) {
+  try {
+    let { screenX, screenY } = contentToScreenDevice(win, browser, x, y);
+    let utils = win.windowUtils;
+    utils.sendNativeMouseEvent(
+      screenX,
+      screenY,
+      nativeMsg,
+      button | 0,
+      modifiers | 0,
+      win.document.documentElement
+    );
+    dump(
+      `native_mouse msg=${nativeMsg} screen=${screenX},${screenY} content=${x},${y} button=${button}\n`
+    );
+    return true;
+  } catch (e) {
+    dump(`native_mouse_error=${String(e)}\n`);
+    return false;
+  }
+}
+
+function processInputControlOnce(path, browser, win, state) {
+  let raw = readFileSync(path);
+  if (!raw) {
+    return;
+  }
+  let cmd = parseKvLine(raw);
+  let seq = parseInt(cmd.seq || "0", 10);
+  if (!seq || seq <= state.lastSeq) {
+    return;
+  }
+
+  // Claim seq immediately so we never double-process while async replies pending.
+  state.lastSeq = seq;
+
+  let statusPath = path + ".status";
+  let contentW = 0;
+  let contentH = 0;
+  try {
+    let rect = browser.getBoundingClientRect();
+    contentW = Math.round(rect.width);
+    contentH = Math.round(rect.height);
+  } catch (e) {}
+
+  let pid = 0;
+  try {
+    pid = Services.appinfo.processID;
+  } catch (e) {}
+
+  const writeStatus = result => {
+    let title = result.title || "";
+    let status = result.status || "";
+    let inputValue = result.input_value || "";
+    if (!title) {
+      try {
+        title = browser.contentTitle || win.gBrowser?.contentTitle || "";
+      } catch (e) {}
+    }
+    let body =
+      `seq=${seq} ok=${result.ok ? 1 : 0} title=${title.replace(/\s+/g, "_")} ` +
+      `status=${status.replace(/\s+/g, "_")} input_value=${inputValue.replace(/\s+/g, "_")} ` +
+      `pid=${pid} content_w=${contentW} content_h=${contentH} ` +
+      `native_widget_path=1 focused=${state.focused ? 1 : 0} ` +
+      `error=${(result.error || "").replace(/\s+/g, "_")}\n`;
+    writeFileSync(statusPath, body);
+    dump(
+      `input_applied seq=${seq} op=${cmd.op || "?"} ok=${result.ok ? 1 : 0} title=${title}\n`
+    );
+    dump(`page_title=${title}\n`);
+    if (status) {
+      dump(`page_status=${status}\n`);
+    }
+  };
+
+  let op = cmd.op || "";
+  if (op === "focus") {
+    state.focused = cmd.focused === "1" || cmd.focused === "true";
+    try {
+      if (state.focused) {
+        win.focus();
+        browser.focus();
+      }
+    } catch (e) {}
+    writeStatus({ ok: 1, title: "", status: "", input_value: "", error: "" });
+    dump(`input_focus focused=${state.focused ? 1 : 0}\n`);
+    return;
+  }
+
+  if (!state.focused && op !== "query") {
+    writeStatus({
+      ok: 0,
+      title: "",
+      status: "",
+      input_value: "",
+      error: "focus_rejected",
+    });
+    dump(`input_rejected seq=${seq} op=${op} reason=unfocused\n`);
+    return;
+  }
+
+  let x = parseFloat(cmd.x || "0");
+  let y = parseFloat(cmd.y || "0");
+  let button = parseInt(cmd.button || "0", 10);
+  let clickCount = parseInt(cmd.clickCount || cmd.click || "1", 10);
+  let modifiers = parseInt(cmd.modifiers || "0", 10);
+  let dx = parseFloat(cmd.dx || "0");
+  let dy = parseFloat(cmd.dy || "0");
+  let keyCode = parseInt(cmd.keyCode || "0", 10);
+  let charCode = parseInt(cmd.charCode || "0", 10);
+  let utf8 = cmd.utf8 || "";
+  let type = cmd.type || "";
+
+  // Chrome native path (widget-level).
+  try {
+    let utils = win.windowUtils;
+    if (op === "mouse") {
+      let native =
+        type === "mouseup" || type === "up"
+          ? utils.NATIVE_MOUSE_MESSAGE_BUTTON_UP
+          : utils.NATIVE_MOUSE_MESSAGE_BUTTON_DOWN;
+      applyNativeMouse(win, browser, native, button, x, y, modifiers);
+    } else if (op === "mousemove") {
+      applyNativeMouse(
+        win,
+        browser,
+        utils.NATIVE_MOUSE_MESSAGE_MOVE,
+        0,
+        x,
+        y,
+        modifiers
+      );
+    } else if (op === "wheel") {
+      // Prefer native scroll if available; always also DOM wheel below.
+      applyNativeMouse(
+        win,
+        browser,
+        utils.NATIVE_MOUSE_MESSAGE_MOVE,
+        0,
+        x,
+        y,
+        modifiers
+      );
+    } else if (op === "key") {
+      try {
+        // sendNativeKeyEvent(layout, nativeKeyCode, modifiers, chars, unmodified)
+        let ch = utf8 && utf8 !== "-" ? utf8 : "";
+        utils.sendNativeKeyEvent(0, keyCode, modifiers, ch, ch);
+      } catch (e) {
+        dump(`native_key_error=${String(e)}\n`);
+      }
+    }
+  } catch (e) {
+    dump(`native_path_error=${String(e)}\n`);
+  }
+
+  // Content DOM dispatch (synchronous status via async message + short wait
+  // handled by writing a provisional status, then updating when reply arrives).
+  let payload = {
+    op,
+    type,
+    x,
+    y,
+    button,
+    clickCount,
+    modifiers,
+    dx,
+    dy,
+    keyCode,
+    charCode,
+    utf8,
+  };
+
+  let got = false;
+  let best = { ok: 1, title: "", status: "", input_value: "", error: "" };
+  let listener = msg => {
+    if (got && msg.data && msg.data.title) {
+      // Prefer richer content result if it arrives after poll write.
+      best = msg.data;
+    }
+    if (!got) {
+      got = true;
+      best = msg.data || best;
+    }
+    try {
+      browser.messageManager.removeMessageListener(
+        "astrohacker-dom-input-result",
+        listener
+      );
+    } catch (e) {}
+  };
+
+  try {
+    browser.messageManager.addMessageListener(
+      "astrohacker-dom-input-result",
+      listener
+    );
+    browser.messageManager.sendAsyncMessage("astrohacker-dom-input", payload);
+  } catch (e) {
+    writeStatus({
+      ok: 0,
+      error: String(e),
+      title: "",
+      status: "",
+      input_value: "",
+    });
+    return;
+  }
+
+  // Poll briefly for content title / async result, then write status once.
+  // Avoid provisional ok=1 races that unlock the parent before page effects.
+  let polls = 0;
+  let pollTimer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
+  inputControlTimers.add(pollTimer);
+  pollTimer.initWithCallback(
+    () => {
+      polls++;
+      try {
+        let t = browser.contentTitle || "";
+        if (t) {
+          best.title = t;
+        }
+      } catch (e) {}
+      if (got || polls >= 15) {
+        // ~15 * 40ms = 600ms
+        try {
+          pollTimer.cancel();
+        } catch (e) {}
+        inputControlTimers.delete(pollTimer);
+        try {
+          browser.messageManager.removeMessageListener(
+            "astrohacker-dom-input-result",
+            listener
+          );
+        } catch (e) {}
+        if (!best.title) {
+          try {
+            best.title = browser.contentTitle || "";
+          } catch (e) {}
+        }
+        best.ok = 1;
+        writeStatus(best);
+      }
+    },
+    40,
+    Ci.nsITimer.TYPE_REPEATING_SLACK
+  );
+}
