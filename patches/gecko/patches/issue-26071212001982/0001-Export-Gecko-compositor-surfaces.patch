From a84ffb1e8199faec6db1719ff11cdfea591f39ba Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sun, 12 Jul 2026 17:36:28 -0500
Subject: [PATCH] Export Gecko compositor surfaces
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

WebRender panes cross Mach’s bright stream,
Acknowledgements guard each borrowed gleam.
No screenshot cart, no pixel toll—
Measured rights return the whole.
---
 .../AstrohackerVisibleWindow.sys.mjs          |  72 ++-
 gfx/layers/AstrohackerSurfaceExporterMac.h    |  27 ++
 gfx/layers/AstrohackerSurfaceExporterMac.mm   | 419 ++++++++++++++++++
 gfx/layers/NativeLayerCA.h                    |   1 +
 gfx/layers/NativeLayerCA.mm                   |   5 +
 gfx/layers/NativeLayerRootRemoteMacParent.mm  |   9 +
 gfx/layers/moz.build                          |   2 +
 7 files changed, 531 insertions(+), 4 deletions(-)
 create mode 100644 gfx/layers/AstrohackerSurfaceExporterMac.h
 create mode 100644 gfx/layers/AstrohackerSurfaceExporterMac.mm

diff --git a/browser/components/astrohacker/AstrohackerVisibleWindow.sys.mjs b/browser/components/astrohacker/AstrohackerVisibleWindow.sys.mjs
index a2bf55fcdf3a..08b4010d60fc 100644
--- a/browser/components/astrohacker/AstrohackerVisibleWindow.sys.mjs
+++ b/browser/components/astrohacker/AstrohackerVisibleWindow.sys.mjs
@@ -10,6 +10,7 @@
 import { BrowserWindowTracker } from "resource:///modules/BrowserWindowTracker.sys.mjs";
 
 const progressListeners = new Set();
+const delayTimers = new Set();
 
 export class CommandLineHandler {
   static classID = Components.ID("{a932e007-0932-4007-8000-000000000007}");
@@ -51,8 +52,7 @@ export class CommandLineHandler {
 
     // HOLD mode (Exp8): leave the normal event loop running after load so
     // the parent can AX-resize the window; do not force-quit.
-    let hold =
-      Services.env.get("ASTROHACKER_GECKO_HOLD") === "1" && !headless;
+    let hold = Services.env.get("ASTROHACKER_GECKO_HOLD") === "1" && !headless;
 
     runVisible(urlParam, headless, hold)
       .catch(err => {
@@ -80,7 +80,15 @@ export class CommandLineHandler {
 function delay(ms) {
   return new Promise(resolve => {
     let timer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
-    timer.initWithCallback(() => resolve(), ms, Ci.nsITimer.TYPE_ONE_SHOT);
+    delayTimers.add(timer);
+    timer.initWithCallback(
+      () => {
+        delayTimers.delete(timer);
+        resolve();
+      },
+      ms,
+      Ci.nsITimer.TYPE_ONE_SHOT
