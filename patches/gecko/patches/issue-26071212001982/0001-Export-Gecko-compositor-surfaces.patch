   });
 }
 
@@ -213,6 +221,23 @@ async function runVisible(urlStr, headless, hold) {
     return;
   }
 
+  if (Services.env.get("ASTROHACKER_GECKO_SURFACE_PROBE") === "1") {
+    const scale = win.devicePixelRatio || 1;
+    const initialRect = browser.getBoundingClientRect();
+    Services.env.set(
+      "ASTROHACKER_GECKO_SURFACE_EXPECTED_WIDTH",
+      String(Math.round(initialRect.width * scale))
+    );
+    Services.env.set(
+      "ASTROHACKER_GECKO_SURFACE_EXPECTED_HEIGHT",
+      String(Math.round(initialRect.height * scale))
+    );
+    Services.env.set("ASTROHACKER_GECKO_SURFACE_RESIZE_EPOCH", "1");
+    dump(
+      `surface_probe_expected_initial=${Math.round(initialRect.width * scale)}x${Math.round(initialRect.height * scale)} scale=${scale}\n`
+    );
+  }
+
   let finalUri;
   try {
     // If openWindow already navigated, wait for stop; else load
@@ -266,12 +291,51 @@ async function runVisible(urlStr, headless, hold) {
   }
 
   let outerOk = (win.outerWidth | 0) >= 100 && (win.outerHeight | 0) >= 100;
-  if (!headless && marker && outerOk && finalUri && finalUri !== "about:blank") {
+  if (
+    !headless &&
+    marker &&
+    outerOk &&
+    finalUri &&
+    finalUri !== "about:blank"
+  ) {
     dump("visible_window_ok=1\n");
   } else {
     dump("visible_window_ok=0\n");
   }
 
+  if (Services.env.get("ASTROHACKER_GECKO_SURFACE_PROBE") === "1") {
+    await delay(900);
+    Services.env.set("ASTROHACKER_GECKO_SURFACE_RESIZE_EPOCH", "0");
+    win.resizeTo(400, 300);
+    await delay(700);
+    const principal = Services.scriptSecurityManager.getSystemPrincipal();
+    browser.loadURI(Services.io.newURI("about:blank"), {
+      triggeringPrincipal: principal,
+    });
+    await delay(300);
+    const resizedRect = browser.getBoundingClientRect();
+    const scale = win.devicePixelRatio || 1;
+    Services.env.set(
+      "ASTROHACKER_GECKO_SURFACE_EXPECTED_WIDTH",
+      String(Math.round(resizedRect.width * scale))
+    );
+    Services.env.set(
+      "ASTROHACKER_GECKO_SURFACE_EXPECTED_HEIGHT",
+      String(Math.round(resizedRect.height * scale))
+    );
+    Services.env.set("ASTROHACKER_GECKO_SURFACE_RESIZE_EPOCH", "2");
+    const resizedLoadDone = waitTabLoad(browser, urlStr);
+    browser.loadURI(Services.io.newURI(urlStr), {
+      triggeringPrincipal: principal,
+    });
+    await resizedLoadDone;
+    await delay(300);
+    dump(
+      `surface_probe_expected_resized=${Math.round(resizedRect.width * scale)}x${Math.round(resizedRect.height * scale)} scale=${scale}\n`
+    );
+    dump("surface_probe_resize=1\n");
+  }
+
   if (hold) {
     // Exp8: retain window; normal event loop continues (no nested busy loop).
     // Parent reaps via SIGTERM; do not claim teardown here.
diff --git a/gfx/layers/AstrohackerSurfaceExporterMac.h b/gfx/layers/AstrohackerSurfaceExporterMac.h
