+        utils.sendNativeKeyEvent(0, keyCode, modifiers, ch, ch);
+      } catch (e) {
+        dump(`native_key_error=${String(e)}\n`);
+      }
+    }
+  } catch (e) {
+    dump(`native_path_error=${String(e)}\n`);
+  }
+
+  // Content DOM dispatch (synchronous status via async message + short wait
+  // handled by writing a provisional status, then updating when reply arrives).
+  let payload = {
+    op,
+    type,
+    phase,
+    data,
+    start,
+    end,
+    expect,
+    x,
+    y,
+    button,
+    clickCount,
+    modifiers,
+    dx,
+    dy,
+    keyCode,
+    charCode,
+    utf8,
+  };
+
+  let got = false;
+  let best = { ok: 1, title: "", status: "", input_value: "", error: "" };
+  let listener = msg => {
+    if (got && msg.data && msg.data.title) {
+      // Prefer richer content result if it arrives after poll write.
+      best = msg.data;
+    }
+    if (!got) {
+      got = true;
+      best = msg.data || best;
+    }
+    try {
+      browser.messageManager.removeMessageListener(
+        "astrohacker-dom-input-result",
+        listener
+      );
+    } catch (e) {}
+  };
+
+  try {
+    browser.messageManager.addMessageListener(
+      "astrohacker-dom-input-result",
+      listener
+    );
+    browser.messageManager.sendAsyncMessage("astrohacker-dom-input", payload);
+  } catch (e) {
+    writeStatus({
+      ok: 0,
+      error: String(e),
+      title: "",
+      status: "",
+      input_value: "",
+    });
+    return;
+  }
+
+  // Poll briefly for content title / async result, then write status once.
+  // Avoid provisional ok=1 races that unlock the parent before page effects.
+  let polls = 0;
+  let pollTimer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
+  inputControlTimers.add(pollTimer);
+  pollTimer.initWithCallback(
+    () => {
+      polls++;
+      try {
+        let t = browser.contentTitle || "";
+        if (t) {
+          best.title = t;
+        }
+      } catch (e) {}
+      if (got || polls >= 15) {
+        // ~15 * 40ms = 600ms
+        try {
+          pollTimer.cancel();
+        } catch (e) {}
+        inputControlTimers.delete(pollTimer);
+        try {
+          browser.messageManager.removeMessageListener(
+            "astrohacker-dom-input-result",
+            listener
+          );
+        } catch (e) {}
+        if (!best.title) {
+          try {
+            best.title = browser.contentTitle || "";
+          } catch (e) {}
+        }
+        if (!got) {
+          best.error = (best.error || "") + "no_frame_reply";
+        } else if (!best.error) {
+          best.error = "got_frame";
+        }
+        best.ok = 1;
+        writeStatus(best);
+      }
+    },
+    40,
+    Ci.nsITimer.TYPE_REPEATING_SLACK
+  );
+}
