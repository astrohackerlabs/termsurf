+NS_IMETHODIMP
+BrowserHost::AstrohackerSetInputActive(bool aActive) {
+  if (!mRoot) {
+    return NS_OK;
+  }
+  const uint64_t actionId = nsFocusManager::GenerateFocusActionId();
+  if (aActive) {
+    mRoot->Activate(actionId);
+  } else {
+    mRoot->Deactivate(false, actionId);
+  }
+  return NS_OK;
