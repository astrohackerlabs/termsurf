+function ensureGenericTextInputScript(browser) {
+  if (browser._astrohackerTextInput) {
+    return;
+  }
+  const script = `
+    var ahTextInputProcessor = null;
+    addMessageListener("astrohacker-text-input", async function(msg) {
+      var d = msg.data || {};
+      var result = { ok: 0, error: "", title: "", status: "", input_value: "" };
+      try {
+        var wu = content.windowUtils;
+        function validRange(start, length, label) {
+          start = Number(start);
+          length = Number(length);
+          if (start === -1 && length === -1) return null;
+          if (!Number.isSafeInteger(start) || !Number.isSafeInteger(length) || start < 0 || length < 0)
+            throw new Error("invalid_" + label + "_range");
+          return [start, length];
+        }
+        async function applyReplacementRange() {
+          var range = validRange(d.replacement_start, d.replacement_length, "replacement");
+          if (!range) return;
+          if (!wu || typeof wu.sendSelectionSetEvent !== "function")
+            throw new Error("no_selection_set_event");
+          var focusManager = Cc["@mozilla.org/focus-manager;1"].getService(Ci.nsIFocusManager);
+          var editor = focusManager.focusedElement || content.document.activeElement || content.document.querySelector("[autofocus]");
+          if (!editor || typeof editor.selectionStart !== "number" || typeof editor.value !== "string")
+            throw new Error("no_focused_text_editor");
+          if (range[0] + range[1] > editor.value.length)
+            throw new Error("replacement_range_out_of_bounds");
+          var nativeContent = wu.sendQueryContentEvent(wu.QUERY_TEXT_CONTENT, 0, 0x7fffffff, 0, 0);
+          if (!nativeContent || !nativeContent.succeeded || typeof nativeContent.text !== "string")
+            throw new Error("query_text_content_failed");
+          var editorBase = nativeContent.text.indexOf(editor.value);
+          if (editorBase < 0 || nativeContent.text.indexOf(editor.value, editorBase + 1) >= 0)
+            throw new Error("ambiguous_editor_base");
+          await new Promise(resolve => content.requestAnimationFrame(() => content.requestAnimationFrame(resolve)));
+          if (!wu.sendSelectionSetEvent(editorBase + range[0], range[1], wu.SELECTION_SET_FLAG_USE_XP_LINE_BREAK))
+            throw new Error("replacement_range_rejected");
+          if (editor.selectionStart !== range[0] || editor.selectionEnd !== range[0] + range[1])
+            throw new Error("replacement_selection_not_applied_base_" + editorBase + "_actual_" + editor.selectionStart + "_" + editor.selectionEnd);
+        }
+        function getTIP() {
+          if (ahTextInputProcessor) return ahTextInputProcessor;
+          var tip = Cc["@mozilla.org/text-input-processor;1"].createInstance(Ci.nsITextInputProcessor);
+          if (!tip.beginInputTransactionForTests(content, null))
+            throw new Error("tip_transaction_rejected");
+          ahTextInputProcessor = tip;
+          return tip;
+        }
+        function setPendingComposition(tip, text) {
+          var selected = validRange(d.selected_start, d.selected_length, "selected");
+          tip.setPendingCompositionString(text);
+          if (!selected) {
+            if (text.length) tip.appendClauseToPendingComposition(text.length, tip.ATTR_RAW_CLAUSE);
+            return;
+          }
+          var start = selected[0], length = selected[1], end = start + length;
+          if (end > text.length) throw new Error("selected_range_out_of_bounds");
+          if (start) tip.appendClauseToPendingComposition(start, tip.ATTR_RAW_CLAUSE);
+          if (length) tip.appendClauseToPendingComposition(length, tip.ATTR_SELECTED_RAW_CLAUSE);
+          if (end < text.length) tip.appendClauseToPendingComposition(text.length - end, tip.ATTR_RAW_CLAUSE);
+          tip.setCaretInPendingComposition(end);
+        }
+        if (d.op === "key") {
+          var raw = String(d.type || "");
+          if (raw !== "down" && raw !== "up" && raw !== "repeat")
+            throw new Error("unknown_key_type");
+          var code = Number(d.keyCode) || 0;
+          var names = {8:["Backspace","Backspace"],9:["Tab","Tab"],13:["Enter","Enter"],27:["Escape","Escape"],32:[" ","Space"],37:["ArrowLeft","ArrowLeft"],38:["ArrowUp","ArrowUp"],39:["ArrowRight","ArrowRight"],40:["ArrowDown","ArrowDown"],46:["Delete","Delete"]};
+          var pair = names[code] || [code >= 65 && code <= 90 ? String.fromCharCode(code + 32) : "Unidentified", code >= 65 && code <= 90 ? "Key" + String.fromCharCode(code) : ""];
+          var event = new content.KeyboardEvent("", { key: pair[0], code: pair[1], keyCode: code, repeat: raw === "repeat" });
+          var tip = getTIP();
+          if (raw === "up") tip.keyup(event, 0);
+          else tip.keydown(event, tip.KEY_DEFAULT_PREVENTED);
+          result.ok = 1;
+          result.error = "widget_key_" + raw;
+        } else if (d.op === "text_input") {
+          var text = String(d.text || "");
+          var utf8Bytes = new TextEncoder().encode(text).length;
+          var codePoints = Array.from(text).length;
+          if (utf8Bytes !== Number(d.text_utf8_bytes) || codePoints !== Number(d.text_code_points))
+            throw new Error("text_code_point_mismatch");
+          var kind = String(d.input_type || "");
+          var textTip = getTIP();
+          if (kind === "commit") {
+            var commitReplacement = validRange(d.replacement_start, d.replacement_length, "replacement");
+            if (commitReplacement) {
+              var replacementEditor = Cc["@mozilla.org/focus-manager;1"].getService(Ci.nsIFocusManager).focusedElement || content.document.activeElement || content.document.querySelector("[autofocus]");
+              if (!replacementEditor || typeof replacementEditor.value !== "string")
+                throw new Error("no_replacement_editor");
+              var beforeReplacement = replacementEditor.value;
+              var expectedReplacement = beforeReplacement.slice(0, commitReplacement[0]) + text + beforeReplacement.slice(commitReplacement[0] + commitReplacement[1]);
+              await applyReplacementRange();
+              wu.sendContentCommandEvent("insertText", null, text);
+              if (replacementEditor.value !== expectedReplacement)
+                throw new Error("native_replace_not_applied");
+            } else if (!textTip.commitCompositionWith(text, null, 0)) {
+              throw new Error("tip_commit_rejected");
+            }
+          } else if (kind === "ime_start") {
+            await applyReplacementRange();
+            if (!textTip.startComposition(null, 0)) throw new Error("tip_start_rejected");
+          } else if (kind === "ime_update") {
+            setPendingComposition(textTip, text);
+            if (!textTip.flushPendingComposition(null, 0)) throw new Error("tip_update_rejected");
+          } else if (kind === "ime_commit") {
+            if (!textTip.commitCompositionWith(text, null, 0)) throw new Error("tip_ime_commit_rejected");
+          } else if (kind === "ime_cancel") {
+            if (textTip.hasComposition) textTip.cancelComposition(null, 0);
+          } else {
+            throw new Error("unknown_text_input");
+          }
+          result.ok = 1;
+          result.error = "widget_text_" + kind + "_utf8=" + utf8Bytes + "_codepoints=" + codePoints;
+        } else if (d.op === "focus") {
+          var selection = content.docShell.QueryInterface(Ci.nsIInterfaceRequestor)
+            .getInterface(Ci.nsISelectionDisplay).QueryInterface(Ci.nsISelectionController);
+          var focusManager = Cc["@mozilla.org/focus-manager;1"].getService(Ci.nsIFocusManager);
+          if (d.focused) {
+            var focusTarget = content.document.querySelector("[autofocus]") || content.document.activeElement;
+            if (focusTarget && focusTarget !== content.document.body && focusTarget !== content.document.documentElement) {
+              focusTarget.focus({ preventScroll: true });
+              focusManager.setFocus(focusTarget, focusManager.FLAG_NOSCROLL);
+            } else
+              focusManager.moveFocus(content, null, focusManager.MOVEFOCUS_FIRST, focusManager.FLAG_NOSCROLL);
+            selection.setDisplaySelection(selection.SELECTION_ON);
+          } else {
+            if (ahTextInputProcessor && ahTextInputProcessor.hasComposition)
+              ahTextInputProcessor.cancelComposition(null, 0);
+            focusManager.clearFocus(content);
+            selection.setDisplaySelection(selection.SELECTION_HIDDEN);
+          }
+          result.ok = 1;
+          result.error = "widget_focus_" + (d.focused ? "on" : "off");
+        } else if (d.op === "query") {
+          result.ok = 1;
+          result.error = "query";
+        } else {
+          throw new Error("unknown_text_op");
+        }
+        result.title = content.document ? content.document.title || "" : "";
+      } catch (e) {
+        result.error = String(e);
+        result.ok = 0;
+      }
+      sendAsyncMessage("astrohacker-text-input-result", result);
+    });`;
+  try {
+    browser.messageManager.loadFrameScript(
+      "data:," + encodeURIComponent(script),
+      true
+    );
+    browser._astrohackerTextInput = true;
+    dump("text_input_widget_frame_script=1\n");
+  } catch (e) {
+    dump(`text_input_widget_frame_script=0 error=${String(e)}\n`);
+  }
+}
