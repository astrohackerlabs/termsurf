+      var d = msg.data || {};
+      var result = { ok: 0, error: "", title: "", status: "", input_value: "" };
+      try {
+        var wu = content.windowUtils;
+        if (!wu) throw new Error("no_window_utils");
+        function finite(value, label) {
+          value = Number(value);
+          if (!Number.isFinite(value)) throw new Error("invalid_" + label);
+          return value;
+        }
+        function nativeModifiers(shared) {
+          shared = Number(shared);
+          if (!Number.isSafeInteger(shared) || shared < 0 || (shared & ~0x1cf))
+            throw new Error("invalid_modifiers");
+          var native = 0;
+          if (shared & 1) native |= wu.MODIFIER_SHIFT;
+          if (shared & 2) native |= wu.MODIFIER_CONTROL;
+          if (shared & 4) native |= wu.MODIFIER_ALT;
+          if (shared & 8) native |= wu.MODIFIER_META;
+          return native;
+        }
+        var x = finite(d.x, "x"), y = finite(d.y, "y");
+        var modifiers = nativeModifiers(d.modifiers);
+        if (d.op === "mouse" || d.op === "mousemove") {
+          var type = d.op === "mousemove" ? "mousemove" : String(d.type || "");
+          if (type === "down") type = "mousedown";
+          if (type === "up") type = "mouseup";
+          if (type !== "mousedown" && type !== "mouseup" && type !== "mousemove")
+            throw new Error("unknown_mouse_type");
+          var button = Number(d.button);
+          var clickCount = d.op === "mousemove" ? 0 : Number(d.clickCount);
+          if (!Number.isSafeInteger(button) || button < 0 || button > 2)
+            throw new Error("invalid_button");
+          if (!Number.isSafeInteger(clickCount) || clickCount < 0 ||
+              (d.op !== "mousemove" && clickCount < 1))
+            throw new Error("invalid_click_count");
+          if (typeof content.synthesizeMouseEvent !== "function")
+            throw new Error("no_widget_mouse_api");
+          var shared = Number(d.modifiers), buttons = 0;
+          if (shared & 64) buttons |= 1;
+          if (shared & 128) buttons |= 4;
+          if (shared & 256) buttons |= 2;
+          content.synthesizeMouseEvent(type, x, y, {
+            identifier: wu.DEFAULT_MOUSE_POINTER_ID,
+            button,
+            buttons,
+            clickCount,
+            modifiers,
+            inputSource: content.MouseEvent.MOZ_SOURCE_MOUSE,
+          }, {
+            isDOMEventSynthesized: false,
+            isWidgetEventSynthesized: false,
+            isAsyncEnabled: false,
+          });
+          result.ok = 1;
+          result.error = "widget_pointer_" + type + "_button=" + button +
+                         "_clicks=" + clickCount + "_shared_modifiers=" + Number(d.modifiers);
+        } else if (d.op === "wheel") {
+          var dx = finite(d.dx, "dx"), dy = finite(d.dy, "dy");
+          var phase = Number(d.scroll_phase), momentumPhase = Number(d.momentum_phase);
+          var precise = !!d.precise;
+          if (!Number.isSafeInteger(phase) || !Number.isSafeInteger(momentumPhase) ||
+              phase < 0 || momentumPhase < 0 || (phase & ~63) || (momentumPhase & ~63))
+            throw new Error("invalid_scroll_phase");
+          if (dx === 0 && dy === 0 && phase === 0 && momentumPhase === 0)
+            throw new Error("empty_scroll_event");
+          var options = 0;
+          if (precise) options |= wu.WHEEL_EVENT_CAUSED_BY_NO_LINE_OR_PAGE_DELTA_DEVICE;
+          if (momentumPhase) options |= wu.WHEEL_EVENT_CAUSED_BY_MOMENTUM;
+          var lineX = precise ? 0 : (dx > 0 ? Math.floor(dx) : Math.ceil(dx));
+          var lineY = precise ? 0 : (dy > 0 ? Math.floor(dy) : Math.ceil(dy));
+          var scale = content.devicePixelRatio || 1;
+          wu.sendWheelEvent(x, y, dx * scale, dy * scale, 0,
+                            content.WheelEvent.DOM_DELTA_PIXEL,
+                            modifiers, lineX, lineY, options);
+          result.ok = 1;
+          result.error = "widget_wheel_phase=" + phase + "_momentum_phase=" +
+                         momentumPhase + "_precise=" + (precise ? 1 : 0) +
+                         "_shared_modifiers=" + Number(d.modifiers);
+        } else {
+          throw new Error("unknown_pointer_op");
+        }
+        await new Promise(resolve =>
+          content.requestAnimationFrame(() => content.requestAnimationFrame(resolve)));
+        result.title = content.document ? content.document.title || "" : "";
+      } catch (e) {
+        result.error = String(e);
+        result.ok = 0;
+      }
+      sendAsyncMessage("astrohacker-pointer-input-result", result);
+    });`;
