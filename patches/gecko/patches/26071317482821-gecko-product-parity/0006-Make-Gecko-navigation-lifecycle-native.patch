+function appendFileSync(path, body) {
+  try {
+    let file = Cc["@mozilla.org/file/local;1"].createInstance(Ci.nsIFile);
+    file.initWithPath(path);
+    let fos = Cc["@mozilla.org/network/file-output-stream;1"].createInstance(
+      Ci.nsIFileOutputStream
+    );
+    // PR_WRONLY | PR_CREATE_FILE | PR_APPEND. Never truncate an event journal.
+    fos.init(file, 0x02 | 0x08 | 0x10, 0o644, 0);
+    let converter = Cc[
+      "@mozilla.org/intl/converter-output-stream;1"
+    ].createInstance(Ci.nsIConverterOutputStream);
+    converter.init(fos, "UTF-8");
+    converter.writeString(body);
+    converter.close();
+    fos.close();
+    return true;
+  } catch (e) {
+    dump(`lifecycle_journal_write_error=${String(e)}\n`);
+    return false;
+  }
+}
+
+function startLifecycleJournal(win, browser) {
+  const path = Services.env.get("ASTROHACKER_GECKO_LIFECYCLE_PATH") || "";
+  if (!path) {
+    dump("lifecycle_journal=0 reason=no_path\n");
+    return null;
+  }
+  if (!writeFileSync(path, "")) {
+    dump("lifecycle_journal=0 reason=truncate_failed\n");
+    return null;
+  }
+
+  let sequence = 0;
+  let nextGeneration = 0;
+  let activeGeneration = 0;
+  let lastLocation = "";
+  let lastLocationGeneration = 0;
+  let lastTitle = "";
+  let lastTitleGeneration = 0;
+  let lastProgress = -1;
+  let closed = false;
+  const requestGenerations = new WeakMap();
+  let pendingTerminal = null;
+  let terminalTimer = null;
+
+  const emit = (kind, generation, options = {}) => {
+    if (closed) {
+      return false;
+    }
+    const url = options.url || "";
+    const title = options.title || "";
+    const progress = Number.isSafeInteger(options.progress)
+      ? Math.max(0, Math.min(100, options.progress))
+      : 0;
+    const status = Number.isSafeInteger(options.status) ? options.status : 0;
+    sequence++;
+    const line =
+      `seq=${sequence} gen=${generation} kind=${kind} progress=${progress} ` +
+      `status=${status} url_enc=${encodeURIComponent(url)} ` +
+      `title_enc=${encodeURIComponent(title)}\n`;
+    const ok = appendFileSync(path, line);
+    dump(
+      `lifecycle_event seq=${sequence} gen=${generation} kind=${kind} ` +
+        `progress=${progress} status=${status}\n`
+    );
+    return ok;
+  };
+
+  const generationForObservation = () => activeGeneration;
+  const finishTerminal = () => {
+    if (!pendingTerminal) {
+      return;
+    }
+    const terminal = pendingTerminal;
+    pendingTerminal = null;
+    if (terminal.generation !== activeGeneration) {
+      dump(
+        `lifecycle_late_drop gen=${terminal.generation} active=${activeGeneration} kind=terminal\n`
+      );
+      return;
+    }
+    emit(terminal.success ? "done" : "error", terminal.generation, {
+      progress: terminal.success ? 100 : Math.max(0, lastProgress),
+      status: terminal.status,
+    });
+    activeGeneration = 0;
+  };
+  const listener = {
+    QueryInterface: ChromeUtils.generateQI([
+      "nsIWebProgressListener",
+      "nsISupportsWeakReference",
+    ]),
+    onStateChange(progress, request, stateFlags, status) {
+      let requestUrl = "";
+      try {
+        requestUrl = request?.QueryInterface(Ci.nsIChannel).URI?.spec || "";
+      } catch (e) {}
+      dump(
+        `lifecycle_state_callback top=${progress?.isTopLevel ? 1 : 0} flags=${stateFlags} url=${requestUrl}\n`
+      );
+      if (!progress?.isTopLevel) {
+        return;
+      }
+      if (requestUrl === "about:blank") {
+        return;
+      }
+      const L = Ci.nsIWebProgressListener;
+      const isWindowNetwork =
+        stateFlags & L.STATE_IS_NETWORK && stateFlags & L.STATE_IS_WINDOW;
+      if (!isWindowNetwork) {
+        return;
+      }
+      if (stateFlags & L.STATE_START) {
+        finishTerminal();
+        if (!activeGeneration) {
+          activeGeneration = ++nextGeneration;
+          lastProgress = -1;
+          emit("start", activeGeneration, { progress: 0, status: 0 });
+        }
+        if (request) {
+          requestGenerations.set(request, activeGeneration);
+        }
+        return;
+      }
+      if (!(stateFlags & L.STATE_STOP) || !activeGeneration) {
+        return;
+      }
+      const requestGeneration = request
+        ? requestGenerations.get(request) || activeGeneration
+        : activeGeneration;
+      if (requestGeneration !== activeGeneration) {
+        dump(
+          `lifecycle_late_drop gen=${requestGeneration} active=${activeGeneration} kind=terminal\n`
+        );
+        return;
+      }
+      const numericStatus = Number(status) || 0;
+      const success = Components.isSuccessCode(numericStatus);
+      pendingTerminal = {
+        generation: activeGeneration,
+        success,
+        status: numericStatus,
+      };
+      terminalTimer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
+      terminalTimer.initWithCallback(
+        () => {
+          terminalTimer = null;
+          finishTerminal();
+        },
+        25,
+        Ci.nsITimer.TYPE_ONE_SHOT
+      );
+    },
+    onProgressChange(progress, _request, curSelf, maxSelf, curTotal, maxTotal) {
+      if (!progress?.isTopLevel || !activeGeneration) {
+        return;
+      }
+      const current = maxTotal > 0 ? curTotal : curSelf;
+      const maximum = maxTotal > 0 ? maxTotal : maxSelf;
+      if (!(maximum > 0)) {
+        return;
+      }
+      const value = Math.max(
+        0,
+        Math.min(99, Math.floor((current * 100) / maximum))
+      );
+      if (value <= lastProgress) {
+        return;
+      }
+      lastProgress = value;
+      emit("progress", activeGeneration, { progress: value });
+    },
+    onLocationChange(progress, _request, location, _flags) {
+      dump(
+        `lifecycle_location_callback top=${progress?.isTopLevel ? 1 : 0} url=${location?.spec || ""}\n`
+      );
+      if (!progress?.isTopLevel) {
+        return;
+      }
+      const url = location?.spec || "";
+      const generation = _request
+        ? requestGenerations.get(_request) || generationForObservation()
+        : generationForObservation();
+      if (generation !== activeGeneration) {
+        return;
+      }
+      if (!generation || !url || url === "about:blank") {
+        return;
+      }
+      if (url === lastLocation && generation === lastLocationGeneration) {
+        return;
+      }
+      lastLocation = url;
+      lastLocationGeneration = generation;
+      emit("location", generation, { url });
+    },
+    onStatusChange() {},
+    onSecurityChange() {},
+    onContentBlockingEvent() {},
+  };
+
+  const titleListener = event => {
+    if (event.target !== browser) {
+      return;
+    }
+    dump("lifecycle_title_callback=1 source=pagetitlechanged\n");
+    const generation = generationForObservation();
+    const title = browser.contentTitle || "";
+    if (
+      !title ||
+      (title === lastTitle &&
+        (generation === lastTitleGeneration || generation === 0))
+    ) {
+      return;
+    }
+    lastTitle = title;
+    lastTitleGeneration = generation;
+    emit("title", generation, { title });
+  };
+
+  const flags =
+    Ci.nsIWebProgress.NOTIFY_STATE_ALL |
+    Ci.nsIWebProgress.NOTIFY_PROGRESS |
+    Ci.nsIWebProgress.NOTIFY_LOCATION;
+  browser.webProgress.addProgressListener(listener, flags);
+  browser.addEventListener("pagetitlechanged", titleListener);
+
+  const observer = {
+    close() {
+      if (closed) {
+        return;
+      }
+      closed = true;
+      try {
+        browser.webProgress.removeProgressListener(listener);
+      } catch (e) {}
+      try {
+        browser.removeEventListener("pagetitlechanged", titleListener);
+      } catch (e) {}
+      if (terminalTimer) {
+        try {
+          terminalTimer.cancel();
+        } catch (e) {}
+        terminalTimer = null;
+      }
+      pendingTerminal = null;
+      lifecycleObservers.delete(observer);
+    },
+  };
+  lifecycleObservers.add(observer);
+  emit("ready", 0);
+  dump(`lifecycle_journal=1 path=${path} ready=1\n`);
+  return observer;
+}
+
+function stopLifecycleObservers() {
+  for (const observer of Array.from(lifecycleObservers)) {
+    observer.close();
+  }
+}
