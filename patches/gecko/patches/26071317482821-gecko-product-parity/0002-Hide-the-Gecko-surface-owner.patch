     FILE* cf = fopen(controlPath, "r");
     if (cf) {
       unsigned long epoch = 0, ew = 0, eh = 0;
-      if (fscanf(cf, "epoch=%lu width=%lu height=%lu", &epoch, &ew, &eh) >= 1) {
+      unsigned long dipWidth = 0, dipHeight = 0;
+      double scale = 0.0;
+      if (fscanf(cf,
+                 "epoch=%lu dip_width=%lu dip_height=%lu scale=%lf "
+                 "physical_width=%lu physical_height=%lu",
+                 &epoch, &dipWidth, &dipHeight, &scale, &ew, &eh) == 6) {
         char buf[64];
         snprintf(buf, sizeof(buf), "%lu", epoch);
         setenv("ASTROHACKER_GECKO_SURFACE_RESIZE_EPOCH", buf, 1);
diff --git a/widget/cocoa/nsCocoaWindow.mm b/widget/cocoa/nsCocoaWindow.mm
index ddb523aff0b0..b2719f94000e 100644
--- a/widget/cocoa/nsCocoaWindow.mm
+++ b/widget/cocoa/nsCocoaWindow.mm
@@ -118,6 +118,26 @@ static uint32_t sModalWindowCount = 0;
 
 LazyLogModule sCocoaLog("nsCocoaWidgets");
 
+static bool IsAstrohackerSurfaceOwner() {
+  const char* value = getenv("ASTROHACKER_GECKO_SURFACE_OWNER");
+  return value && strcmp(value, "hidden") == 0;
+}
+
+static void PositionAstrohackerSurfaceOwner(NSWindow* aWindow) {
+  static bool sPositioning = false;
+  if (!aWindow || !IsAstrohackerSurfaceOwner() || sPositioning) {
+    return;
+  }
+  NSRect frame = aWindow.frame;
+  if (frame.origin.x == -100000.0 && frame.origin.y == -100000.0) {
+    return;
+  }
+  frame.origin = NSMakePoint(-100000.0, -100000.0);
+  sPositioning = true;
+  [aWindow setFrame:frame display:NO];
+  sPositioning = false;
+}
+
 extern "C" {
 // CGSPrivate.h
 typedef NSInteger CGSConnection;
@@ -5491,12 +5511,31 @@ void nsCocoaWindow::Show(bool aState) {
 
   NSWindow* nativeParentWindow =
       mParent ? (NSWindow*)mParent->GetNativeData(NS_NATIVE_WINDOW) : nil;
+  const bool astrohackerSurfaceOwner = IsAstrohackerSurfaceOwner();
 
   if (aState && !mBounds.IsEmpty()) {
+    // Astrohacker's Gecko renderer needs a live native compositor owner, but
+    // it must never expose browser chrome or steal focus from the terminal.
+    // Configure this before the first order operation. Ordinary Firefox
+    // windows do not set the marker and retain the upstream behavior below.
+    if (astrohackerSurfaceOwner) {
+      NSApp.activationPolicy = NSApplicationActivationPolicyProhibited;
+      [mWindow setAlphaValue:0.0];
+      [mWindow setIgnoresMouseEvents:YES];
+      [mWindow setHasShadow:NO];
+      [mWindow setAccessibilityElement:NO];
+      PositionAstrohackerSurfaceOwner(mWindow);
+      fprintf(stderr,
+              "astrohacker_owner_configured=1 hidden=1 alpha=0 "
+              "ignores_mouse=1 shadow=0 activation_policy=%ld\n",
+              (long)NSApp.activationPolicy);
+    }
+
     // If we had set the activationPolicy to accessory, then right now we won't
     // have a dock icon. Make sure that we undo that and show a dock icon now
     // that we're going to show a window.
-    if (NSApp.activationPolicy != NSApplicationActivationPolicyRegular) {
+    if (!astrohackerSurfaceOwner &&
+        NSApp.activationPolicy != NSApplicationActivationPolicyRegular) {
       NSApp.activationPolicy = NSApplicationActivationPolicyRegular;
       PR_SetEnv("MOZ_APP_NO_DOCK=");
     }
@@ -5596,7 +5635,9 @@ void nsCocoaWindow::Show(bool aState) {
       }
     } else {
       NS_OBJC_BEGIN_TRY_IGNORE_BLOCK;
-      EnsureFrameIsOnScreen();
+      if (!astrohackerSurfaceOwner) {
+        EnsureFrameIsOnScreen();
+      }
       if (mWindowType == WindowType::TopLevel &&
           [mWindow respondsToSelector:@selector(setAnimationBehavior:)]) {
         NSWindowAnimationBehavior behavior;
@@ -5621,7 +5662,18 @@ void nsCocoaWindow::Show(bool aState) {
       // We don't want most alwaysontop / alert windows to pull focus when
       // they're opened, as these tend to be for peripheral indicators and
       // displays.
-      if ((mAlwaysOnTop && mPiPType != PiPType::DocumentPiP) || mIsAlert) {
+      if (astrohackerSurfaceOwner) {
+        [mWindow orderFront:nil];
+        // AppKit can constrain a newly ordered frame back toward a display.
+        // Reassert the already configured owner policy without ever exposing
+        // it (alpha remains zero throughout the first order operation).
+        PositionAstrohackerSurfaceOwner(mWindow);
+        fprintf(stderr,
+                "astrohacker_owner_ordered=1 key=%d main=%d visible=%d\n",
+                mWindow.isKeyWindow ? 1 : 0, mWindow.isMainWindow ? 1 : 0,
+                mWindow.isVisible ? 1 : 0);
+      } else if ((mAlwaysOnTop && mPiPType != PiPType::DocumentPiP) ||
+                 mIsAlert) {
         [mWindow orderFront:nil];
       } else {
         [mWindow makeKeyAndOrderFront:nil];
@@ -7032,7 +7084,7 @@ void nsCocoaWindow::DispatchOcclusionEvent() {
 
   // Our new occlusion state is true if the window is not visible.
   bool newOcclusionState =
-      !keyOrMainNonFullscreen &&
+      !IsAstrohackerSurfaceOwner() && !keyOrMainNonFullscreen &&
       !(mHasStartedNativeFullscreen ||
         ([mWindow occlusionState] & NSWindowOcclusionStateVisible));
 
@@ -7672,6 +7724,9 @@ LayoutDeviceIntPoint nsCocoaWindow::GetNativeLockedPoint() {
 }
 
 - (void)windowDidResize:(NSNotification*)aNotification {
+  if (IsAstrohackerSurfaceOwner()) {
+    PositionAstrohackerSurfaceOwner(aNotification.object);
+  }
   if (!mGeckoWindow) return;
 
   mGeckoWindow->CocoaWindowDidResize();
@@ -7800,6 +7855,10 @@ LayoutDeviceIntPoint nsCocoaWindow::GetNativeLockedPoint() {
 - (void)windowDidBecomeMain:(NSNotification*)aNotification {
   NS_OBJC_BEGIN_TRY_IGNORE_BLOCK;
 
+  if (IsAstrohackerSurfaceOwner()) {
+    fprintf(stderr, "astrohacker_owner_violation=main\n");
+  }
+
   RollUpPopups();
   ChildViewMouseTracker::ReEvaluateMouseEnterState();
 
@@ -7852,6 +7911,10 @@ LayoutDeviceIntPoint nsCocoaWindow::GetNativeLockedPoint() {
 - (void)windowDidBecomeKey:(NSNotification*)aNotification {
   NS_OBJC_BEGIN_TRY_IGNORE_BLOCK;
 
+  if (IsAstrohackerSurfaceOwner()) {
+    fprintf(stderr, "astrohacker_owner_violation=key\n");
+  }
+
   RollUpPopups();
   ChildViewMouseTracker::ReEvaluateMouseEnterState();
 
@@ -7883,6 +7946,9 @@ LayoutDeviceIntPoint nsCocoaWindow::GetNativeLockedPoint() {
 }
 
 - (void)windowDidMove:(NSNotification*)aNotification {
+  if (IsAstrohackerSurfaceOwner()) {
+    PositionAstrohackerSurfaceOwner(aNotification.object);
+  }
   if (mGeckoWindow) mGeckoWindow->ReportMoveEvent();
 }
 
@@ -8045,6 +8111,20 @@ static NSMutableSet* gSwizzledFrameViewClasses = nil;
 
 @implementation BaseWindow
 
+- (BOOL)canBecomeKeyWindow {
+  if (IsAstrohackerSurfaceOwner()) {
+    return NO;
+  }
+  return [super canBecomeKeyWindow];
+}
+
+- (BOOL)canBecomeMainWindow {
+  if (IsAstrohackerSurfaceOwner()) {
+    return NO;
+  }
+  return [super canBecomeMainWindow];
+}
