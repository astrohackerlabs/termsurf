@@ -343,6 +348,7 @@ async function runVisible(urlStr, headless, hold) {
     dump("hold_mode=1\n");
     dump("hold_ms=0\n");
     dump("hold_retained=1\n");
+    startSurfaceControlLoop(win, browser);
