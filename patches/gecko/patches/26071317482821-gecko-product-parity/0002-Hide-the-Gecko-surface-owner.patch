+  if (IsAstrohackerSurfaceOwner()) {
+    return NO;
+  }
   return YES;
 }
 
@@ -9135,6 +9218,10 @@ static const NSUInteger kWindowShadowOptionsTooltip = 4;
 - (BOOL)canBecomeMainWindow {
   NS_OBJC_BEGIN_TRY_BLOCK_RETURN;
 
+  if (IsAstrohackerSurfaceOwner()) {
+    return NO;
+  }
+
   return self.isVisible;
 
   NS_OBJC_END_TRY_BLOCK_RETURN(NO);
