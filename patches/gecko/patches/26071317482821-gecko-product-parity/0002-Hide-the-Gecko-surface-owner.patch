+/**
+ * Hidden compositor-owner resize contract.
+ *
+ * Request file:
+ *   epoch=N dip_width=W dip_height=H scale=S physical_width=PW physical_height=PH
+ * Status file (request path + ".status"):
+ *   epoch=N observed_dip_width=W observed_dip_height=H scale=S
+ *   physical_width=PW physical_height=PH owner_hidden=1
+ *
+ * The parent derives the requested physical size from the scale Gecko
+ * reports here. An epoch is acknowledged only after the browser content rect
+ * reaches the requested DIP and physical dimensions.
+ *
+ * @param {Window} win The hidden compositor-owner chrome window.
+ * @param {MozBrowser} browser The browser whose content rect is resized.
+ */
+function startSurfaceControlLoop(win, browser) {
+  const path =
+    Services.env.get("ASTROHACKER_GECKO_SURFACE_CONTROL_PATH") || "";
+  if (!path) {
+    dump("surface_owner_control=0 reason=no_path\n");
+    return;
+  }
+
+  const statusPath = path + ".status";
+  let lastEpoch = 0;
+  let pending = null;
+
+  function observed(epoch) {
+    const rect = browser.getBoundingClientRect();
+    const scale = win.devicePixelRatio || 1;
+    const dipWidth = Math.round(rect.width);
+    const dipHeight = Math.round(rect.height);
+    return {
+      epoch,
+      dipWidth,
+      dipHeight,
+      scale,
+      physicalWidth: Math.round(rect.width * scale),
+      physicalHeight: Math.round(rect.height * scale),
+    };
+  }
+
+  function writeStatus(value) {
+    writeFileSync(
+      statusPath,
+      `epoch=${value.epoch} observed_dip_width=${value.dipWidth} ` +
+        `observed_dip_height=${value.dipHeight} scale=${value.scale.toFixed(6)} ` +
+        `physical_width=${value.physicalWidth} physical_height=${value.physicalHeight} ` +
+        "owner_hidden=1\n"
+    );
+  }
+
+  try {
+    writeStatus(observed(0));
+  } catch (e) {
+    dump(`surface_owner_initial_status_error=${String(e)}\n`);
+  }
+
+  const timer = Cc["@mozilla.org/timer;1"].createInstance(Ci.nsITimer);
+  surfaceControlTimers.add(timer);
+  timer.initWithCallback(
+    () => {
+      try {
+        if (pending) {
+          const value = observed(pending.epoch);
+          const matches =
+            Math.abs(value.dipWidth - pending.dipWidth) <= 1 &&
+            Math.abs(value.dipHeight - pending.dipHeight) <= 1 &&
+            Math.abs(value.scale - pending.scale) <= 0.01 &&
+            Math.abs(value.physicalWidth - pending.physicalWidth) <= 1 &&
+            Math.abs(value.physicalHeight - pending.physicalHeight) <= 1;
+          if (matches) {
+            writeStatus(value);
+            lastEpoch = pending.epoch;
+            dump(
+              `surface_owner_resize_ack=1 epoch=${lastEpoch} ` +
+                `dip=${value.dipWidth}x${value.dipHeight} ` +
+                `scale=${value.scale.toFixed(3)} ` +
+                `physical=${value.physicalWidth}x${value.physicalHeight}\n`
+            );
+            pending = null;
+          }
+          return;
+        }
+
+        const request = parseKvLine(readFileSync(path));
+        const epoch = Number.parseInt(request.epoch || "0", 10);
+        if (!Number.isFinite(epoch) || epoch <= lastEpoch) {
+          return;
+        }
+        const dipWidth = Number.parseInt(request.dip_width || "0", 10);
+        const dipHeight = Number.parseInt(request.dip_height || "0", 10);
+        const scale = Number.parseFloat(request.scale || "0");
+        const physicalWidth = Number.parseInt(
+          request.physical_width || "0",
+          10
+        );
+        const physicalHeight = Number.parseInt(
+          request.physical_height || "0",
+          10
+        );
+        if (
+          dipWidth <= 0 ||
+          dipHeight <= 0 ||
+          scale <= 0 ||
+          physicalWidth !== Math.round(dipWidth * scale) ||
+          physicalHeight !== Math.round(dipHeight * scale)
+        ) {
+          dump(`surface_owner_resize_rejected=1 epoch=${epoch}\n`);
+          return;
+        }
+
+        const current = observed(0);
+        if (Math.abs(current.scale - scale) > 0.01) {
+          dump(
+            `surface_owner_resize_rejected=1 epoch=${epoch} reason=scale ` +
+              `requested=${scale} observed=${current.scale}\n`
+          );
+          return;
+        }
+        const outerWidth = Math.max(
+          1,
+          dipWidth + Math.round(win.outerWidth - current.dipWidth)
+        );
+        const outerHeight = Math.max(
+          1,
+          dipHeight + Math.round(win.outerHeight - current.dipHeight)
+        );
+        pending = {
+          epoch,
+          dipWidth,
+          dipHeight,
+          scale,
+          physicalWidth,
+          physicalHeight,
+        };
+        win.resizeTo(outerWidth, outerHeight);
+        dump(
+          `surface_owner_resize_apply=1 epoch=${epoch} ` +
+            `dip=${dipWidth}x${dipHeight} outer=${outerWidth}x${outerHeight}\n`
+        );
+      } catch (e) {
+        dump(`surface_owner_control_error=${String(e)}\n`);
+      }
+    },
+    20,
+    Ci.nsITimer.TYPE_REPEATING_SLACK
+  );
+  dump(`surface_owner_control=1 path=${path} poll_ms=20\n`);
+}
+
 /**
  * Exp5 input control protocol (parent → Firefox chrome → content windowUtils).
  *
diff --git a/gfx/layers/AstrohackerSurfaceExporterMac.mm b/gfx/layers/AstrohackerSurfaceExporterMac.mm
