From b298a9f292042dcbaa61707c9b8f9a31f2a6f364 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Fri, 26 Jun 2026 14:32:20 -0500
Subject: [PATCH 3/3] Trace PDF response handoff

A PDF knocked once on the frame-loader door,
We marked the hinges, the latch, and the floor.
If no one answers, the trace will tell more.
---
 .../WebLocalFrameLoaderClient.cpp             | 99 ++++++++++++++++++-
 1 file changed, 98 insertions(+), 1 deletion(-)

diff --git a/Source/WebKit/WebProcess/WebCoreSupport/WebLocalFrameLoaderClient.cpp b/Source/WebKit/WebProcess/WebCoreSupport/WebLocalFrameLoaderClient.cpp
index 1e296c811d..7db951e8d1 100644
--- a/Source/WebKit/WebProcess/WebCoreSupport/WebLocalFrameLoaderClient.cpp
+++ b/Source/WebKit/WebProcess/WebCoreSupport/WebLocalFrameLoaderClient.cpp
@@ -116,6 +116,10 @@
 #include <wtf/ProcessID.h>
 #include <wtf/ProcessPrivilege.h>
 #include <wtf/RuntimeApplicationChecks.h>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <string>
 
 #if ENABLE(FULLSCREEN_API)
 #include <WebCore/DocumentFullscreen.h>
@@ -138,6 +142,58 @@
 namespace WebKit {
 using namespace WebCore;
 
+IGNORE_CLANG_WARNINGS_BEGIN("unsafe-buffer-usage")
+static std::string termsurfPDFPathTracePath()
+{
+    if (const char* path = std::getenv("TERMSURF_WEBKIT_PDF_PATH_TRACE_FILE"); path && *path)
+        return path;
+
+    const char* tmpdir = std::getenv("TMPDIR");
+    std::string configPath = tmpdir && *tmpdir ? tmpdir : "/tmp";
+    if (configPath.back() != '/')
+        configPath += '/';
+    configPath += "termsurf/issue-853-webkit-trace-config";
+
+    FILE* file = std::fopen(configPath.c_str(), "r");
+    if (!file)
+        return { };
+
+    constexpr const char* prefix = "TERMSURF_WEBKIT_PDF_PATH_TRACE_FILE=";
+    char line[4096];
+    while (std::fgets(line, sizeof(line), file)) {
+        if (std::strncmp(line, prefix, std::strlen(prefix)))
+            continue;
+        std::fclose(file);
+        std::string path = line + std::strlen(prefix);
+        while (!path.empty() && (path.back() == '\n' || path.back() == '\r'))
+            path.pop_back();
+        return path;
+    }
+
+    std::fclose(file);
+    return { };
+}
+
+static void termsurfAppendPDFPathTrace(const char* line)
+{
+    auto path = termsurfPDFPathTracePath();
+    if (path.empty())
+        return;
+
+    FILE* file = std::fopen(path.c_str(), "a");
+    if (!file)
+        return;
+    std::fputs(line, file);
+    std::fputc('\n', file);
+    std::fclose(file);
+}
+IGNORE_CLANG_WARNINGS_END
+
+static bool termsurfURLHasPDFExtension(const URL& url)
+{
+    return url.path().endsWithIgnoringASCIICase(".pdf"_s);
+}
+
 WebLocalFrameLoaderClient::WebLocalFrameLoaderClient(LocalFrame& localFrame, FrameLoader& loader, Ref<WebFrame>&& frame, ScopeExit<Function<void()>>&& invalidator)
     : LocalFrameLoaderClient(loader)
     , WebFrameLoaderClient(WTF::move(frame), WTF::move(invalidator))
@@ -962,6 +1018,16 @@ void WebLocalFrameLoaderClient::dispatchShow()
 
 void WebLocalFrameLoaderClient::dispatchDecidePolicyForResponse(const ResourceResponse& response, const ResourceRequest& request, const String& downloadAttribute, FramePolicyFunction&& function)
 {
+    if (termsurfURLHasPDFExtension(request.url()) || MIMETypeRegistry::isPDFMIMEType(response.mimeType())) {
+        char line[512];
+        std::snprintf(line, sizeof(line), "termsurf-webkit-pdf-path phase=decide-policy-for-response source=WebLocalFrameLoaderClient.cpp process=webcontent pid=%d main_frame=%d url_ext_pdf=%d mime_pdf=%d marker=issue-853-exp13",
+            getCurrentProcessID(),
+            m_frame->isMainFrame() ? 1 : 0,
+            termsurfURLHasPDFExtension(request.url()) ? 1 : 0,
+            MIMETypeRegistry::isPDFMIMEType(response.mimeType()) ? 1 : 0);
+        termsurfAppendPDFPathTrace(line);
+    }
+
     RefPtr webPage = m_frame->page();
     if (!webPage) {
         WebLocalFrameLoaderClient_RELEASE_LOG(Network, "dispatchDecidePolicyForResponse: ignoring because there's no web page");
@@ -1801,6 +1867,15 @@ bool WebLocalFrameLoaderClient::canCachePage() const
 
 void WebLocalFrameLoaderClient::convertMainResourceLoadToDownload(DocumentLoader *documentLoader, const ResourceRequest& request, const ResourceResponse& response)
 {
+    if (termsurfURLHasPDFExtension(request.url()) || MIMETypeRegistry::isPDFMIMEType(response.mimeType())) {
+        char line[512];
+        std::snprintf(line, sizeof(line), "termsurf-webkit-pdf-path phase=local-frame-convert-main-resource-to-download source=WebLocalFrameLoaderClient.cpp process=webcontent pid=%d main_frame=%d url_ext_pdf=%d mime_pdf=%d marker=issue-853-exp13",
+            getCurrentProcessID(),
+            m_frame->isMainFrame() ? 1 : 0,
+            termsurfURLHasPDFExtension(request.url()) ? 1 : 0,
+            MIMETypeRegistry::isPDFMIMEType(response.mimeType()) ? 1 : 0);
+        termsurfAppendPDFPathTrace(line);
+    }
     m_frame->convertMainResourceLoadToDownload(documentLoader, request, response);
 }
 
@@ -1822,6 +1897,16 @@ RefPtr<LocalFrame> WebLocalFrameLoaderClient::createFrame(const AtomString& name
 
 RefPtr<Widget> WebLocalFrameLoaderClient::createPlugin(HTMLPlugInElement& pluginElement, const URL& url, const Vector<AtomString>&, const Vector<AtomString>&, const String& mimeType, bool loadManually)
 {
+    if (termsurfURLHasPDFExtension(url) || MIMETypeRegistry::isPDFMIMEType(mimeType)) {
+        char line[512];
+        std::snprintf(line, sizeof(line), "termsurf-webkit-pdf-path phase=local-frame-create-plugin source=WebLocalFrameLoaderClient.cpp process=webcontent pid=%d main_frame=%d url_ext_pdf=%d mime_pdf=%d load_manually=%d marker=issue-853-exp13",
+            getCurrentProcessID(),
+            m_frame->isMainFrame() ? 1 : 0,
+            termsurfURLHasPDFExtension(url) ? 1 : 0,
+            MIMETypeRegistry::isPDFMIMEType(mimeType) ? 1 : 0,
+            loadManually ? 1 : 0);
+        termsurfAppendPDFPathTrace(line);
+    }
 #if ENABLE(PDF_PLUGIN)
     return PluginView::create(pluginElement, url, mimeType, loadManually && !m_frameCameFromBackForwardCache);
 #else
@@ -1836,6 +1921,7 @@ RefPtr<Widget> WebLocalFrameLoaderClient::createPlugin(HTMLPlugInElement& plugin
 void WebLocalFrameLoaderClient::redirectDataToPlugin(Widget& pluginWidget)
 {
 #if ENABLE(PDF_PLUGIN)
+    termsurfAppendPDFPathTrace("termsurf-webkit-pdf-path phase=local-frame-redirect-data-to-plugin source=WebLocalFrameLoaderClient.cpp process=webcontent marker=issue-853-exp13");
     m_pluginView = downcast<PluginView>(pluginWidget);
 #else
     UNUSED_PARAM(pluginWidget);
@@ -2122,7 +2208,18 @@ void WebLocalFrameLoaderClient::notifyPageOfAppBoundBehavior()
 bool WebLocalFrameLoaderClient::shouldUsePDFPlugin(const String& contentType, StringView path) const
 {
     RefPtr page = m_frame->page();
-    return page && page->shouldUsePDFPlugin(contentType, path);
+    bool shouldUsePDFPlugin = page && page->shouldUsePDFPlugin(contentType, path);
+    if (MIMETypeRegistry::isPDFMIMEType(contentType) || path.endsWithIgnoringASCIICase(".pdf"_s)) {
+        char line[512];
+        std::snprintf(line, sizeof(line), "termsurf-webkit-pdf-path phase=local-frame-should-use-pdf-plugin source=WebLocalFrameLoaderClient.cpp process=webcontent pid=%d main_frame=%d path_ext_pdf=%d mime_pdf=%d result=%d marker=issue-853-exp13",
+            getCurrentProcessID(),
+            m_frame->isMainFrame() ? 1 : 0,
+            path.endsWithIgnoringASCIICase(".pdf"_s) ? 1 : 0,
+            MIMETypeRegistry::isPDFMIMEType(contentType) ? 1 : 0,
+            shouldUsePDFPlugin ? 1 : 0);
+        termsurfAppendPDFPathTrace(line);
+    }
+    return shouldUsePDFPlugin;
 }
 
 #endif
