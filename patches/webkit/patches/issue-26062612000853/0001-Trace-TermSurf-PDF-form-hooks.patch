From 3afabe9a5993cf806a33968478dca95a97af94a9 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Fri, 26 Jun 2026 13:48:07 -0500
Subject: [PATCH 1/3] Trace TermSurf PDF form hooks

A WebKit trail of crumbs appears,
To prove which codepath volunteers.
If forms stay quiet after the click,
The log will show which gear won't tick.
---
 .../WebKit/UIProcess/API/Cocoa/WKWebView.mm   | 36 +++++++++++++
 .../WebProcess/Plugins/PDF/PDFPlugin.mm       | 53 ++++++++++++++++++
 .../Plugins/PDF/PDFPluginAnnotation.mm        | 51 ++++++++++++++++++
 .../WebProcess/Plugins/PDF/PDFPluginBase.mm   | 44 +++++++++++++++
 .../Plugins/PDF/PDFPluginTextAnnotation.mm    | 42 +++++++++++++++
 .../PDF/UnifiedPDF/UnifiedPDFPlugin.mm        | 54 +++++++++++++++++++
 6 files changed, 280 insertions(+)

diff --git a/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm b/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
index bb0b4d07bc..5888e54653 100644
--- a/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
+++ b/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
@@ -343,6 +343,40 @@ RetainPtr<NSError> nsErrorFromExceptionDetails(const std::optional<WebCore::Exce
 
 #endif
 
+static void termsurfAppendLocalExecutionTrace(NSString *line)
+{
+    NSString *path = NSProcessInfo.processInfo.environment[@"TERMSURF_WEBKIT_LOCAL_EXECUTION_TRACE_FILE"];
+    if (!path.length) {
+        NSString *configPath = [NSTemporaryDirectory() stringByAppendingPathComponent:@"termsurf/issue-853-webkit-trace-config"];
+        NSString *config = [NSString stringWithContentsOfFile:configPath encoding:NSUTF8StringEncoding error:nil];
+        NSString *prefix = @"TERMSURF_WEBKIT_LOCAL_EXECUTION_TRACE_FILE=";
+        for (NSString *row in [config componentsSeparatedByString:@"\n"]) {
+            if ([row hasPrefix:prefix]) {
+                path = [row substringFromIndex:prefix.length];
+                break;
+            }
+        }
+    }
+    if (!path.length)
+        return;
+
+    NSFileManager *fileManager = NSFileManager.defaultManager;
+    NSString *parent = path.stringByDeletingLastPathComponent;
+    if (parent.length)
+        [fileManager createDirectoryAtPath:parent withIntermediateDirectories:YES attributes:nil error:nil];
+
+    NSData *data = [[line stringByAppendingString:@"\n"] dataUsingEncoding:NSUTF8StringEncoding];
+    if (![fileManager fileExistsAtPath:path]) {
+        [data writeToFile:path atomically:YES];
+        return;
+    }
+
+    NSFileHandle *handle = [NSFileHandle fileHandleForWritingAtPath:path];
+    [handle seekToEndOfFile];
+    [handle writeData:data];
+    [handle closeFile];
+}
+
 @implementation WKWebView
 
 WK_OBJECT_DISABLE_DISABLE_KVC_IVAR_ACCESS;
