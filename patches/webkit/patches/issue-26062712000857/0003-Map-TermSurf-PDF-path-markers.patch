Date: Fri, 26 Jun 2026 14:12:43 -0500
Subject: [PATCH 3/5] Map TermSurf PDF path markers

The PDF trail was shy and thin,
So markers watched the doorway in.
UI waved, the plugin stayed mute,
Now the next clue has a route.
---
 .../WebKit/UIProcess/API/Cocoa/WKWebView.mm   | 37 ++++++++++++++
 .../WebProcess/Plugins/PDF/PDFPlugin.mm       | 44 ++++++++++++++++
 .../WebProcess/Plugins/PDF/PDFPluginBase.mm   | 15 ++++++
 .../PDF/UnifiedPDF/UnifiedPDFPlugin.mm        | 44 ++++++++++++++++
 .../WebProcess/WebPage/Cocoa/WebPageCocoa.mm  | 50 +++++++++++++++++--
 5 files changed, 187 insertions(+), 3 deletions(-)

diff --git a/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm b/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
index 7ca017da07..2cde6349a4 100644
--- a/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
+++ b/Source/WebKit/UIProcess/API/Cocoa/WKWebView.mm
@@ -371,6 +371,40 @@ static void termsurfAppendLocalExecutionTrace(NSString *line)
     [handle closeFile];
 }
 
+static void termsurfAppendPDFPathTrace(NSString *line)
+{
+    NSString *path = NSProcessInfo.processInfo.environment[@"TERMSURF_WEBKIT_PDF_PATH_TRACE_FILE"];
+    if (!path.length) {
+        NSString *configPath = [NSTemporaryDirectory() stringByAppendingPathComponent:@"termsurf/issue-853-webkit-trace-config"];
+        NSString *config = [NSString stringWithContentsOfFile:configPath encoding:NSUTF8StringEncoding error:nil];
+        NSString *prefix = @"TERMSURF_WEBKIT_PDF_PATH_TRACE_FILE=";
+        for (NSString *row in [config componentsSeparatedByString:@"\n"]) {
+            if ([row hasPrefix:prefix]) {
+                path = [row substringFromIndex:prefix.length];
+                break;
+            }
+        }
+    }
+    if (!path.length)
+        return;
+
+    NSFileManager *fileManager = NSFileManager.defaultManager;
+    NSString *parent = path.stringByDeletingLastPathComponent;
+    if (parent.length)
+        [fileManager createDirectoryAtPath:parent withIntermediateDirectories:YES attributes:nil error:nil];
+
+    NSData *data = [[line stringByAppendingString:@"\n"] dataUsingEncoding:NSUTF8StringEncoding];
+    if (![fileManager fileExistsAtPath:path]) {
+        [data writeToFile:path atomically:YES];
+        return;
+    }
+
+    NSFileHandle *handle = [NSFileHandle fileHandleForWritingAtPath:path];
+    [handle seekToEndOfFile];
+    [handle writeData:data];
+    [handle closeFile];
+}
+
 @implementation WKWebView
 
 WK_OBJECT_DISABLE_DISABLE_KVC_IVAR_ACCESS;
@@ -1105,6 +1139,9 @@ static void addBrowsingContextControllerMethodStubsIfNeeded()
     THROW_IF_SUSPENDED;
     if (_page->isServiceWorkerPage())
         [NSException raise:NSInternalInconsistencyException format:@"The WKWebView was used to load a service worker"];
+    if ([request.URL.path.pathExtension caseInsensitiveCompare:@"pdf"] == NSOrderedSame)
+        termsurfAppendPDFPathTrace([NSString stringWithFormat:@"termsurf-webkit-pdf-path phase=wkwebview-load-request source=WKWebView.mm process=ui pid=%d url_ext=pdf marker=issue-853-exp12",
+                                             NSProcessInfo.processInfo.processIdentifier]);
     return wrapper(_page->loadRequest(request)).autorelease();
 }
 
