From 04bf8fbd4dbbdcad1186ea3476a7b6da040be342 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Fri, 17 Jul 2026 12:54:06 -0500
Subject: [PATCH 3/3] Fix user-script sandbox exclusion for EagerLinking TBD rm

Xcode xcconfig treats // as a line comment, so the exclusion name
"Work around rdar://109484516" was truncated to "Work around rdar:" and
never matched the shell phase. The sandboxed script then failed with
file-write-unlink on EagerLinkingTBDs/*.tbd.

Rename the phase and exclusion to "Work around rdar 109484516" (no
URL form) so ENABLE_USER_SCRIPT_SANDBOXING exclusions apply for
WebKitLegacy, JavaScriptCore, and WebKit.
---
 Source/JavaScriptCore/Configurations/Base.xcconfig          | 2 +-
 .../JavaScriptCore/JavaScriptCore.xcodeproj/project.pbxproj | 6 +++---
 Source/WebKit/Configurations/Base.xcconfig                  | 2 +-
 Source/WebKit/WebKit.xcodeproj/project.pbxproj              | 6 +++---
 Source/WebKitLegacy/WebKitLegacy.xcodeproj/project.pbxproj  | 6 +++---
 Source/WebKitLegacy/mac/Configurations/Base.xcconfig        | 2 +-
 6 files changed, 12 insertions(+), 12 deletions(-)

diff --git a/Source/JavaScriptCore/Configurations/Base.xcconfig b/Source/JavaScriptCore/Configurations/Base.xcconfig
index 6cdd6e5aa7..59ac864212 100644
--- a/Source/JavaScriptCore/Configurations/Base.xcconfig
+++ b/Source/JavaScriptCore/Configurations/Base.xcconfig
@@ -25,7 +25,7 @@
 
 ALWAYS_SEARCH_USER_PATHS = NO;
 ENABLE_USER_SCRIPT_SANDBOXING = YES;
-EXCLUDED_USER_SCRIPT_SANDBOXING_PHASE_NAMES = $(inherited) "Generate Unified Sources" "Generate Derived Sources" "Generate <wtf/Platform.h> args" "Check For Inappropriate Files In Framework" "Check For Inappropriate Macros in External Headers" "Check .xcfilelists" "Copy jsc into JavaScriptCore.framework" "Audit SPI use" "Create Versions/Current/Helpers symlink" "Work around rdar://109484516";
+EXCLUDED_USER_SCRIPT_SANDBOXING_PHASE_NAMES = $(inherited) "Generate Unified Sources" "Generate Derived Sources" "Generate <wtf/Platform.h> args" "Check For Inappropriate Files In Framework" "Check For Inappropriate Macros in External Headers" "Check .xcfilelists" "Copy jsc into JavaScriptCore.framework" "Audit SPI use" "Create Versions/Current/Helpers symlink" "Work around rdar 109484516";
 
