+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_run_javascript_for_testing(TsLadybirdView* view, char const* script)
+{
+    if (!validate_view(view))
+        return false;
+    if (!script) {
+        set_runtime_error(view->runtime, "script is null");
+        return false;
+    }
+
+    auto script_view = StringView { script, strlen(script) };
+    auto script_string = String::from_utf8(script_view);
+    if (script_string.is_error()) {
+        set_runtime_error(view->runtime, "script is not valid UTF-8");
+        return false;
+    }
+    view->view->run_javascript(script_string.release_value());
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_navigation_action(TsLadybirdView* view, char const* action)
+{
+    if (!validate_view(view))
+        return false;
+    if (!action) {
+        set_runtime_error(view->runtime, "navigation action is null");
+        return false;
+    }
+
+    if (!strcmp(action, "back")) {
+        if (!view->view->navigate_back_action().enabled()) {
+            set_runtime_error(view->runtime, "back navigation is unavailable");
+            return false;
+        }
+        auto outcome = view->view->traverse_the_history_by_delta(-1);
+        outln("PROBE: TermSurf Ladybird ABI navigation_action action=back status={} replace_process={} top_level={} waiting={} url={}",
+            history_traversal_status_name(outcome.status), outcome.will_replace_web_content_process, outcome.will_change_top_level_entry, outcome.waiting_for_cancelation_check, view->view->url().to_byte_string());
+        return true;
+    }
+    if (!strcmp(action, "forward")) {
+        if (!view->view->navigate_forward_action().enabled()) {
+            set_runtime_error(view->runtime, "forward navigation is unavailable");
+            return false;
+        }
+        auto outcome = view->view->traverse_the_history_by_delta(1);
+        outln("PROBE: TermSurf Ladybird ABI navigation_action action=forward status={} replace_process={} top_level={} waiting={} url={}",
+            history_traversal_status_name(outcome.status), outcome.will_replace_web_content_process, outcome.will_change_top_level_entry, outcome.waiting_for_cancelation_check, view->view->url().to_byte_string());
+        return true;
+    }
+    if (!strcmp(action, "refresh")) {
+        if (!view->has_committed_document && !view->did_crash) {
+            set_runtime_error(view->runtime, "refresh is unavailable");
+            return false;
+        }
+        view->did_finish_load = false;
+        view->did_crash = false;
+        view->view->reload();
+        return true;
+    }
+
+    set_runtime_error(view->runtime, "navigation action is unsupported");
+    return false;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_navigation_state(TsLadybirdView const* view, TsLadybirdNavigationState* out_state)
+{
+    if (!out_state) {
+        set_runtime_error(view ? view->runtime : nullptr, "navigation state output is null");
+        return false;
+    }
+    memset(out_state, 0, sizeof(*out_state));
+    if (!validate_view(const_cast<TsLadybirdView*>(view)))
+        return false;
+
+    if (view->did_crash) {
+        out_state->can_refresh = view->has_committed_document;
+        return true;
+    }
+    out_state->can_go_back = view->view->navigate_back_action().enabled();
+    out_state->can_go_forward = view->view->navigate_forward_action().enabled();
+    out_state->can_refresh = view->has_committed_document;
+    return true;
+}
+
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_take_title_changed(TsLadybirdView* view, char* out_title, size_t out_title_len)
 {
     if (!validate_view(view))
@@ -1299,6 +1411,11 @@ TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView co
 {
     if (!view)
         return "";
+    if (view->view) {
+        auto* mutable_view = const_cast<TsLadybirdView*>(view);
+        mutable_view->last_url = view->view->url().to_byte_string();
+        return mutable_view->last_url.characters();
+    }
     return view->last_url.characters();
 }
 
