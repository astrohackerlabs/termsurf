 namespace {
 
+StringView history_traversal_status_name(WebView::HistoryTraversalStatus status)
+{
+    switch (status) {
+    case WebView::HistoryTraversalStatus::Started:
+        return "started"sv;
+    case WebView::HistoryTraversalStatus::NoEntry:
+        return "no-entry"sv;
+    case WebView::HistoryTraversalStatus::Canceled:
+        return "canceled"sv;
+    }
+    VERIFY_NOT_REACHED();
+}
+
 class TermSurfLadybirdApplication final : public WebView::Application {
     WEB_VIEW_APPLICATION(TermSurfLadybirdApplication)
 
