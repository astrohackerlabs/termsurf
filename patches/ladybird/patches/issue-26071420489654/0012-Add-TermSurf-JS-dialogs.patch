+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_take_javascript_dialog_request(TsLadybirdView* view, TsLadybirdJavaScriptDialogRequest* out_request)
+{
+    if (!out_request) {
+        set_runtime_error(view ? view->runtime : nullptr, "JavaScript dialog request output is null");
+        return false;
+    }
+
+    memset(out_request, 0, sizeof(*out_request));
+    if (!validate_view(view))
+        return false;
+    if (view->pending_javascript_dialog_requests.is_empty())
+        return false;
+
+    auto request = view->pending_javascript_dialog_requests.take_first();
+    out_request->request_id = request.request_id;
+    copy_c_string(out_request->dialog_type, sizeof(out_request->dialog_type), request.dialog_type);
+    copy_c_string(out_request->origin_url, sizeof(out_request->origin_url), request.origin_url);
+    copy_c_string(out_request->message, sizeof(out_request->message), request.message);
+    copy_c_string(out_request->default_prompt_text, sizeof(out_request->default_prompt_text), request.default_prompt_text);
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_reply_javascript_dialog(TsLadybirdView* view, unsigned long long request_id, bool accepted, char const* prompt_text)
+{
+    if (!validate_view(view))
+        return false;
+    if (view->active_javascript_dialog_request_id == 0) {
+        set_runtime_error(view->runtime, "no active JavaScript dialog request");
+        warnln("TermSurf Ladybird ABI stale JavaScript dialog reply request_id={} reason=no-active-dialog", request_id);
+        return false;
+    }
+    if (view->active_javascript_dialog_request_id != request_id) {
+        set_runtime_error(view->runtime, "stale JavaScript dialog request id");
+        warnln("TermSurf Ladybird ABI stale JavaScript dialog reply request_id={} active_request_id={}",
+            request_id, view->active_javascript_dialog_request_id);
+        return false;
+    }
+
+    auto dialog_type = view->active_javascript_dialog_type;
+    if (dialog_type == "alert") {
+        view->view->alert_closed();
+    } else if (dialog_type == "confirm") {
+        view->view->confirm_closed(accepted);
+    } else if (dialog_type == "prompt") {
+        if (accepted) {
+            auto prompt_text_view = StringView { prompt_text ? prompt_text : "", prompt_text ? strlen(prompt_text) : 0 };
+            view->view->prompt_closed(MUST(String::from_utf8(prompt_text_view)));
+        } else {
+            view->view->prompt_closed({});
+        }
+    } else {
+        set_runtime_error(view->runtime, ByteString::formatted("unsupported JavaScript dialog type: {}", dialog_type));
+        warnln("TermSurf Ladybird ABI unsupported JavaScript dialog reply request_id={} type={}", request_id, dialog_type);
+        return false;
+    }
+
+    outln("PROBE: TermSurf Ladybird ABI javascript_dialog_reply request_id={} type={} accepted={}",
+        request_id, dialog_type, accepted);
+    view->active_javascript_dialog_request_id = 0;
+    view->active_javascript_dialog_type = {};
+    return true;
+}
