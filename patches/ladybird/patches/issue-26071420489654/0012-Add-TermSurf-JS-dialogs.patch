+static void queue_javascript_dialog_request(TsLadybirdView* wrapper, ByteString dialog_type, String const& message, String const& default_prompt_text = {})
+{
+    auto request_id = wrapper->next_javascript_dialog_request_id++;
+    wrapper->active_javascript_dialog_request_id = request_id;
+    wrapper->active_javascript_dialog_type = dialog_type;
+
+    JavaScriptDialogRequest request;
+    request.request_id = request_id;
+    request.dialog_type = dialog_type;
+    request.origin_url = wrapper->view->url().to_byte_string();
+    request.message = message.to_byte_string();
+    request.default_prompt_text = default_prompt_text.to_byte_string();
+
+    outln("PROBE: TermSurf Ladybird ABI javascript_dialog request_id={} type={} origin={} message={} default={}",
+        request.request_id, request.dialog_type, request.origin_url, request.message, request.default_prompt_text);
+
+    if (wrapper->pending_javascript_dialog_requests.size() >= 16) {
+        warnln("TermSurf Ladybird ABI JavaScript dialog queue full; dropping request_id={} type={}",
+            request.request_id, request.dialog_type);
+        return;
+    }
+    wrapper->pending_javascript_dialog_requests.append(move(request));
+}
