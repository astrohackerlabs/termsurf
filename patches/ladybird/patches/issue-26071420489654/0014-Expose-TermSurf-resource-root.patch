From f62380e875c3aa63c5e27c23b8b31cd9190dc6af Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Thu, 2 Jul 2026 04:59:43 -0500
Subject: [PATCH 14/18] Expose TermSurf resource root

PDFs go looking for their stage,
A resource path behind the page.
We hand them the key,
So tests can agree,
And not trust a guessed backstage.
---
 .../LibTermSurfLadybird/TermSurfLadybird.cpp     | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp b/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
index e02aa8981a..5cb80211db 100644
--- a/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
+++ b/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
@@ -27,6 +27,7 @@
 #include <LibWebView/ConsoleOutput.h>
 #include <LibWebView/HeadlessWebView.h>
 #include <LibWebView/Options.h>
+#include <LibWebView/Utilities.h>
 #include <limits.h>
 #include <pthread.h>
 #include <string.h>
@@ -710,6 +711,7 @@ struct TsLadybirdView;
 
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_name();
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_version();
+TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_resource_root();
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_warmup();
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_initialize_runtime();
 TERMSURF_LADYBIRD_EXPORT void ts_ladybird_shutdown_runtime();
@@ -750,6 +752,20 @@ TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_version()
     return "ladybird-a80d01fc-issue-0884-renderer-crashed";
 }
 
+TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_resource_root()
+{
+    static ByteString root;
+    if (root.is_empty()) {
+        if (!s_runtime || !s_runtime->app) {
+            auto runtime = ts_ladybird_runtime_create();
+            if (runtime)
+                ts_ladybird_runtime_destroy(runtime);
+        }
+        root = WebView::s_ladybird_resource_root;
+    }
+    return root.characters();
+}
+
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_warmup()
 {
     if (!run_headless_lifecycle_probe()) {
