+static ByteString console_level(WebView::ConsoleLog const& log)
+{
+    switch (log.level) {
+    case JS::Console::LogLevel::Debug:
+        return "debug";
+    case JS::Console::LogLevel::Error:
+        return "error";
+    case JS::Console::LogLevel::Info:
+        return "info";
+    case JS::Console::LogLevel::Log:
+        return "log";
+    case JS::Console::LogLevel::Warn:
+        return "warn";
+    default:
+        return "log";
+    }
+}
+
+static ByteString serialize_console_arguments(Vector<JsonValue> const& arguments)
+{
+    StringBuilder builder;
+    bool first = true;
+    for (auto const& argument : arguments) {
+        if (!first)
+            builder.append(' ');
+        first = false;
+        builder.append(argument.serialized());
+    }
+    return builder.to_byte_string();
+}
+
+static ByteString stack_frame_source_id(WebView::StackFrame const& frame)
+{
+    return frame.file.map([](auto const& file) {
+                         return file.to_byte_string();
+                     })
+        .value_or("<ladybird-console>");
+}
+
+static int stack_frame_line_no(WebView::StackFrame const& frame)
+{
+    auto line = frame.line.value_or(0);
+    if (line > static_cast<size_t>(INT_MAX))
+        return INT_MAX;
+    return static_cast<int>(line);
+}
+
+static ConsoleMessage console_message_from_output(WebView::ConsoleOutput const& console_output)
+{
+    ConsoleMessage message;
+    message.level = "log";
+    message.message = "";
+    message.line_no = 0;
+    message.source_id = "<ladybird-console>";
+
+    console_output.output.visit(
+        [&](WebView::ConsoleLog const& log) {
+            message.level = console_level(log);
+            message.message = serialize_console_arguments(log.arguments);
+        },
+        [&](WebView::ConsoleError const& error) {
+            message.level = "error";
+            message.message = ByteString::formatted("{}: {}", error.name, error.message);
+            if (!error.trace.is_empty()) {
+                auto const& first_frame = error.trace.first();
+                message.source_id = stack_frame_source_id(first_frame);
+                message.line_no = stack_frame_line_no(first_frame);
+            }
+        },
+        [&](WebView::ConsoleTrace const& trace) {
+            message.level = "trace";
+            message.message = trace.label.to_byte_string();
+            if (!trace.stack.is_empty()) {
+                auto const& first_frame = trace.stack.first();
+                message.source_id = stack_frame_source_id(first_frame);
+                message.line_no = stack_frame_line_no(first_frame);
+            }
+        });
+
+    return message;
+}
