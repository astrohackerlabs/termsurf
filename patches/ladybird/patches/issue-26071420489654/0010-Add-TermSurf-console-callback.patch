+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_take_console_message(TsLadybirdView* view, TsLadybirdConsoleMessage* out_message)
+{
+    if (!out_message) {
+        set_runtime_error(view ? view->runtime : nullptr, "console message output is null");
+        return false;
+    }
+
+    memset(out_message, 0, sizeof(*out_message));
+    if (!validate_view(view))
+        return false;
+    if (view->pending_console_messages.is_empty())
+        return false;
+
+    auto message = view->pending_console_messages.take_first();
+    copy_c_string(out_message->level, sizeof(out_message->level), message.level);
+    copy_c_string(out_message->message, sizeof(out_message->message), message.message);
+    out_message->line_no = message.line_no;
+    copy_c_string(out_message->source_id, sizeof(out_message->source_id), message.source_id);
+    return true;
+}
