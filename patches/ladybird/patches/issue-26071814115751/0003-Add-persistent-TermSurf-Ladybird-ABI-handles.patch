+
+TERMSURF_LADYBIRD_EXPORT TsLadybirdRuntime* ts_ladybird_runtime_create()
+{
+    if (s_runtime && !s_runtime->destroyed) {
+        set_global_error("runtime already exists");
+        return nullptr;
+    }
+
+    auto app = create_application();
+    if (app.is_error()) {
+        set_global_error(ByteString::formatted("failed to create Ladybird application: {}", app.error()));
+        return nullptr;
+    }
+
+    auto* runtime = new TsLadybirdRuntime;
+    runtime->app = app.release_value();
+    runtime->owner_thread = pthread_self();
+    runtime->last_error = {};
+    runtime->destroyed = false;
+    s_runtime = runtime;
+    return runtime;
+}
+
+TERMSURF_LADYBIRD_EXPORT void ts_ladybird_runtime_destroy(TsLadybirdRuntime* runtime)
+{
+    if (!runtime || runtime->destroyed)
+        return;
+
+    if (!runtime_is_on_owner_thread(*runtime)) {
+        set_runtime_error(runtime, "runtime destroyed from non-owner thread");
+        return;
+    }
+
+    runtime->app = nullptr;
+    runtime->destroyed = true;
+    if (s_runtime == runtime)
+        s_runtime = nullptr;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_runtime_pump(TsLadybirdRuntime* runtime)
+{
+    if (!validate_runtime(runtime))
+        return false;
+
+    (void)Core::EventLoop::current().pump(Core::EventLoop::WaitMode::PollForEvents);
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_last_error(TsLadybirdRuntime const* runtime)
+{
+    if (runtime)
+        return runtime->last_error.characters();
+    return s_global_last_error.characters();
+}
+
+TERMSURF_LADYBIRD_EXPORT TsLadybirdView* ts_ladybird_view_create(TsLadybirdRuntime* runtime, int width, int height)
+{
+    if (!validate_runtime(runtime))
+        return nullptr;
+    if (width <= 0 || height <= 0) {
+        set_runtime_error(runtime, "view size must be positive");
+        return nullptr;
+    }
+
+    auto view_or_error = create_headless_view();
+    if (view_or_error.is_error()) {
+        set_runtime_error(runtime, ByteString::formatted("failed to create HeadlessWebView: {}", view_or_error.error()));
+        return nullptr;
+    }
+
+    auto* wrapper = new TsLadybirdView;
+    wrapper->runtime = runtime;
+    wrapper->view = view_or_error.release_value();
+    wrapper->last_url = {};
+    wrapper->did_finish_load = false;
+    wrapper->did_crash = false;
+    wrapper->destroyed = false;
+
+    wrapper->view->on_load_finish = [wrapper](URL::URL const& url) {
+        wrapper->last_url = url.to_byte_string();
+        outln("PROBE: TermSurf Ladybird ABI load_finish url={}", wrapper->last_url);
+        if (url.scheme() == "data"sv) {
+            outln("TIER3: TermSurf Ladybird ABI load_finish url={}", wrapper->last_url);
+            wrapper->did_finish_load = true;
+        }
+    };
+    wrapper->view->on_web_content_crashed = [wrapper] {
+        wrapper->did_crash = true;
+        set_runtime_error(wrapper->runtime, "WebContent crashed");
+    };
+
+    outln("TIER2: TermSurf Ladybird ABI constructed HeadlessWebView handle={}", wrapper->view->handle());
+    return wrapper;
+}
+
+TERMSURF_LADYBIRD_EXPORT void ts_ladybird_view_destroy(TsLadybirdView* view)
+{
+    if (!view || view->destroyed)
+        return;
+
+    view->view = nullptr;
+    view->destroyed = true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_load_url(TsLadybirdView* view, char const* url)
+{
+    if (!validate_view(view))
+        return false;
+    if (!url) {
+        set_runtime_error(view->runtime, "url is null");
+        return false;
+    }
+
+    auto url_view = StringView { url, strlen(url) };
+    auto parsed_url = URL::Parser::basic_parse(url_view);
+    if (!parsed_url.has_value()) {
+        set_runtime_error(view->runtime, "url parse failed");
+        return false;
+    }
+
+    view->last_url = {};
+    view->did_finish_load = false;
+    view->did_crash = false;
+    view->view->load(parsed_url.release_value(), Web::Bindings::NavigationHistoryBehavior::Auto);
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView const* view)
+{
+    if (!view)
+        return "";
+    return view->last_url.characters();
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_finish_load(TsLadybirdView const* view)
+{
+    return view && view->did_finish_load;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_crash(TsLadybirdView const* view)
+{
+    return view && view->did_crash;
+}
