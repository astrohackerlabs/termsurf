+struct TsLadybirdRuntime {
+    OwnPtr<TermSurfLadybirdApplication> app;
+    ByteString last_error;
+    pthread_t owner_thread {};
+    bool destroyed { false };
+};
+
+struct TsLadybirdView {
+    TsLadybirdRuntime* runtime { nullptr };
+    OwnPtr<WebView::HeadlessWebView> view;
+    ByteString last_url;
+    bool did_finish_load { false };
+    bool did_crash { false };
+    bool destroyed { false };
+};
+
+extern "C" TsLadybirdRuntime* ts_ladybird_runtime_create();
+extern "C" void ts_ladybird_runtime_destroy(TsLadybirdRuntime*);
+extern "C" bool ts_ladybird_runtime_pump(TsLadybirdRuntime*);
+extern "C" char const* ts_ladybird_runtime_last_error(TsLadybirdRuntime const*);
+extern "C" TsLadybirdView* ts_ladybird_view_create(TsLadybirdRuntime*, int, int);
+extern "C" void ts_ladybird_view_destroy(TsLadybirdView*);
+extern "C" bool ts_ladybird_view_load_url(TsLadybirdView*, char const*);
+extern "C" char const* ts_ladybird_view_last_url(TsLadybirdView const*);
+extern "C" bool ts_ladybird_view_did_finish_load(TsLadybirdView const*);
+extern "C" bool ts_ladybird_view_did_crash(TsLadybirdView const*);
+
+namespace {
+
+static TsLadybirdRuntime* s_runtime = nullptr;
+static ByteString s_global_last_error;
+
+static bool runtime_is_on_owner_thread(TsLadybirdRuntime const& runtime)
+{
+    return pthread_equal(pthread_self(), runtime.owner_thread);
+}
+
+static void set_global_error(ByteString error)
+{
+    s_global_last_error = move(error);
+}
+
+static void set_runtime_error(TsLadybirdRuntime* runtime, ByteString error)
+{
+    if (runtime)
+        runtime->last_error = move(error);
+    else
+        set_global_error(move(error));
+}
+
+static bool validate_runtime(TsLadybirdRuntime* runtime)
+{
+    if (!runtime) {
+        set_global_error("runtime is null");
+        return false;
+    }
+    if (runtime->destroyed) {
+        set_runtime_error(runtime, "runtime is destroyed");
+        return false;
+    }
+    if (!runtime_is_on_owner_thread(*runtime)) {
+        set_runtime_error(runtime, "runtime used from non-owner thread");
+        return false;
+    }
+    return true;
+}
+
+static bool validate_view(TsLadybirdView* view)
+{
+    if (!view) {
+        set_global_error("view is null");
+        return false;
+    }
+    if (view->destroyed) {
+        set_runtime_error(view->runtime, "view is destroyed");
+        return false;
+    }
+    if (!validate_runtime(view->runtime))
+        return false;
+    if (!view->view) {
+        set_runtime_error(view->runtime, "view has no Ladybird object");
+        return false;
+    }
+    return true;
+}
