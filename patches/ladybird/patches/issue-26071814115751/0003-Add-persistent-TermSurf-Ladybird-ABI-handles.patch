+static bool pump_until_finished(TsLadybirdRuntime* runtime, TsLadybirdView* view)
+{
+    for (u32 elapsed_ms = 0; elapsed_ms < 30'000; elapsed_ms += 5) {
+        if (view->did_finish_load || view->did_crash)
+            return true;
+        if (!ts_ladybird_runtime_pump(runtime))
+            return false;
+        if (Core::System::sleep_ms(5).is_error()) {
+            set_runtime_error(runtime, "sleep while pumping failed");
+            return false;
         }
-    };
-    view->on_web_content_crashed = [&] {
-        crashed = true;
-    };
+    }
+
+    set_runtime_error(runtime, "timed out waiting for view load");
+    return false;
+}
