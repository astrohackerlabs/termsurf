From 8cdbce4ade2cc31bf390c0ae42bbae5ce1945b47 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Thu, 2 Jul 2026 02:16:19 -0500
Subject: [PATCH 07/22] Add TermSurf state controls

A page learned dark from light,
And visible from night.
Its focus waits in Rust for now,
A quiet, tracked delight.
---
 .../LibTermSurfLadybird/TermSurfLadybird.cpp  | 36 ++++++++++++++++++-
 1 file changed, 35 insertions(+), 1 deletion(-)

diff --git a/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp b/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
index 5dcd07b557..86ed2b03fb 100644
--- a/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
+++ b/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
@@ -18,6 +18,8 @@
 #include <LibURL/Parser.h>
 #include <LibURL/URL.h>
 #include <LibWeb/Bindings/Navigation.h>
+#include <LibWeb/CSS/PreferredColorScheme.h>
+#include <LibWeb/HTML/VisibilityState.h>
 #include <LibWebView/Application.h>
 #include <LibWebView/HeadlessWebView.h>
 #include <LibWebView/Options.h>
@@ -143,6 +145,16 @@ public:
         reset_viewport_size(viewport_size);
     }
 
+    void set_color_scheme(bool dark)
+    {
+        set_preferred_color_scheme(dark ? Web::CSS::PreferredColorScheme::Dark : Web::CSS::PreferredColorScheme::Light);
+    }
+
+    void set_gui_active(bool active)
+    {
+        set_system_visibility_state(active ? Web::HTML::VisibilityState::Visible : Web::HTML::VisibilityState::Hidden);
+    }
+
 private:
     TermSurfWebView(Core::AnonymousBuffer theme, Web::DevicePixelSize viewport_size)
         : HeadlessWebView(move(theme), viewport_size)
@@ -192,6 +204,8 @@ extern "C" TsLadybirdView* ts_ladybird_view_create(TsLadybirdRuntime*, int, int)
 extern "C" void ts_ladybird_view_destroy(TsLadybirdView*);
 extern "C" bool ts_ladybird_view_load_url(TsLadybirdView*, char const*);
 extern "C" bool ts_ladybird_view_resize(TsLadybirdView*, int, int);
+extern "C" bool ts_ladybird_view_set_color_scheme(TsLadybirdView*, bool);
+extern "C" bool ts_ladybird_view_set_gui_active(TsLadybirdView*, bool);
 extern "C" char const* ts_ladybird_view_last_url(TsLadybirdView const*);
 extern "C" bool ts_ladybird_view_did_finish_load(TsLadybirdView const*);
 extern "C" bool ts_ladybird_view_did_crash(TsLadybirdView const*);
@@ -383,6 +397,8 @@ TERMSURF_LADYBIRD_EXPORT TsLadybirdView* ts_ladybird_view_create(TsLadybirdRunti
 TERMSURF_LADYBIRD_EXPORT void ts_ladybird_view_destroy(TsLadybirdView*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_load_url(TsLadybirdView*, char const*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_resize(TsLadybirdView*, int, int);
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_set_color_scheme(TsLadybirdView*, bool);
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_set_gui_active(TsLadybirdView*, bool);
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView const*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_finish_load(TsLadybirdView const*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_crash(TsLadybirdView const*);
@@ -395,7 +411,7 @@ TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_name()
 
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_version()
 {
-    return "ladybird-a80d01fc-issue-0884-core-tab-resize";
+    return "ladybird-a80d01fc-issue-0884-state-sync-controls";
 }
 
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_warmup()
@@ -561,6 +577,24 @@ TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_resize(TsLadybirdView* view, int
     return true;
 }
 
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_set_color_scheme(TsLadybirdView* view, bool dark)
+{
+    if (!validate_view(view))
+        return false;
+
+    view->view->set_color_scheme(dark);
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_set_gui_active(TsLadybirdView* view, bool active)
+{
+    if (!validate_view(view))
+        return false;
+
+    view->view->set_gui_active(active);
+    return true;
+}
+
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView const* view)
 {
     if (!view)
