--- a/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
+++ b/Libraries/LibTermSurfLadybird/TermSurfLadybird.cpp
@@ -87,6 +87,13 @@ struct JavaScriptDialogRequest {
     ByteString default_prompt_text;
 };
 
+struct RendererCrash {
+    ByteString termination_status;
+    int termination_status_code { 0 };
+    ByteString url;
+    bool can_reload { true };
+};
+
 class TermSurfWebView final : public WebView::HeadlessWebView {
 public:
     static NonnullOwnPtr<TermSurfWebView> create(Core::AnonymousBuffer theme, Web::DevicePixelSize window_size)
@@ -226,6 +233,7 @@ struct TsLadybirdView {
     Vector<int> pending_cursor_changes;
     Vector<ByteString> pending_target_urls;
     Vector<JavaScriptDialogRequest> pending_javascript_dialog_requests;
+    Vector<RendererCrash> pending_renderer_crashes;
     u64 next_javascript_dialog_request_id { 1 };
     u64 active_javascript_dialog_request_id { 0 };
     ByteString active_javascript_dialog_type;
@@ -250,6 +258,13 @@ typedef struct TsLadybirdJavaScriptDialogRequest {
     char default_prompt_text[1024];
 } TsLadybirdJavaScriptDialogRequest;
 
+typedef struct TsLadybirdRendererCrash {
+    char termination_status[64];
+    int termination_status_code;
+    char url[1024];
+    bool can_reload;
+} TsLadybirdRendererCrash;
+
 extern "C" TsLadybirdRuntime* ts_ladybird_runtime_create();
 extern "C" void ts_ladybird_runtime_destroy(TsLadybirdRuntime*);
 extern "C" bool ts_ladybird_runtime_pump(TsLadybirdRuntime*);
@@ -270,6 +285,8 @@ extern "C" bool ts_ladybird_view_take_cursor_changed(TsLadybirdView*, int*);
 extern "C" bool ts_ladybird_view_take_target_url_changed(TsLadybirdView*, char*, size_t);
 extern "C" bool ts_ladybird_view_take_javascript_dialog_request(TsLadybirdView*, TsLadybirdJavaScriptDialogRequest*);
 extern "C" bool ts_ladybird_view_reply_javascript_dialog(TsLadybirdView*, unsigned long long, bool, char const*);
+extern "C" bool ts_ladybird_view_take_renderer_crashed(TsLadybirdView*, TsLadybirdRendererCrash*);
+extern "C" bool ts_ladybird_view_crash_current_page_for_testing(TsLadybirdView*);
 extern "C" char const* ts_ladybird_view_last_url(TsLadybirdView const*);
