+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_mouse_event(TsLadybirdView* view, char const* type, char const* button, double x, double y, int click_count, unsigned long long modifiers)
+{
+    if (!validate_view(view))
+        return false;
+
+    auto event_type = mouse_event_type_from_name(type);
+    if (!event_type.has_value()) {
+        set_runtime_error(view->runtime, "mouse event type is unsupported");
+        return false;
+    }
+    auto mouse_button = mouse_button_from_name(button);
+    if (mouse_button == Web::UIEvents::MouseButton::None) {
+        set_runtime_error(view->runtime, "mouse button is unsupported");
+        return false;
+    }
+
+    Web::MouseEvent event {
+        event_type.release_value(),
+        Web::DevicePixelPoint { static_cast<int>(x), static_cast<int>(y) },
+        Web::DevicePixelPoint {},
+        mouse_button,
+        strcmp(type, "down") == 0 ? mouse_button : pressed_buttons_from_termsurf(modifiers),
+        termsurf_modifiers_to_ladybird(modifiers),
+        0,
+        0,
+        click_count,
+        nullptr,
+        false,
+    };
+    view->view->enqueue_mouse_event(move(event));
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_mouse_move(TsLadybirdView* view, double x, double y, unsigned long long modifiers)
+{
+    if (!validate_view(view))
+        return false;
+
+    Web::MouseEvent event {
+        Web::MouseEvent::Type::MouseMove,
+        Web::DevicePixelPoint { static_cast<int>(x), static_cast<int>(y) },
+        Web::DevicePixelPoint {},
+        Web::UIEvents::MouseButton::None,
+        pressed_buttons_from_termsurf(modifiers),
+        termsurf_modifiers_to_ladybird(modifiers),
+        0,
+        0,
+        0,
+        nullptr,
+        false,
+    };
+    view->view->enqueue_mouse_event(move(event));
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_scroll_event(TsLadybirdView* view, double x, double y, double delta_x, double delta_y, unsigned long long phase, unsigned long long momentum_phase, bool precise, unsigned long long modifiers)
+{
+    (void)phase;
+    (void)momentum_phase;
+    (void)precise;
+    if (!validate_view(view))
+        return false;
+
+    Web::MouseEvent event {
+        Web::MouseEvent::Type::MouseWheel,
+        Web::DevicePixelPoint { static_cast<int>(x), static_cast<int>(y) },
+        Web::DevicePixelPoint {},
+        Web::UIEvents::MouseButton::None,
+        pressed_buttons_from_termsurf(modifiers),
+        termsurf_modifiers_to_ladybird(modifiers),
+        delta_x,
+        delta_y,
+        0,
+        nullptr,
+        false,
+    };
+    view->view->enqueue_mouse_event(move(event));
+    return true;
+}
+
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_key_event(TsLadybirdView* view, char const* type, int windows_key_code, char const* utf8, unsigned long long modifiers)
+{
+    if (!validate_view(view))
+        return false;
+
+    auto event_type = key_event_type_from_name(type);
+    if (!event_type.has_value()) {
+        set_runtime_error(view->runtime, "key event type is unsupported");
+        return false;
+    }
+    auto key_code = key_code_from_windows_code(windows_key_code);
+    if (!key_code.has_value()) {
+        set_runtime_error(view->runtime, "windows key code is unsupported");
+        return false;
+    }
+
+    auto code_point = ascii_code_point(utf8);
+    auto type_value = event_type.release_value();
+    Web::KeyEvent event {
+        type_value,
+        key_code.release_value(),
+        termsurf_modifiers_to_ladybird(modifiers),
+        code_point,
+        key_event_is_repeat(type),
+        code_point != 0 && type_value == Web::KeyEvent::Type::KeyDown,
+        nullptr,
+    };
+    view->view->enqueue_key_event(move(event));
+    return true;
+}
+
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView const* view)
 {
     if (!view)
