+static Web::UIEvents::KeyModifier termsurf_modifiers_to_ladybird(unsigned long long modifiers)
+{
+    auto mapped = Web::UIEvents::KeyModifier::Mod_None;
+    if (modifiers & 1)
+        mapped |= Web::UIEvents::KeyModifier::Mod_Shift;
+    if (modifiers & 2)
+        mapped |= Web::UIEvents::KeyModifier::Mod_Ctrl;
+    if (modifiers & 4)
+        mapped |= Web::UIEvents::KeyModifier::Mod_Alt;
+    if (modifiers & 8)
+        mapped |= Web::UIEvents::KeyModifier::Mod_Super;
+    return mapped;
+}
+
+static Web::UIEvents::MouseButton mouse_button_from_name(char const* button)
+{
+    if (!button)
+        return Web::UIEvents::MouseButton::None;
+    if (strcmp(button, "left") == 0)
+        return Web::UIEvents::MouseButton::Primary;
+    if (strcmp(button, "right") == 0)
+        return Web::UIEvents::MouseButton::Secondary;
+    if (strcmp(button, "middle") == 0)
+        return Web::UIEvents::MouseButton::Middle;
+    return Web::UIEvents::MouseButton::None;
+}
+
+static Web::UIEvents::MouseButton pressed_buttons_from_termsurf(unsigned long long modifiers)
+{
+    auto buttons = Web::UIEvents::MouseButton::None;
+    if (modifiers & 64)
+        buttons |= Web::UIEvents::MouseButton::Primary;
+    if (modifiers & 128)
+        buttons |= Web::UIEvents::MouseButton::Middle;
+    if (modifiers & 256)
+        buttons |= Web::UIEvents::MouseButton::Secondary;
+    return buttons;
+}
+
+static Optional<Web::MouseEvent::Type> mouse_event_type_from_name(char const* type)
+{
+    if (!type)
+        return {};
+    if (strcmp(type, "down") == 0)
+        return Web::MouseEvent::Type::MouseDown;
+    if (strcmp(type, "up") == 0)
+        return Web::MouseEvent::Type::MouseUp;
+    return {};
+}
+
+static Optional<Web::KeyEvent::Type> key_event_type_from_name(char const* type)
+{
+    if (!type)
+        return {};
+    if (strcmp(type, "down") == 0 || strcmp(type, "repeat") == 0)
+        return Web::KeyEvent::Type::KeyDown;
+    if (strcmp(type, "up") == 0)
+        return Web::KeyEvent::Type::KeyUp;
+    return {};
+}
+
+static bool key_event_is_repeat(char const* type)
+{
+    return type && strcmp(type, "repeat") == 0;
+}
+
+static Optional<Web::UIEvents::KeyCode> key_code_from_windows_code(int windows_key_code)
+{
+    switch (windows_key_code) {
+    case 8:
+        return Web::UIEvents::KeyCode::Key_Backspace;
+    case 9:
+        return Web::UIEvents::KeyCode::Key_Tab;
+    case 13:
+        return Web::UIEvents::KeyCode::Key_Return;
+    case 27:
+        return Web::UIEvents::KeyCode::Key_Escape;
+    case 32:
+        return Web::UIEvents::KeyCode::Key_Space;
+    case 37:
+        return Web::UIEvents::KeyCode::Key_Left;
+    case 38:
+        return Web::UIEvents::KeyCode::Key_Up;
+    case 39:
+        return Web::UIEvents::KeyCode::Key_Right;
+    case 40:
+        return Web::UIEvents::KeyCode::Key_Down;
+    case 46:
+        return Web::UIEvents::KeyCode::Key_Delete;
+    default:
+        break;
+    }
+
+    if (windows_key_code >= '0' && windows_key_code <= '9')
+        return static_cast<Web::UIEvents::KeyCode>(windows_key_code);
+    if (windows_key_code >= 'A' && windows_key_code <= 'Z')
+        return static_cast<Web::UIEvents::KeyCode>(windows_key_code);
+    return {};
+}
+
+static u32 ascii_code_point(char const* utf8)
+{
+    if (!utf8 || utf8[0] == '\0')
+        return 0;
+    auto byte = static_cast<unsigned char>(utf8[0]);
+    if (byte >= 0x80)
+        return 0;
+    return byte;
+}
+
