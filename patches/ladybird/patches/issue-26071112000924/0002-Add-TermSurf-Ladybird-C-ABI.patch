+)
+
+set_target_properties(TermSurfLadybird PROPERTIES
+    OUTPUT_NAME termsurf_ladybird
+    MACOSX_RPATH ON
+    INSTALL_NAME_DIR "@rpath"
+    BUILD_RPATH "${CMAKE_BINARY_DIR}/lib;$<TARGET_FILE_DIR:ladybird>"
