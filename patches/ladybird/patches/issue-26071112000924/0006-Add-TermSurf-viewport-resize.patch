 extern "C" bool ts_ladybird_view_load_url(TsLadybirdView*, char const*);
+extern "C" bool ts_ladybird_view_resize(TsLadybirdView*, int, int);
 extern "C" char const* ts_ladybird_view_last_url(TsLadybirdView const*);
 extern "C" bool ts_ladybird_view_did_finish_load(TsLadybirdView const*);
 extern "C" bool ts_ladybird_view_did_crash(TsLadybirdView const*);
@@ -376,6 +382,7 @@ TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_last_error(TsLadybirdRu
 TERMSURF_LADYBIRD_EXPORT TsLadybirdView* ts_ladybird_view_create(TsLadybirdRuntime*, int, int);
 TERMSURF_LADYBIRD_EXPORT void ts_ladybird_view_destroy(TsLadybirdView*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_load_url(TsLadybirdView*, char const*);
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_resize(TsLadybirdView*, int, int);
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_view_last_url(TsLadybirdView const*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_finish_load(TsLadybirdView const*);
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_did_crash(TsLadybirdView const*);
@@ -388,7 +395,7 @@ TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_name()
 
 TERMSURF_LADYBIRD_EXPORT char const* ts_ladybird_runtime_version()
 {
-    return "ladybird-a80d01fc-issue-0884-render-surface-abi-probe";
+    return "ladybird-a80d01fc-issue-0884-core-tab-resize";
 }
 
 TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_warmup()
@@ -541,6 +548,19 @@ TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_load_url(TsLadybirdView* view, ch
     return true;
 }
 
+TERMSURF_LADYBIRD_EXPORT bool ts_ladybird_view_resize(TsLadybirdView* view, int width, int height)
+{
+    if (!validate_view(view))
+        return false;
+    if (width <= 0 || height <= 0) {
+        set_runtime_error(view->runtime, "view size must be positive");
+        return false;
+    }
+
+    view->view->resize(Web::DevicePixelSize { width, height });
+    return true;
+}
