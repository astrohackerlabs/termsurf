@@ -0,0 +1,96 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+CHROMIUM_SRC="$(cd "$SCRIPT_DIR/../../.." && pwd)"
+OUT_DIR="${CHROMIUM_OUT_DIR:-$CHROMIUM_SRC/out/Default}"
+TEST_BIN="$OUT_DIR/libtermsurf_chromium_test"
+
+if [[ ! -x "$TEST_BIN" ]]; then
+  echo "missing executable: $TEST_BIN" >&2
+  echo "build it with: autoninja -C $OUT_DIR libtermsurf_chromium_test" >&2
+  exit 1
+fi
+
+TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/termsurf-chromium-back.XXXXXX")"
+PORT_FILE="$TMP_DIR/port"
+
+cleanup() {
+  if [[ -n "${SERVER_PID:-}" ]]; then
+    kill "$SERVER_PID" 2>/dev/null || true
+    wait "$SERVER_PID" 2>/dev/null || true
+  fi
+  rm -rf "$TMP_DIR"
+}
+trap cleanup EXIT
+
+python3 - "$PORT_FILE" <<'PY' &
+import http.server
+import socketserver
+import sys
+
+port_file = sys.argv[1]
+
+PAGES = {
+    "/a1": "<!doctype html><meta charset='utf-8'><title>A1</title><body>A1</body>",
+    "/a2": "<!doctype html><meta charset='utf-8'><title>A2 base</title><body>A2</body>",
+    "/b1": "<!doctype html><meta charset='utf-8'><title>B1</title><body>B1</body>",
+}
+
+class Handler(http.server.BaseHTTPRequestHandler):
+    protocol_version = "HTTP/1.1"
+
+    def do_GET(self):
+        path = self.path.split("?", 1)[0].split("#", 1)[0]
+        body = PAGES.get(path)
+        if body is None:
+            self.send_response(404)
+            self.send_header("Content-Length", "0")
+            self.end_headers()
+            return
+        data = body.encode("utf-8")
+        self.send_response(200)
+        self.send_header("Content-Type", "text/html; charset=utf-8")
+        self.send_header("Cache-Control", "no-store")
+        self.send_header("Content-Length", str(len(data)))
+        self.end_headers()
+        self.wfile.write(data)
+
+    def log_message(self, fmt, *args):
+        return
+
+class Server(socketserver.ThreadingMixIn, http.server.HTTPServer):
+    daemon_threads = True
+    allow_reuse_address = True
+
+server = Server(("127.0.0.1", 0), Handler)
+with open(port_file, "w", encoding="utf-8") as f:
+    f.write(str(server.server_address[1]))
+server.serve_forever()
+PY
+SERVER_PID=$!
+
+for _ in {1..100}; do
+  [[ -s "$PORT_FILE" ]] && break
+  sleep 0.05
+done
+
+if [[ ! -s "$PORT_FILE" ]]; then
+  echo "fixture server did not start" >&2
+  exit 1
+fi
+
+PORT="$(<"$PORT_FILE")"
+export TERMSURF_CHROMIUM_SMOKE_A1_URL="http://a.test:$PORT/a1"
+export TERMSURF_CHROMIUM_SMOKE_A2_URL="http://a.test:$PORT/a2"
+export TERMSURF_CHROMIUM_SMOKE_B1_URL="http://b.test:$PORT/b1"
+
+"$TEST_BIN" \
+  --user-data-dir="$TMP_DIR/profile" \
+  --host-resolver-rules="MAP *.test 127.0.0.1" \
+  --no-sandbox \
+  --disable-gpu \
+  --disable-software-rasterizer \
+  --disable-extensions \
+  --disable-background-networking \
+  --disable-component-update
diff --git a/content/libtermsurf_chromium/test_main.cc b/content/libtermsurf_chromium/test_main.cc
index 36b3cdc114..b9937dee75 100644
--- a/content/libtermsurf_chromium/test_main.cc
+++ b/content/libtermsurf_chromium/test_main.cc
@@ -1,17 +1,371 @@
 // Copyright 2025 TermSurf
-// Minimal test: initialize libtermsurf_chromium and quit.
+// Back-only semantic navigation smoke for libtermsurf_chromium.
 
-#include <stdio.h>
 #include "content/libtermsurf_chromium/libtermsurf_chromium.h"
 
-static void on_initialized(void* user_data) {
-  printf("[test_main] Chromium initialized, quitting.\n");
+#include <stdlib.h>
+#include <unistd.h>
+
+#include <atomic>
+#include <chrono>
+#include <string>
+#include <thread>
+
+namespace {
+
+struct NavState {
+  bool back = false;
+  bool seen = false;
+  int updates = 0;
+};
+
+struct Tab {
+  ts_web_contents_t wc = nullptr;
+  int tab_id = 0;
+  NavState nav;
+  std::string url;
+  std::string title;
+  bool initial_false_seen = false;
+  bool crashed = false;
+};
+
+enum class Step {
+  kWaitInitial,
+  kWaitFirstA2,
+  kWaitBackA1,
+  kWaitSecondA2,
+  kWaitPushed,
+  kWaitBackSameDocument,
+  kWaitCrash,
+  kWaitRecovery,
+  kCleanup,
+  kDone,
+};
+
+struct Smoke {
+  Tab a;
+  Tab b;
+  ts_browser_context_t ctx = nullptr;
+  Step step = Step::kWaitInitial;
+  std::string a1_url;
+  std::string a2_url;
+  std::string b1_url;
+  int recovery_state_epoch = 0;
+  bool recovery_state_seen = false;
+  bool action = false;
+  bool state = false;
+  bool disabled = false;
+  bool isolation = false;
+  bool same_document = false;
+  bool crash_recovery = false;
+  bool cleanup = false;
+  bool future_actions_rejected = false;
+  bool cleanup_scheduled = false;
+};
+
+Smoke* g_smoke = new Smoke;
+#define g (*g_smoke)
+std::atomic<bool> g_done(false);
+
+bool Contains(const std::string& value, const char* needle) {
+  return value.find(needle) != std::string::npos;
+}
+
+Tab* TabFor(ts_web_contents_t wc) {
+  if (wc && g.a.wc == wc) {
+    return &g.a;
+  }
+  if (wc && g.b.wc == wc) {
+    return &g.b;
+  }
+  if (!g.a.wc) {
+    return &g.a;
+  }
+  if (!g.b.wc) {
+    return &g.b;
+  }
+  return nullptr;
+}
+
+void WriteLine(int fd, const std::string& line) {
+  const std::string output = line + "\n";
+  const ssize_t ignored = write(fd, output.data(), output.size());
+  (void)ignored;
+}
+
+void Fail(const char* message) {
+  WriteLine(STDERR_FILENO,
+            "BACK_ACTION_SMOKE_FAIL engine=chromium step=" +
+                std::to_string(static_cast<int>(g.step)) + " message=" +
+                std::string(message ? message : "") + " a_url=" + g.a.url +
+                " a_title=" + g.a.title + " a_back=" +
+                std::to_string(g.a.nav.back ? 1 : 0) + " b_url=" + g.b.url +
+                " b_title=" + g.b.title + " b_back=" +
+                std::to_string(g.b.nav.back ? 1 : 0));
+  g_done = true;
+  _Exit(1);
+}
+
+bool BUnchanged() {
+  return Contains(g.b.url, "/b1") && g.b.title == "B1" && g.b.nav.seen &&
+         !g.b.nav.back && !g.b.crashed;
+}
+
+void Finish() {
+  WriteLine(
+      STDOUT_FILENO,
+      "BACK_ACTION_SMOKE_PASS engine=chromium tabs=2 action=" +
+          std::to_string(g.action ? 1 : 0) + " state=" +
+          std::to_string(g.state ? 1 : 0) + " disabled=" +
+          std::to_string(g.disabled ? 1 : 0) + " isolation=" +
+          std::to_string(g.isolation ? 1 : 0) + " same_document=" +
+          std::to_string(g.same_document ? 1 : 0) + " crash_recovery=" +
+          std::to_string(g.crash_recovery ? 1 : 0) + " cleanup=" +
+          std::to_string(g.cleanup ? 1 : 0) +
+          " future_actions_rejected=" +
+          std::to_string(g.future_actions_rejected ? 1 : 0));
+  g_done = true;
   ts_quit();
 }
 
+void Advance();
+
+void CleanupAndFinish(void*) {
+  const ts_web_contents_t stale_a = g.a.wc;
+  ts_destroy_web_contents(g.a.wc);
+  if (ts_navigation_action(stale_a, "back")) {
+    Fail("closed tab accepted Back");
+  }
+  if (!BUnchanged()) {
+    Fail("closed-tab action mutated peer tab");
+  }
+  ts_destroy_web_contents(g.b.wc);
+  g.cleanup = true;
+  g.isolation = true;
+  g.step = Step::kDone;
+  Finish();
+}
+
+void OnInitialized(void*) {
+  g.ctx = ts_create_incognito_browser_context();
+  if (!g.ctx) {
+    Fail("missing browser context");
+  }
+  g.a.wc = ts_create_web_contents(g.ctx, g.a1_url.c_str(), 800, 600, true);
+  g.b.wc = ts_create_web_contents(g.ctx, g.b1_url.c_str(), 800, 600, true);
+  if (!g.a.wc || !g.b.wc || g.a.wc == g.b.wc) {
+    Fail("failed to create two tabs");
+  }
+  Advance();
+}
+
+void OnTabReady(ts_web_contents_t wc, int tab_id, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->tab_id = tab_id;
+  Advance();
+}
+
+void OnNavigationState(ts_web_contents_t wc, bool can_go_back, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->nav.back = can_go_back;
+  tab->nav.seen = true;
+  tab->nav.updates += 1;
+  if (!can_go_back && tab->url.empty() && tab->title.empty()) {
+    tab->initial_false_seen = true;
+  }
+  if (tab == &g.a && g.step == Step::kWaitRecovery &&
+      tab->nav.updates > g.recovery_state_epoch) {
+    g.recovery_state_seen = true;
+  }
+  Advance();
+}
+
+void OnUrlChanged(ts_web_contents_t wc, const char* url, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->url = url ? url : "";
+  Advance();
+}
+
+void OnTitleChanged(ts_web_contents_t wc, const char* title, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->title = title ? title : "";
+  Advance();
+}
+
+void OnRendererCrashed(ts_web_contents_t wc,
+                       const char*,
+                       int,
+                       const char*,
+                       bool,
+                       void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->crashed = true;
+  Advance();
+}
+
+void Advance() {
+  switch (g.step) {
+    case Step::kWaitInitial:
+      if (g.a.tab_id > 0 && g.b.tab_id > 0 && g.a.initial_false_seen &&
+          g.b.initial_false_seen && Contains(g.a.url, "/a1") &&
+          g.a.title == "A1" && !g.a.nav.back && BUnchanged()) {
+        g.step = Step::kWaitFirstA2;
+        ts_load_url(g.a.wc, g.a2_url.c_str());
+      }
+      break;
+
+    case Step::kWaitFirstA2:
+      if (Contains(g.a.url, "/a2") && g.a.title == "A2 base" &&
+          g.a.nav.back && BUnchanged()) {
+        g.step = Step::kWaitBackA1;
+        if (!ts_navigation_action(g.a.wc, "back")) {
+          Fail("semantic Back was rejected");
+        }
+      }
+      break;
+
+    case Step::kWaitBackA1:
+      if (Contains(g.a.url, "/a1") && !g.a.nav.back && BUnchanged()) {
+        g.action = true;
+        g.state = true;
+        const std::string before_url = g.a.url;
+        const std::string before_title = g.a.title;
+        const int before_state_updates = g.a.nav.updates;
+        if (ts_navigation_action(g.a.wc, "back")) {
+          Fail("disabled Back was accepted");
+        }
+        if (g.a.url != before_url || g.a.title != before_title ||
+            g.a.nav.updates != before_state_updates) {
+          Fail("disabled Back mutated page or callback state");
+        }
+        if (ts_navigation_action(g.a.wc, "forward") ||
+            ts_navigation_action(g.a.wc, "refresh") ||
+            ts_navigation_action(g.a.wc, "unknown") ||
+            ts_navigation_action(nullptr, "back")) {
+          Fail("future, unknown, or missing-tab action was accepted");
+        }
+        if (g.a.nav.updates != before_state_updates) {
+          Fail("rejected future action fabricated state");
+        }
+        g.disabled = true;
+        g.future_actions_rejected = true;
+        g.step = Step::kWaitSecondA2;
+        ts_load_url(g.a.wc, g.a2_url.c_str());
+      }
+      break;
+
+    case Step::kWaitSecondA2:
+      if (Contains(g.a.url, "/a2") && g.a.title == "A2 base" &&
+          g.a.nav.back && BUnchanged()) {
+        g.step = Step::kWaitPushed;
+        if (!ts_test_execute_javascript(
+                g.a.wc,
+                "(() => {"
+                "const update = () => { document.title = "
+                "location.hash === '#state' ? 'A2 state' : 'A2 base'; };"
+                "window.addEventListener('popstate', update);"
+                "history.pushState({ termsurf: 'back' }, '', "
+                "location.pathname + location.search + '#state');"
+                "update();"
+                "})()")) {
+          Fail("pushState script was rejected");
+        }
+      }
+      break;
+
+    case Step::kWaitPushed:
+      if (Contains(g.a.url, "/a2#state") && g.a.title == "A2 state" &&
+          g.a.nav.back && BUnchanged()) {
+        g.step = Step::kWaitBackSameDocument;
+        if (!ts_navigation_action(g.a.wc, "back")) {
+          Fail("same-document Back was rejected");
+        }
+      }
+      break;
+
+    case Step::kWaitBackSameDocument:
+      if (Contains(g.a.url, "/a2") && !Contains(g.a.url, "#state") &&
+          g.a.nav.back && BUnchanged()) {
+        g.same_document = true;
+        g.step = Step::kWaitCrash;
+        if (!ts_test_crash_current_page(g.a.wc)) {
+          Fail("addressed crash hook was rejected");
+        }
+      }
+      break;
+
+    case Step::kWaitCrash:
+      if (g.a.crashed && g.a.nav.seen && !g.a.nav.back && BUnchanged()) {
+        g.recovery_state_epoch = g.a.nav.updates;
+        g.recovery_state_seen = false;
+        g.step = Step::kWaitRecovery;
+        ts_load_url(g.a.wc, g.a1_url.c_str());
+      }
+      break;
+
+    case Step::kWaitRecovery:
+      if (g.recovery_state_seen && Contains(g.a.url, "/a1") && BUnchanged()) {
+        g.crash_recovery = true;
+        if (!g.cleanup_scheduled) {
+          g.cleanup_scheduled = true;
+          g.step = Step::kCleanup;
+          ts_post_task(CleanupAndFinish, nullptr);
+        }
+      }
+      break;
+
+    case Step::kCleanup:
+    case Step::kDone:
+      break;
+  }
+}
+
+}  // namespace
+
 int main(int argc, const char** argv) {
-  ts_set_on_initialized(on_initialized, nullptr);
-  int result = ts_content_main(argc, argv);
-  printf("[test_main] Exited with code %d\n", result);
-  return result;
+  const char* a1 = getenv("TERMSURF_CHROMIUM_SMOKE_A1_URL");
+  const char* a2 = getenv("TERMSURF_CHROMIUM_SMOKE_A2_URL");
+  const char* b1 = getenv("TERMSURF_CHROMIUM_SMOKE_B1_URL");
+  if (!a1 || !a2 || !b1) {
+    WriteLine(STDERR_FILENO, "missing TERMSURF_CHROMIUM_SMOKE_* fixture URLs");
+    return 64;
+  }
+  g.a1_url = a1;
+  g.a2_url = a2;
+  g.b1_url = b1;
+
+  ts_set_on_initialized(OnInitialized, nullptr);
+  ts_set_on_tab_ready(OnTabReady, nullptr);
+  ts_set_on_navigation_state(OnNavigationState, nullptr);
+  ts_set_on_url_changed(OnUrlChanged, nullptr);
+  ts_set_on_title_changed(OnTitleChanged, nullptr);
+  ts_set_on_renderer_crashed(OnRendererCrashed, nullptr);
+
+  std::thread([] {
+    std::this_thread::sleep_for(std::chrono::seconds(45));
+    if (!g_done.load()) {
+      Fail("timeout");
+    }
+  }).detach();
+
