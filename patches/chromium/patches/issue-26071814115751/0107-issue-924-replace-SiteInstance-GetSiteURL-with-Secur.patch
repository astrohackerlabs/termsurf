     if (rfh->GetSiteInstance()) {
-      site_url = rfh->GetSiteInstance()->GetSiteURL().spec();
+      site_url = rfh->GetSiteInstance()->GetSecurityPrincipal().GetDeprecatedSiteURL().spec();
     }
     const bool pdf_related =
         rfh->GetLastCommittedURL().spec().find(
@@ -170,7 +170,7 @@ void LogIssue794InputFrames(const char* tag,
 std::string Issue794FrameClassification(RenderFrameHost* rfh) {
   std::string site_url;
   if (rfh->GetSiteInstance()) {
-    site_url = rfh->GetSiteInstance()->GetSiteURL().spec();
+    site_url = rfh->GetSiteInstance()->GetSecurityPrincipal().GetDeprecatedSiteURL().spec();
   }
   const std::string url = rfh->GetLastCommittedURL().spec();
   if (!rfh->GetParent()) {
@@ -204,7 +204,7 @@ void LogIssue794KeyTarget(const char* tag,
     found = true;
     std::string site_url;
     if (rfh->GetSiteInstance()) {
-      site_url = rfh->GetSiteInstance()->GetSiteURL().spec();
+      site_url = rfh->GetSiteInstance()->GetSecurityPrincipal().GetDeprecatedSiteURL().spec();
     }
     LOG(INFO) << tag
               << " key-target frame_tree_node_id=" << rfh->GetFrameTreeNodeId()
