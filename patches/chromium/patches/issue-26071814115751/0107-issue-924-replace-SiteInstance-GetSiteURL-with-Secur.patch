From 04d92a23de6f5cb71bb2a04ed88d7f264f3a1436 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 11 Jul 2026 15:44:42 -0500
Subject: [PATCH 107/122] issue-924: replace SiteInstance::GetSiteURL with
 SecurityPrincipal

Chromium 150 removed SiteInstance::GetSiteURL; use
GetSecurityPrincipal().GetDeprecatedSiteURL() for logging and site checks.
---
 .../extensions/ts_extensions_browser_client.cc       |  2 +-
 .../libtermsurf_chromium/ts_browser_main_parts.cc    |  6 +++---
 .../libtermsurf_chromium/ts_mime_handler_binders.cc  |  2 +-
 .../libtermsurf_chromium/ts_pdf_browser_support.cc   | 12 ++++++------
 .../ts_pdf_help_bubble_handler_factory.cc            |  2 +-
 5 files changed, 12 insertions(+), 12 deletions(-)

diff --git a/content/libtermsurf_chromium/extensions/ts_extensions_browser_client.cc b/content/libtermsurf_chromium/extensions/ts_extensions_browser_client.cc
index 234d1842a3..aa4f75d745 100644
--- a/content/libtermsurf_chromium/extensions/ts_extensions_browser_client.cc
+++ b/content/libtermsurf_chromium/extensions/ts_extensions_browser_client.cc
@@ -428,7 +428,7 @@ void TsExtensionsBrowserClient::RegisterBrowserInterfaceBindersForFrame(
     const extensions::Extension* extension) const {
   LOG(INFO) << "[termsurf-pdf] extensions-frame-binder-invoked frame_url="
             << render_frame_host->GetLastCommittedURL() << " site_url="
-            << render_frame_host->GetSiteInstance()->GetSiteURL()
+            << render_frame_host->GetSiteInstance()->GetSecurityPrincipal().GetDeprecatedSiteURL()
             << " extension_id=" << extension->id() << " populate_called=1";
   extensions::PopulateExtensionFrameBinders(binder_map, render_frame_host,
                                             extension);
diff --git a/content/libtermsurf_chromium/ts_browser_main_parts.cc b/content/libtermsurf_chromium/ts_browser_main_parts.cc
