diff --git a/chrome/browser/resources/pdf/controller.ts b/chrome/browser/resources/pdf/controller.ts
index 2885372370..d733be0b32 100644
--- a/chrome/browser/resources/pdf/controller.ts
+++ b/chrome/browser/resources/pdf/controller.ts
@@ -3,6 +3,7 @@
 // found in the LICENSE file.
 
 import {assert} from 'chrome://resources/js/assert.js';
+import {loadTimeData} from 'chrome://resources/js/load_time_data.js';
 import {PromiseResolver} from 'chrome://resources/js/promise_resolver.js';
 
 // clang-format off
@@ -19,6 +20,39 @@ import {PinchPhase} from './viewport.js';
 
 type SaveRequestType = chrome.pdfViewerPrivate.SaveRequestType;
 
+function termsurfPdfPrintBridgeTraceEnabled(): boolean {
+  try {
+    return loadTimeData.getBoolean('termsurfPdfPrintBridgeTrace');
+  } catch {
+    return false;
+  }
+}
+
+function termsurfPdfPrintBridgeActivationId(): string {
+  return String((window as any).__termsurfPdfPrintBridgeActivationId || '');
+}
+
+function shouldTraceTermSurfPdfMessage(type: string): boolean {
+  return type === 'print' || type === 'rotateCounterclockwise' ||
+      type === 'rotateClockwise' || type === 'viewport';
+}
+
+function traceTermSurfPdfPrintBridge(
+    event: string, fields: Record<string, any> = {}) {
+  if (!termsurfPdfPrintBridgeTraceEnabled()) {
+    return;
+  }
+
+  const trace =
+      ((window as any).__termsurfPdfPrintBridgeTrace ||= [] as Array<any>);
+  trace.push({
+    source: 'controller.ts',
+    event,
+    activationId: termsurfPdfPrintBridgeActivationId(),
+    ...fields,
+  });
+}
+
 export interface MessageData {
   type: string;
   messageId?: string;
@@ -533,6 +567,17 @@ export class PluginController implements ContentController {
    */
   private postMessage_(message: PluginMessage) {
     assert(this.plugin_);
+    if (shouldTraceTermSurfPdfMessage(message.type)) {
+      traceTermSurfPdfPrintBridge('post-message', {
+        type: message.type,
+        hasPlugin: !!this.plugin_,
+        delayedMessagesActive: this.delayedMessages_ !== null,
+      });
+      const activationId = termsurfPdfPrintBridgeActivationId();
+      if (activationId) {
+        (message as any).termsurfActivationId = activationId;
+      }
+    }
     this.plugin_.postMessage(message);
   }
 
@@ -576,6 +621,10 @@ export class PluginController implements ContentController {
   }
 
   print() {
+    traceTermSurfPdfPrintBridge('controller-print', {
+      hasPlugin: !!this.plugin_,
+      delayedMessagesActive: this.delayedMessages_ !== null,
+    });
     this.postMessage_({type: 'print'});
   }
 
@@ -742,6 +791,10 @@ export class PluginController implements ContentController {
     assert(this.delayedMessages_ !== null);
     assert(this.plugin_);
     const delayedMessages = this.delayedMessages_;
+    traceTermSurfPdfPrintBridge('bind-message-handler', {
+      delayedCount: delayedMessages.length,
+      delayedTypes: delayedMessages.map(({message}) => String(message?.type)),
+    });
     this.delayedMessages_ = null;
 
     this.port_ = port;
diff --git a/content/libtermsurf_chromium/extensions/ts_component_extension_resource_manager.cc b/content/libtermsurf_chromium/extensions/ts_component_extension_resource_manager.cc
index 252bffa1e7..8ae248aad7 100644
