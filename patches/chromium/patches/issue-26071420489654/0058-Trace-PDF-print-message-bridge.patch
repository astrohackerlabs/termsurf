--- a/pdf/pdf_view_web_plugin.cc
+++ b/pdf/pdf_view_web_plugin.cc
@@ -158,6 +158,10 @@ constexpr std::string_view kChromeExtensionHost =
 constexpr char kTsPdfPrintInterceptSwitch[] = "termsurf-pdf-print-intercept";
 constexpr char kTsPdfPrintInterceptFileSwitch[] =
     "termsurf-pdf-print-intercept-file";
+constexpr char kTsPdfPrintBridgeTraceSwitch[] =
+    "termsurf-pdf-print-bridge-trace";
+constexpr char kTsPdfPrintBridgeTraceFileSwitch[] =
+    "termsurf-pdf-print-bridge-trace-file";
 
 bool Issue794InputTraceEnabled() {
   static const bool enabled =
@@ -186,6 +190,53 @@ std::optional<base::FilePath> GetTermSurfPdfPrintInterceptPath() {
   return base::FilePath::FromUTF8Unsafe(path);
 }
 
+std::optional<base::FilePath> GetTermSurfPdfPrintBridgeTracePath() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kTsPdfPrintBridgeTraceSwitch)) {
+    base::FilePath path =
+        command_line->GetSwitchValuePath(kTsPdfPrintBridgeTraceFileSwitch);
+    if (!path.empty()) {
+      return path;
+    }
+  }
+
+  const char* enabled = std::getenv("TERMSURF_PDF_PRINT_BRIDGE_TRACE");
+  const char* path = std::getenv("TERMSURF_PDF_PRINT_BRIDGE_TRACE_FILE");
+  if (!enabled || std::string_view(enabled) != "1" || !path ||
+      std::string_view(path).empty()) {
+    return std::nullopt;
+  }
+
+  return base::FilePath::FromUTF8Unsafe(path);
+}
+
+bool ShouldTraceTermSurfPdfMessage(std::string_view type) {
+  return type == "print" || type == "rotateCounterclockwise" ||
+         type == "rotateClockwise" || type == "viewport";
+}
+
+void TraceTermSurfPdfPrintBridge(const base::DictValue& message,
+                                 std::string_view event) {
+  const std::string* type = message.FindString("type");
+  if (!type || !ShouldTraceTermSurfPdfMessage(*type)) {
+    return;
+  }
+
+  std::optional<base::FilePath> trace_path =
+      GetTermSurfPdfPrintBridgeTracePath();
+  if (!trace_path) {
+    return;
+  }
+
+  const std::string* activation_id = message.FindString("termsurfActivationId");
+  const std::string line = base::StrCat(
+      {"pdf-print-bridge pid=", base::NumberToString(base::GetCurrentProcId()),
+       " source=pdf_view_web_plugin.cc event=", event, " type=", *type,
+       " activationId=", activation_id ? *activation_id : "", "\n"});
+  base::AppendToFile(*trace_path, line);
+}
+
 bool Issue794IsMousePointerEvent(blink::WebInputEvent::Type type) {
   return type == blink::WebInputEvent::Type::kMouseDown ||
          type == blink::WebInputEvent::Type::kMouseMove ||
@@ -1905,6 +1956,7 @@ PdfViewWebPlugin::CreateAssociatedURLLoader(
 }
 
 void PdfViewWebPlugin::OnMessage(const base::DictValue& message) {
+  TraceTermSurfPdfPrintBridge(message, "on-message");
 #if BUILDFLAG(ENABLE_PDF_INK2)
   if (ink_module_ && ink_module_->OnMessage(message)) {
     return;
@@ -1953,6 +2005,7 @@ void PdfViewWebPlugin::OnMessage(const base::DictValue& message) {
       });
 
   MessageHandler handler = kMessageHandlers.at(*message.FindString("type"));
+  TraceTermSurfPdfPrintBridge(message, "before-dispatch");
   (this->*handler)(message);
 }
 
@@ -2068,7 +2121,8 @@ void PdfViewWebPlugin::HandleHighlightTextFragmentsMessage(
   }
 }
 
-void PdfViewWebPlugin::HandlePrintMessage(const base::DictValue& /*message*/) {
+void PdfViewWebPlugin::HandlePrintMessage(const base::DictValue& message) {
+  TraceTermSurfPdfPrintBridge(message, "handle-print");
   Print();
 }
 
