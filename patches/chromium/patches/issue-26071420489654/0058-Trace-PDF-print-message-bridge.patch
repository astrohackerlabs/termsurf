+
 base::DictValue GetPdfStringsForTermSurf() {
   base::DictValue dict;
 
@@ -222,6 +235,8 @@ base::DictValue GetPdfStringsForTermSurf() {
   dict.Set("pdfTextAnnotationsEnabled", false);
   dict.Set("pdfUseShowSaveFilePicker", false);
   dict.Set("printingEnabled", IsTermSurfPdfPrintInterceptActive());
