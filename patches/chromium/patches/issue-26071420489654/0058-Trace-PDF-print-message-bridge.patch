@@ -357,18 +361,24 @@ void TsBrowserClient::AppendExtraCommandLineSwitches(
     return;
   }
 
-  std::optional<std::string> intercept_file =
-      GetTsPdfPrintInterceptFileFromEnv();
-  if (!intercept_file) {
-    return;
+  // Renderer processes do not reliably inherit the browser process environment.
+  // Forward the contained PDF print test guards explicitly.
+  std::optional<std::string> intercept_file = GetTsPdfTraceFileFromEnv(
+      "TERMSURF_PDF_PRINT_INTERCEPT", "TERMSURF_PDF_PRINT_INTERCEPT_FILE");
+  if (intercept_file) {
+    command_line->AppendSwitch(kTsPdfPrintInterceptSwitch);
+    command_line->AppendSwitchASCII(kTsPdfPrintInterceptFileSwitch,
+                                    *intercept_file);
   }
 
-  // Renderer processes do not reliably inherit the browser process environment.
-  // Forward the contained PDF print test guard explicitly so the PDF plugin can
-  // intercept before reaching native print.
-  command_line->AppendSwitch(kTsPdfPrintInterceptSwitch);
-  command_line->AppendSwitchASCII(kTsPdfPrintInterceptFileSwitch,
-                                  *intercept_file);
+  std::optional<std::string> bridge_trace_file =
+      GetTsPdfTraceFileFromEnv("TERMSURF_PDF_PRINT_BRIDGE_TRACE",
+                               "TERMSURF_PDF_PRINT_BRIDGE_TRACE_FILE");
+  if (bridge_trace_file) {
