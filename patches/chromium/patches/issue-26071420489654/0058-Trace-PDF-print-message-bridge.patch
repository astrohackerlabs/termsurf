@@ -38,6 +38,19 @@ bool IsTermSurfPdfPrintInterceptActive() {
   return path && !path->empty();
 }
 
+bool IsTermSurfPdfPrintBridgeTraceActive() {
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> enabled =
+      env->GetVar("TERMSURF_PDF_PRINT_BRIDGE_TRACE");
+  if (!enabled || *enabled != "1") {
+    return false;
+  }
+
+  std::optional<std::string> path =
+      env->GetVar("TERMSURF_PDF_PRINT_BRIDGE_TRACE_FILE");
+  return path && !path->empty();
+}
+
 void AddPdfString(ui::TemplateReplacements* replacements,
                   const char* name,
                   int resource_id) {
@@ -213,6 +226,8 @@ void PopulatePdfTemplateReplacements(ui::TemplateReplacements* replacements) {
   (*replacements)["pdfOopifEnabled"] = "";
   (*replacements)["printingEnabled"] =
       IsTermSurfPdfPrintInterceptActive() ? "true" : "false";
+  (*replacements)["termsurfPdfPrintBridgeTrace"] =
+      IsTermSurfPdfPrintBridgeTraceActive() ? "true" : "false";
 
   webui::SetLoadTimeDataDefaults(l10n_util::GetApplicationLocale(std::string()),
                                  replacements);
