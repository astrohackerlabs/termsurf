+bool TsBrowserMainParts::NavigationAction(void* wc_handle,
+                                          const std::string& action) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab || !tab->shell || !tab->tab_observer) {
+    return false;
+  }
+  WebContents* web_contents = tab->shell->web_contents();
+  NavigationController& controller = web_contents->GetController();
+  if (action == "back") {
+    if (tab->tab_observer->renderer_crashed() || !controller.CanGoBack()) {
+      return false;
+    }
+    controller.GoBack();
+  } else if (action == "forward") {
+    if (tab->tab_observer->renderer_crashed() || !controller.CanGoForward()) {
+      return false;
+    }
+    controller.GoForward();
+  } else if (action == "refresh") {
+    if (!tab->tab_observer->CanRefresh()) {
+      return false;
+    }
+    controller.Reload(content::ReloadType::NORMAL, false);
+  } else {
+    return false;
+  }
+  tab->tab_observer->NotifyNavigationState();
+  return true;
+#else
+  return false;
+#endif
+}
+
+bool TsBrowserMainParts::TestCrashCurrentPage(void* wc_handle) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab || !tab->shell) {
+    return false;
+  }
+  WebContents* web_contents = tab->shell->web_contents();
+  if (!web_contents) {
+    return false;
+  }
+  RenderFrameHost* main_frame = web_contents->GetPrimaryMainFrame();
+  if (!main_frame || !main_frame->GetProcess()) {
+    return false;
+  }
+  return main_frame->GetProcess()->Shutdown(0);
+#else
+  return false;
+#endif
+}
+
+bool TsBrowserMainParts::TestExecuteJavaScript(void* wc_handle,
+                                               const std::string& script) {
+#if BUILDFLAG(IS_MAC)
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  TabState* tab = FindTab(wc_handle);
+  if (!tab || !tab->shell) {
+    return false;
+  }
+  WebContents* web_contents = tab->shell->web_contents();
+  if (!web_contents || !web_contents->GetPrimaryMainFrame()) {
+    return false;
+  }
+  web_contents->GetPrimaryMainFrame()->ExecuteJavaScriptWithUserGestureForTests(
+      base::UTF8ToUTF16(script), base::NullCallback(),
+      ISOLATED_WORLD_ID_GLOBAL);
+  return true;
+#else
+  return false;
+#endif
