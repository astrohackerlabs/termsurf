+      break;
+
+    case Step::kWaitForwardSameDocument:
+      if (Contains(g.a.url, "/a2#state") &&
+          Contains(g.a.title,
+                   ("A2 state reload=" + std::to_string(g.expected_reload))
+                       .c_str()) &&
+          NavIs(g.a, true, false, true) && BUnchanged()) {
+        g.same_document = true;
+        g.step = Step::kRefresh;
+        if (!ts_navigation_action(g.a.wc, "refresh")) {
+          Fail("semantic refresh action rejected");
+        }
+        g.expected_reload += 1;
+        g.step = Step::kWaitRefresh;
+      }
