+        if (!ts_test_crash_current_page(g.a.wc)) {
+          Fail("test crash hook rejected tab");
+        }
+        g.step = Step::kWaitCrash;
+      }
+      break;
+
+    case Step::kWaitCrash:
+      if (g.a.crashed && NavIs(g.a, false, false, true) && BUnchanged()) {
+        g.step = Step::kRecoverRefresh;
+        if (!ts_navigation_action(g.a.wc, "refresh")) {
+          Fail("semantic refresh rejected crashed reloadable tab");
+        }
+        g.expected_reload += 1;
+        g.step = Step::kWaitRecovery;
+      }
+      break;
+
+    case Step::kWaitRecovery:
+      if (Contains(g.a.url, "/a2#state") &&
+          Contains(g.a.title,
+                   ("A2 state reload=" + std::to_string(g.expected_reload))
+                       .c_str()) &&
+          NavIs(g.a, true, false, true) && BUnchanged()) {
+        g.crash_recovery = true;
+        g.isolation = true;
+        if (!g.cleanup_scheduled) {
+          g.cleanup_scheduled = true;
+          g.step = Step::kCleanup;
+          ts_post_task(DoCleanupAndFinish, nullptr);
+        }
+      }
+      break;
+
+    case Step::kNavigateA2:
+    case Step::kBackToA1:
+    case Step::kDisabledBack:
+    case Step::kForwardToA2:
+    case Step::kPushState:
+    case Step::kBackSameDocument:
+    case Step::kForwardSameDocument:
+    case Step::kRefresh:
+    case Step::kCrash:
+    case Step::kRecoverRefresh:
+    case Step::kCleanup:
+    case Step::kDone:
+      break;
+  }
