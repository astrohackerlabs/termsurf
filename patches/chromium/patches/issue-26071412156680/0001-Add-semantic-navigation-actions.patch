diff --git a/content/libtermsurf_chromium/smoke-test/run-navigation-actions-smoke.sh b/content/libtermsurf_chromium/smoke-test/run-navigation-actions-smoke.sh
new file mode 100755
index 0000000000..36087625f5
--- /dev/null
+++ b/content/libtermsurf_chromium/smoke-test/run-navigation-actions-smoke.sh
@@ -0,0 +1,125 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+CHROMIUM_SRC="$(cd "$SCRIPT_DIR/../../.." && pwd)"
+OUT_DIR="${CHROMIUM_OUT_DIR:-$CHROMIUM_SRC/out/Default}"
+TEST_BIN="$OUT_DIR/libtermsurf_chromium_test"
+
+if [[ ! -x "$TEST_BIN" ]]; then
+  echo "missing executable: $TEST_BIN" >&2
+  echo "build it with: autoninja -C $OUT_DIR libtermsurf_chromium_test" >&2
+  exit 1
+fi
+
+TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/termsurf-chromium-nav.XXXXXX")"
+PORT_FILE="$TMP_DIR/port"
+
+cleanup() {
+  if [[ -n "${SERVER_PID:-}" ]]; then
+    kill "$SERVER_PID" 2>/dev/null || true
+    wait "$SERVER_PID" 2>/dev/null || true
+  fi
+  rm -rf "$TMP_DIR"
+}
+trap cleanup EXIT
+
+python3 - "$PORT_FILE" <<'PY' &
+import http.server
+import socketserver
+import sys
+
+port_file = sys.argv[1]
+counts = {}
+
+def page(label, variant, count):
+    if variant == "a2":
+        return f"""<!doctype html>
+<meta charset='utf-8'>
+<script>
+window.reloadCount = {count};
+function setBaseTitle() {{
+  document.title = location.hash === '#state'
+    ? 'A2 state reload=' + window.reloadCount
+    : 'A2 base reload=' + window.reloadCount;
+}}
+window.addEventListener('popstate', setBaseTitle);
+window.addEventListener('hashchange', setBaseTitle);
+window.addEventListener('pageshow', setBaseTitle);
+setBaseTitle();
+</script>
+<body>A2 reload {count}</body>
+"""
+    return f"""<!doctype html>
+<meta charset='utf-8'>
+<script>
+window.reloadCount = {count};
+document.title = '{label} reload=' + window.reloadCount;
+</script>
+<body>{label} reload {count}</body>
+"""
+
+class Handler(http.server.BaseHTTPRequestHandler):
+    protocol_version = "HTTP/1.1"
+
+    def do_GET(self):
+        path = self.path.split("?", 1)[0].split("#", 1)[0]
+        if path not in ("/a1", "/a2", "/b1"):
+            self.send_response(404)
+            self.send_header("Content-Length", "0")
+            self.end_headers()
+            return
+        counts[path] = counts.get(path, 0) + 1
+        label = {" /a1": "A1"}.get(path)
+        if path == "/a1":
+            body = page("A1", "plain", counts[path])
+        elif path == "/b1":
+            body = page("B1", "plain", counts[path])
+        else:
+            body = page("A2", "a2", counts[path])
+        data = body.encode("utf-8")
+        self.send_response(200)
+        self.send_header("Content-Type", "text/html; charset=utf-8")
+        self.send_header("Cache-Control", "no-store")
+        self.send_header("Content-Length", str(len(data)))
+        self.end_headers()
+        self.wfile.write(data)
+
+    def log_message(self, fmt, *args):
+        return
+
+class Server(socketserver.ThreadingMixIn, http.server.HTTPServer):
+    daemon_threads = True
+    allow_reuse_address = True
+
+server = Server(("127.0.0.1", 0), Handler)
+with open(port_file, "w", encoding="utf-8") as f:
+    f.write(str(server.server_address[1]))
+server.serve_forever()
+PY
+SERVER_PID=$!
+
+for _ in {1..100}; do
+  [[ -s "$PORT_FILE" ]] && break
+  sleep 0.05
+done
+
+if [[ ! -s "$PORT_FILE" ]]; then
+  echo "fixture server did not start" >&2
+  exit 1
+fi
+
+PORT="$(cat "$PORT_FILE")"
+export TERMSURF_CHROMIUM_SMOKE_A1_URL="http://a.test:$PORT/a1"
+export TERMSURF_CHROMIUM_SMOKE_A2_URL="http://a.test:$PORT/a2"
+export TERMSURF_CHROMIUM_SMOKE_B1_URL="http://b.test:$PORT/b1"
+
+"$TEST_BIN" \
+  --user-data-dir="$TMP_DIR/profile" \
+  --host-resolver-rules="MAP *.test 127.0.0.1" \
+  --no-sandbox \
+  --disable-gpu \
+  --disable-software-rasterizer \
+  --disable-extensions \
+  --disable-background-networking \
+  --disable-component-update
diff --git a/content/libtermsurf_chromium/test_main.cc b/content/libtermsurf_chromium/test_main.cc
index 36b3cdc114..9addff9a54 100644
--- a/content/libtermsurf_chromium/test_main.cc
+++ b/content/libtermsurf_chromium/test_main.cc
@@ -1,17 +1,486 @@
 // Copyright 2025 TermSurf
-// Minimal test: initialize libtermsurf_chromium and quit.
+// Semantic navigation smoke for libtermsurf_chromium.
 
-#include <stdio.h>
 #include "content/libtermsurf_chromium/libtermsurf_chromium.h"
 
-static void on_initialized(void* user_data) {
-  printf("[test_main] Chromium initialized, quitting.\n");
+#include <stdlib.h>
+#include <unistd.h>
+
+#include <atomic>
+#include <chrono>
+#include <cstring>
+#include <string>
+#include <thread>
+
+namespace {
+
+struct NavState {
+  bool back = false;
+  bool forward = false;
+  bool refresh = false;
+  bool seen = false;
+};
+
+struct Tab {
+  ts_web_contents_t wc = nullptr;
+  int tab_id = 0;
+  NavState nav;
+  std::string url;
+  std::string title;
+  bool crashed = false;
+};
+
+enum class Step {
+  kWaitInitial,
+  kNavigateA2,
+  kWaitA2,
+  kBackToA1,
+  kWaitBackA1,
+  kDisabledBack,
+  kForwardToA2,
+  kWaitForwardA2,
+  kPushState,
+  kWaitPushed,
+  kBackSameDocument,
+  kWaitBackSameDocument,
+  kForwardSameDocument,
+  kWaitForwardSameDocument,
+  kRefresh,
+  kWaitRefresh,
+  kCrash,
+  kWaitCrash,
+  kRecoverRefresh,
+  kWaitRecovery,
+  kCleanup,
+  kDone,
+};
+
+struct Smoke {
+  Tab a;
+  Tab b;
+  ts_browser_context_t ctx = nullptr;
+  Step step = Step::kWaitInitial;
+  std::string a1_url;
+  std::string a2_url;
+  std::string b1_url;
+  int expected_reload = 1;
+  bool initial_disabled = false;
+  bool push_delay_elapsed = false;
+  bool back = false;
+  bool forward = false;
+  bool refresh = false;
+  bool capabilities = false;
+  bool disabled = false;
+  bool isolation = false;
+  bool same_document = false;
+  bool crash_recovery = false;
+  bool cleanup = false;
+  bool cleanup_scheduled = false;
+};
+
+Smoke* g_smoke = new Smoke;
+#define g (*g_smoke)
+std::atomic<bool> g_done(false);
+
+bool Contains(const std::string& value, const char* needle) {
+  return value.find(needle) != std::string::npos;
+}
+
+bool IsA(ts_web_contents_t wc) {
+  return wc && g.a.wc == wc;
+}
+
+bool IsB(ts_web_contents_t wc) {
+  return wc && g.b.wc == wc;
+}
+
+Tab* TabFor(ts_web_contents_t wc) {
+  if (IsA(wc)) {
+    return &g.a;
+  }
+  if (IsB(wc)) {
+    return &g.b;
+  }
+  if (!g.a.wc) {
+    return &g.a;
+  }
+  if (!g.b.wc) {
+    return &g.b;
+  }
+  return nullptr;
+}
+
+bool NavIs(const Tab& tab, bool back, bool forward, bool refresh) {
+  return tab.nav.seen && tab.nav.back == back && tab.nav.forward == forward &&
+         tab.nav.refresh == refresh;
+}
+
+int ExtractReloadCount(const std::string& title) {
+  const std::string marker = "reload=";
+  size_t pos = title.find(marker);
+  if (pos == std::string::npos) {
+    return 0;
+  }
+  pos += marker.size();
+  int value = 0;
+  while (pos < title.size() && title[pos] >= '0' && title[pos] <= '9') {
+    value = value * 10 + (title[pos] - '0');
+    ++pos;
+  }
+  return value;
+}
+
+void WriteLine(int fd, const std::string& line) {
+  std::string output = line + "\n";
+  ssize_t ignored = write(fd, output.data(), output.size());
+  (void)ignored;
+}
+
+void Fail(const char* message) {
+  WriteLine(STDERR_FILENO,
+            "NAVIGATION_ACTIONS_SMOKE_FAIL engine=chromium step=" +
+                std::to_string(static_cast<int>(g.step)) + " message=" +
+                std::string(message ? message : "") + " a_url=" + g.a.url +
+                " a_title=" + g.a.title + " a_nav=" +
+                std::to_string(g.a.nav.back ? 1 : 0) + "/" +
+                std::to_string(g.a.nav.forward ? 1 : 0) + "/" +
+                std::to_string(g.a.nav.refresh ? 1 : 0) + " b_url=" +
+                g.b.url + " b_title=" + g.b.title + " b_nav=" +
+                std::to_string(g.b.nav.back ? 1 : 0) + "/" +
+                std::to_string(g.b.nav.forward ? 1 : 0) + "/" +
+                std::to_string(g.b.nav.refresh ? 1 : 0));
+  g_done = true;
+  _Exit(1);
+}
+
+void Finish() {
+  WriteLine(STDOUT_FILENO,
+            "NAVIGATION_ACTIONS_SMOKE_PASS engine=chromium tabs=2 back=" +
+                std::to_string(g.back ? 1 : 0) + " forward=" +
+                std::to_string(g.forward ? 1 : 0) + " refresh=" +
+                std::to_string(g.refresh ? 1 : 0) + " capabilities=" +
+                std::to_string(g.capabilities ? 1 : 0) + " disabled=" +
+                std::to_string(g.disabled ? 1 : 0) + " isolation=" +
+                std::to_string(g.isolation ? 1 : 0) + " same_document=" +
+                std::to_string(g.same_document ? 1 : 0) +
+                " crash_recovery=" +
+                std::to_string(g.crash_recovery ? 1 : 0) + " cleanup=" +
+                std::to_string(g.cleanup ? 1 : 0));
+  g_done = true;
   ts_quit();
 }
 
+void Advance();
+
+void DoCleanupAndFinish(void*) {
+  ts_destroy_web_contents(g.a.wc);
+  ts_destroy_web_contents(g.b.wc);
+  g.cleanup = true;
+  g.step = Step::kDone;
+  Finish();
+}
+
+void MarkPushDelayElapsed(void*) {
+  g.push_delay_elapsed = true;
+  Advance();
+}
+
+void PostPushDelay() {
+  std::thread([] {
+    std::this_thread::sleep_for(std::chrono::milliseconds(250));
+    ts_post_task(MarkPushDelayElapsed, nullptr);
+  }).detach();
+}
+
+void OnInitialized(void*) {
+  g.ctx = ts_create_incognito_browser_context();
+  if (!g.ctx) {
+    Fail("missing browser context");
+  }
+
+  g.a.wc = ts_create_web_contents(g.ctx, g.a1_url.c_str(), 800, 600, true);
+  g.b.wc = ts_create_web_contents(g.ctx, g.b1_url.c_str(), 800, 600, true);
+  if (!g.a.wc || !g.b.wc || g.a.wc == g.b.wc) {
+    Fail("failed to create two tabs");
+  }
+  Advance();
+}
+
+void OnTabReady(ts_web_contents_t wc, int tab_id, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->tab_id = tab_id;
+  Advance();
+}
+
+void OnNavigationState(ts_web_contents_t wc,
+                       bool can_go_back,
+                       bool can_go_forward,
+                       bool can_refresh,
+                       void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->nav = {can_go_back, can_go_forward, can_refresh, true};
+  Advance();
+}
+
+void OnUrlChanged(ts_web_contents_t wc, const char* url, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->url = url ? url : "";
+  Advance();
+}
+
+void OnTitleChanged(ts_web_contents_t wc, const char* title, void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->wc = wc;
+  tab->title = title ? title : "";
+  Advance();
+}
+
+void OnRendererCrashed(ts_web_contents_t wc,
+                       const char*,
+                       int,
+                       const char*,
+                       bool can_reload,
+                       void*) {
+  Tab* tab = TabFor(wc);
+  if (!tab) {
+    return;
+  }
+  tab->crashed = true;
+  if (!can_reload) {
+    Fail("crash callback reported non-reloadable tab");
+  }
+  Advance();
+}
+
+bool BUnchanged() {
+  return Contains(g.b.url, "/b1") && Contains(g.b.title, "B1 reload=1") &&
+         NavIs(g.b, false, false, true) && !g.b.crashed;
+}
+
+void Advance() {
+  switch (g.step) {
+    case Step::kWaitInitial:
+      if (g.a.nav.seen && g.b.nav.seen && g.a.tab_id > 0 && g.b.tab_id > 0) {
+        if (!g.initial_disabled) {
+          if (!NavIs(g.a, false, false, false) ||
+              !NavIs(g.b, false, false, false)) {
+            Fail("initial precommit navigation state was not disabled");
+          }
+          g.initial_disabled = true;
+        }
+        if (Contains(g.a.url, "/a1") && Contains(g.a.title, "A1 reload=1") &&
+            NavIs(g.a, false, false, true) && BUnchanged()) {
+          g.capabilities = true;
+          g.step = Step::kNavigateA2;
+          ts_load_url(g.a.wc, g.a2_url.c_str());
+          g.step = Step::kWaitA2;
+        }
+      }
+      break;
+
+    case Step::kWaitA2:
+      if (Contains(g.a.url, "/a2") &&
+          Contains(g.a.title, "A2 base reload=") &&
+          NavIs(g.a, true, false, true) && BUnchanged()) {
+        g.step = Step::kBackToA1;
+        if (!ts_navigation_action(g.a.wc, "back")) {
+          Fail("semantic back action rejected");
+        }
+        g.step = Step::kWaitBackA1;
+      }
+      break;
+
+    case Step::kWaitBackA1:
+      if (Contains(g.a.url, "/a1") &&
+          NavIs(g.a, false, true, true) && BUnchanged()) {
+        g.back = true;
+        g.step = Step::kDisabledBack;
+        const std::string before_url = g.a.url;
+        const std::string before_title = g.a.title;
+        if (ts_navigation_action(g.a.wc, "back")) {
+          Fail("disabled back action was accepted");
+        }
+        if (g.a.url != before_url || g.a.title != before_title) {
+          Fail("disabled back action mutated the page");
+        }
+        g.disabled = true;
+        g.step = Step::kForwardToA2;
+        if (!ts_navigation_action(g.a.wc, "forward")) {
+          Fail("semantic forward action rejected");
+        }
+        g.step = Step::kWaitForwardA2;
+      }
+      break;
+
+    case Step::kWaitForwardA2:
+      if (Contains(g.a.url, "/a2") &&
+          Contains(g.a.title, "A2 base reload=") &&
+          NavIs(g.a, true, false, true) && BUnchanged()) {
+        g.forward = true;
+        g.expected_reload = ExtractReloadCount(g.a.title);
+        g.step = Step::kPushState;
+        if (!ts_test_execute_javascript(
+                g.a.wc,
+                "(() => {"
+                "const match = document.title.match(/reload=(\\d+)/);"
+                "const reload = match ? match[1] : 'unknown';"
+                "const update = () => { document.title = 'A2 ' + "
+                "(location.hash === '#state' ? 'state' : 'base') + "
+                "' reload=' + reload; };"
+                "window.addEventListener('popstate', update);"
+                "history.pushState({ termsurf: 'state' }, '', "
+                "location.pathname + location.search + '#state');"
+                "update();"
+                "})()")) {
+          Fail("pushState script rejected");
+        }
+        g.push_delay_elapsed = false;
+        PostPushDelay();
+        g.step = Step::kWaitPushed;
+      }
+      break;
+
+    case Step::kWaitPushed:
+      if (g.push_delay_elapsed && Contains(g.a.url, "/a2#state") &&
+          Contains(g.a.title,
+                   ("A2 state reload=" + std::to_string(g.expected_reload))
+                       .c_str()) &&
