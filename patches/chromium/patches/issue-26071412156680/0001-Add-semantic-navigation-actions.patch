     g_on_title_changed(wc_handle, title, g_on_title_changed_data);
@@ -302,6 +319,27 @@ void ts_load_url(ts_web_contents_t wc, const char* url) {
   g_main_parts->NavigateTab(wc, url);
 }
 
+bool ts_navigation_action(ts_web_contents_t wc, const char* action) {
+  if (!g_main_parts || !action) {
+    return false;
+  }
+  return g_main_parts->NavigationAction(wc, action);
+}
+
+bool ts_test_crash_current_page(ts_web_contents_t wc) {
