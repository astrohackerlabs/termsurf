+bool TsPdfComponentExtensionResourceManager::EnsurePdfResourcesPackLoaded()
+    const {
+  base::FilePath assets_path;
+  if (!base::PathService::Get(base::DIR_ASSETS, &assets_path)) {
+    return false;
+  }
+
+  base::FilePath pdf_resources_pack =
+      assets_path.AppendASCII(kPdfResourcesPackPath);
+  ui::ResourceBundle::GetSharedInstance().AddDataPackFromPath(
+      pdf_resources_pack, ui::kScaleFactorNone);
+
+  int known_resource_id = 0;
+  return IsComponentExtensionResource(
+             base::FilePath::FromUTF8Unsafe(kKnownPdfResourcePath),
+             &known_resource_id) &&
+         ui::ResourceBundle::GetSharedInstance().HasDataResource(
+             known_resource_id);
+}
