+#include "services/network/public/cpp/url_loader_completion_status.h"
+#include "services/network/public/mojom/url_loader.mojom.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+#include "ui/base/resource/resource_bundle.h"
+#include "ui/base/template_expressions.h"
+#include "url/gurl.h"
+
+namespace content {
+namespace {
+
+constexpr char kPdfExtensionId[] = "mhjfbmdgcfjbbpaeojofohoefgiehjai";
+
+std::string MimeTypeForPath(std::string_view path) {
+  if (base::EndsWith(path, ".html", base::CompareCase::INSENSITIVE_ASCII)) {
+    return "text/html";
+  }
+  if (base::EndsWith(path, ".css", base::CompareCase::INSENSITIVE_ASCII)) {
+    return "text/css";
+  }
+  if (base::EndsWith(path, ".js", base::CompareCase::INSENSITIVE_ASCII) ||
+      base::EndsWith(path, ".mjs", base::CompareCase::INSENSITIVE_ASCII)) {
+    return "text/javascript";
+  }
+  if (base::EndsWith(path, ".wasm", base::CompareCase::INSENSITIVE_ASCII)) {
+    return "application/wasm";
+  }
+  if (base::EndsWith(path, ".svg", base::CompareCase::INSENSITIVE_ASCII)) {
+    return "image/svg+xml";
+  }
+  return "application/octet-stream";
+}
+
+std::string PathFromPdfViewerUrl(const GURL& url) {
+  std::string path(url.path());
+  if (!path.empty() && path.front() == '/') {
+    path.erase(0, 1);
+  }
+  return path;
+}
+
+network::mojom::URLResponseHeadPtr ResponseHeadForMimeType(
+    const std::string& mime_type) {
+  auto response = network::mojom::URLResponseHead::New();
+  response->mime_type = mime_type;
+  response->headers = base::MakeRefCounted<net::HttpResponseHeaders>(
+      base::StrCat({"HTTP/1.1 200 OK\nContent-Type: ", mime_type, "\n"}));
+  return response;
+}
+
+struct WriteData {
+  mojo::Remote<network::mojom::URLLoaderClient> client;
+  std::string data;
+  std::unique_ptr<mojo::DataPipeProducer> producer;
+};
+
+void OnWrite(std::unique_ptr<WriteData> write_data, MojoResult result) {
+  if (result != MOJO_RESULT_OK) {
+    write_data->client->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_FAILED));
+    return;
+  }
+
+  network::URLLoaderCompletionStatus status(net::OK);
+  status.encoded_data_length = write_data->data.size();
+  status.encoded_body_length = write_data->data.size();
+  status.decoded_body_length = write_data->data.size();
+  write_data->client->OnComplete(status);
+}
+
+class TsPdfViewerURLLoaderFactory
+    : public network::SelfDeletingURLLoaderFactory {
+ public:
+  TsPdfViewerURLLoaderFactory(
+      TsPdfComponentExtensionResourceManager* resource_manager,
+      mojo::PendingReceiver<network::mojom::URLLoaderFactory> receiver)
+      : network::SelfDeletingURLLoaderFactory(std::move(receiver)),
+        resource_manager_(resource_manager) {}
+
+  TsPdfViewerURLLoaderFactory(const TsPdfViewerURLLoaderFactory&) = delete;
+  TsPdfViewerURLLoaderFactory& operator=(const TsPdfViewerURLLoaderFactory&) =
+      delete;
+
+ private:
+  ~TsPdfViewerURLLoaderFactory() override = default;
+
+  void CreateLoaderAndStart(
+      mojo::PendingReceiver<network::mojom::URLLoader> loader,
+      int32_t request_id,
+      uint32_t options,
+      const network::ResourceRequest& request,
+      mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+      const net::MutableNetworkTrafficAnnotationTag& traffic_annotation)
+      override {
+    mojo::Remote<network::mojom::URLLoaderClient> client_remote(
+        std::move(client));
+
+    LOG(INFO) << "[issue-776-exp7] request url=" << request.url.spec();
+
+    if (!resource_manager_) {
+      LOG(INFO) << "[issue-776-exp7] rejected reason=no-resource-manager"
+                << " url=" << request.url.spec();
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_FAILED));
+      return;
+    }
+
+    if (!request.url.SchemeIs(extensions::kExtensionScheme)) {
+      LOG(INFO) << "[issue-776-exp7] rejected reason=wrong-scheme"
+                << " url=" << request.url.spec();
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_UNKNOWN_URL_SCHEME));
+      return;
+    }
+
+    if (request.url.host() != kPdfExtensionId) {
+      LOG(INFO) << "[issue-776-exp7] rejected reason=wrong-extension-id"
+                << " extension_id=" << request.url.host()
+                << " path=" << PathFromPdfViewerUrl(request.url);
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_BLOCKED_BY_CLIENT));
+      return;
+    }
+
+    std::string resource_path = PathFromPdfViewerUrl(request.url);
+    int resource_id = 0;
+    bool found = resource_manager_->IsComponentExtensionResource(
+        base::FilePath::FromUTF8Unsafe(resource_path), &resource_id);
+    if (!found) {
+      LOG(INFO) << "[issue-776-exp7] rejected reason=unknown-path"
+                << " extension_id=" << request.url.host()
+                << " path=" << resource_path;
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_FILE_NOT_FOUND));
+      return;
+    }
+
+    std::string mime_type = MimeTypeForPath(resource_path);
+    bool template_replacements_applied = false;
+    std::string_view raw_data =
+        ui::ResourceBundle::GetSharedInstance().GetRawDataResource(resource_id);
+    std::string data(raw_data);
+    const ui::TemplateReplacements* replacements =
+        resource_manager_->GetTemplateReplacementsForExtension(kPdfExtensionId);
+    if (replacements && mime_type == "text/html") {
+      data = ui::ReplaceTemplateExpressions(data, *replacements);
+      template_replacements_applied = true;
+    }
+
+    LOG(INFO) << "[issue-776-exp7] served extension_id=" << request.url.host()
+              << " path=" << resource_path << " id=" << resource_id
+              << " bytes=" << data.size() << " mime=" << mime_type
+              << " template_replacements="
+              << (template_replacements_applied ? "true" : "false")
+              << " bytes_kind=decoded";
+
+    mojo::ScopedDataPipeProducerHandle producer;
+    mojo::ScopedDataPipeConsumerHandle consumer;
+    if (CreateDataPipe(nullptr, producer, consumer) != MOJO_RESULT_OK) {
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_INSUFFICIENT_RESOURCES));
+      return;
+    }
+
+    client_remote->OnReceiveResponse(ResponseHeadForMimeType(mime_type),
+                                     std::move(consumer), std::nullopt);
+
+    auto write_data = std::make_unique<WriteData>();
+    write_data->client = std::move(client_remote);
+    write_data->data = std::move(data);
+    write_data->producer =
+        std::make_unique<mojo::DataPipeProducer>(std::move(producer));
+
+    mojo::DataPipeProducer* producer_ptr = write_data->producer.get();
+    std::string_view data_view(write_data->data);
+    producer_ptr->Write(
+        std::make_unique<mojo::StringDataSource>(
+            data_view, mojo::StringDataSource::AsyncWritingMode::
+                           STRING_STAYS_VALID_UNTIL_COMPLETION),
+        base::BindOnce(OnWrite, std::move(write_data)));
+  }
+
+  raw_ptr<TsPdfComponentExtensionResourceManager> resource_manager_;
+};
+
+}  // namespace
+
+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+CreateTsPdfViewerURLLoaderFactory(
+    TsPdfComponentExtensionResourceManager* resource_manager) {
+  mojo::PendingRemote<network::mojom::URLLoaderFactory> remote;
+  new TsPdfViewerURLLoaderFactory(resource_manager,
+                                  remote.InitWithNewPipeAndPassReceiver());
+  return remote;
+}
+
+}  // namespace content
