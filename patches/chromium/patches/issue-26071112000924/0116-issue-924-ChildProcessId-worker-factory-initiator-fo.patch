From c82a7c9493fac7615a82eb7bd7645d9d394d8b3f Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 11 Jul 2026 15:56:23 -0500
Subject: [PATCH 116/119] issue-924: ChildProcessId + worker factory initiator
 for PDF support

Pass request_initiator to worker main factories; use typed process IDs
for ProcessMap and CreateExtensionURLLoaderFactory.
---
 .../libtermsurf_chromium/ts_browser_client.cc |  4 +--
 .../ts_pdf_browser_support.cc                 | 25 +++++++++++++------
 .../ts_pdf_browser_support.h                  |  1 +
 3 files changed, 20 insertions(+), 10 deletions(-)

diff --git a/content/libtermsurf_chromium/ts_browser_client.cc b/content/libtermsurf_chromium/ts_browser_client.cc
index ef783aaedf..2a316c8990 100644
--- a/content/libtermsurf_chromium/ts_browser_client.cc
+++ b/content/libtermsurf_chromium/ts_browser_client.cc
@@ -217,8 +217,8 @@ void TsBrowserClient::RegisterNonNetworkWorkerMainResourceURLLoaderFactories(
     NonNetworkURLLoaderFactoryMap* factories) {
   ContentBrowserClient::RegisterNonNetworkWorkerMainResourceURLLoaderFactories(
       browser_context, request_initiator, request_destination, factories);
-  RegisterTsPdfExtensionWorkerMainResourceURLLoaderFactory(browser_context,
-                                                           factories);
+  RegisterTsPdfExtensionWorkerMainResourceURLLoaderFactory(
+      browser_context, request_initiator, factories);
 }
 
 void TsBrowserClient::RegisterNonNetworkServiceWorkerUpdateURLLoaderFactories(
diff --git a/content/libtermsurf_chromium/ts_pdf_browser_support.cc b/content/libtermsurf_chromium/ts_pdf_browser_support.cc
index 628ff3b220..0f2aa5f98b 100644
--- a/content/libtermsurf_chromium/ts_pdf_browser_support.cc
+++ b/content/libtermsurf_chromium/ts_pdf_browser_support.cc
@@ -23,6 +23,7 @@
 #include "content/libtermsurf_chromium/ts_plugin_response_interceptor_url_loader_throttle.h"
 #include "content/libtermsurf_chromium/ts_plugin_utils.h"
 #include "content/public/browser/browser_context.h"
+#include "content/public/common/child_process_id.h"
 #include "content/public/browser/child_process_security_policy.h"
 #include "content/public/browser/navigation_handle.h"
 #include "content/public/browser/navigation_throttle_registry.h"
@@ -314,13 +315,14 @@ CreateTsPdfExtensionNavigationURLLoaderFactory(
 
 void RegisterTsPdfExtensionWorkerMainResourceURLLoaderFactory(
     BrowserContext* browser_context,
+    const std::optional<url::Origin>& request_initiator,
     ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories) {
   LOG(INFO) << "[termsurf-pdf] extension-factory"
             << " scheme=chrome-extension type=worker-main";
   factories->emplace(
       extensions::kExtensionScheme,
       extensions::CreateExtensionWorkerMainResourceURLLoaderFactory(
-          browser_context));
+          browser_context, request_initiator));
 }
 
 void RegisterTsPdfExtensionServiceWorkerUpdateURLLoaderFactory(
@@ -341,9 +343,11 @@ void RegisterTsPdfExtensionSubresourceURLLoaderFactory(
     ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories) {
   LOG(INFO) << "[termsurf-pdf] extension-factory"
             << " scheme=chrome-extension type=subresource";
-  factories->emplace(extensions::kExtensionScheme,
-                     extensions::CreateExtensionURLLoaderFactory(
-                         render_process_id, render_frame_id));
+  factories->emplace(
+      extensions::kExtensionScheme,
+      extensions::CreateExtensionURLLoaderFactory(
+          content::ChildProcessId::FromUnsafeValue(render_process_id),
+          render_frame_id));
 
   RenderProcessHost* process_host =
       RenderProcessHost::FromID(render_process_id);
@@ -436,24 +440,29 @@ void MaybeActivateTsPdfSiteInstance(SiteInstance* site_instance) {
     return;
   }
 
-  const int process_id = site_instance->GetProcess()->GetDeprecatedID();
+  const content::ChildProcessId process_id =
+      site_instance->GetProcess()->GetID();
   extensions::ProcessMap::Get(browser_context)
       ->Insert(extension->id(), process_id);
   LOG(INFO) << "[termsurf-pdf] process-map-insert extension_id="
-            << extension->id() << " process_id=" << process_id
+            << extension->id()
+            << " process_id=" << process_id.GetUnsafeValue()
             << " site_url=" << site_instance->GetSecurityPrincipal().GetDeprecatedSiteURL();
 
   auto* renderer_startup_helper =
       extensions::RendererStartupHelperFactory::GetForBrowserContext(
           browser_context);
   LOG(INFO) << "[termsurf-pdf] pdf-process-map-helper extension_id="
-            << extension->id() << " process_id=" << process_id
+            << extension->id()
+            << " process_id=" << process_id.GetUnsafeValue()
             << " helper=" << (renderer_startup_helper != nullptr);
   if (renderer_startup_helper) {
     renderer_startup_helper->ActivateExtensionInProcess(
         *extension, site_instance->GetProcess());
     LOG(INFO) << "[termsurf-pdf] pdf-activate-request extension_id="
-              << extension->id() << " process_id=" << process_id << " called=1";
+              << extension->id()
+              << " process_id=" << process_id.GetUnsafeValue()
+              << " called=1";
   }
   // This grant is process-scoped. It is safe only because the process policy
   // above is restricted to the PDF component extension's site URL.
diff --git a/content/libtermsurf_chromium/ts_pdf_browser_support.h b/content/libtermsurf_chromium/ts_pdf_browser_support.h
index 3b0a3598e9..37bfc76728 100644
--- a/content/libtermsurf_chromium/ts_pdf_browser_support.h
+++ b/content/libtermsurf_chromium/ts_pdf_browser_support.h
@@ -75,6 +75,7 @@ CreateTsPdfExtensionNavigationURLLoaderFactory(
     FrameTreeNodeId frame_tree_node_id);
 void RegisterTsPdfExtensionWorkerMainResourceURLLoaderFactory(
     BrowserContext* browser_context,
+    const std::optional<url::Origin>& request_initiator,
     ContentBrowserClient::NonNetworkURLLoaderFactoryMap* factories);
 void RegisterTsPdfExtensionServiceWorkerUpdateURLLoaderFactory(
     BrowserContext* browser_context,
-- 
2.54.0

