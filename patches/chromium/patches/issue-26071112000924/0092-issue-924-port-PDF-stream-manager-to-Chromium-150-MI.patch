From 688cf53bc95bf268d832bf1c5c245c06f9a85821 Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Sat, 11 Jul 2026 13:45:56 -0500
Subject: [PATCH 092/119] issue-924: port PDF stream manager to Chromium 150
 MIME handler API

PdfViewerStreamManager removed upstream; use MimeHandlerStreamManager
with PdfHandlerStreamDelegate for OOPIF PDF streams.
---
 content/libtermsurf_chromium/BUILD.gn                 |  3 +--
 .../libtermsurf_chromium/ts_mime_handler_binders.cc   |  5 +++--
 .../libtermsurf_chromium/ts_pdf_stream_delegate.cc    |  9 +++++----
 ...plugin_response_interceptor_url_loader_throttle.cc | 11 +++++++----
 4 files changed, 16 insertions(+), 12 deletions(-)

diff --git a/content/libtermsurf_chromium/BUILD.gn b/content/libtermsurf_chromium/BUILD.gn
index 4b9027e46f..d6f073118c 100644
--- a/content/libtermsurf_chromium/BUILD.gn
+++ b/content/libtermsurf_chromium/BUILD.gn
@@ -7,8 +7,6 @@ import("//build/config/ui.gni")
 shared_library("libtermsurf_chromium") {
   testonly = true
   sources = [
-    "//chrome/browser/pdf/pdf_viewer_stream_manager.cc",
-    "//chrome/browser/pdf/pdf_viewer_stream_manager.h",
     "extensions/ts_browser_context_keyed_service_factories.cc",
     "extensions/ts_browser_context_keyed_service_factories.h",
     "extensions/ts_component_extension_resource_manager.cc",
@@ -111,6 +109,7 @@ shared_library("libtermsurf_chromium") {
     "//components/custom_handlers",
     "//components/keyed_service/content",
     "//components/keyed_service/core",
+    "//chrome/browser/pdf",
     "//components/pdf/browser",
     "//components/pdf/browser:interceptors",
     "//components/pdf/renderer",
diff --git a/content/libtermsurf_chromium/ts_mime_handler_binders.cc b/content/libtermsurf_chromium/ts_mime_handler_binders.cc
index f0fd85012a..bc20b42695 100644
--- a/content/libtermsurf_chromium/ts_mime_handler_binders.cc
+++ b/content/libtermsurf_chromium/ts_mime_handler_binders.cc
@@ -9,7 +9,8 @@
 #include <utility>
 
 #include "base/logging.h"
-#include "chrome/browser/pdf/pdf_viewer_stream_manager.h"
+#include "chrome/browser/pdf/pdf_handler_stream_delegate.h"
+#include "extensions/browser/mime_handler/mime_handler_stream_manager.h"
 #include "content/public/browser/render_frame_host.h"
 #include "content/public/browser/site_instance.h"
 #include "extensions/browser/api/mime_handler_private/mime_handler_private.h"
@@ -83,7 +84,7 @@ void BindTsMimeHandlerService(
   RenderFrameHost* embedder_host = render_frame_host->GetParent();
   auto* manager =
       embedder_host
-          ? pdf::PdfViewerStreamManager::FromRenderFrameHost(embedder_host)
+          ? extensions::mime_handler::MimeHandlerStreamManager::FromRenderFrameHost(embedder_host)
           : nullptr;
   base::WeakPtr<extensions::StreamContainer> stream =
       manager && embedder_host ? manager->GetStreamContainer(embedder_host)
diff --git a/content/libtermsurf_chromium/ts_pdf_stream_delegate.cc b/content/libtermsurf_chromium/ts_pdf_stream_delegate.cc
index fccd87a64e..4c94f66eed 100644
--- a/content/libtermsurf_chromium/ts_pdf_stream_delegate.cc
+++ b/content/libtermsurf_chromium/ts_pdf_stream_delegate.cc
@@ -12,7 +12,8 @@
 #include "base/memory/weak_ptr.h"
 #include "base/no_destructor.h"
 #include "base/numerics/safe_conversions.h"
-#include "chrome/browser/pdf/pdf_viewer_stream_manager.h"
+#include "chrome/browser/pdf/pdf_handler_stream_delegate.h"
+#include "extensions/browser/mime_handler/mime_handler_stream_manager.h"
 #include "chrome/grit/pdf_resources.h"
 #include "content/public/browser/document_user_data.h"
 #include "content/public/browser/navigation_handle.h"
@@ -75,7 +76,7 @@ std::optional<GURL> TsPdfStreamDelegate::MapToOriginalUrl(
   base::WeakPtr<extensions::StreamContainer> stream;
   RenderFrameHost* embedder_parent_frame = embedder_frame->GetParent();
   if (chrome_pdf::features::IsOopifPdfEnabled() && embedder_parent_frame) {
-    auto* manager = pdf::PdfViewerStreamManager::FromWebContents(contents);
+    auto* manager = extensions::mime_handler::MimeHandlerStreamManager::FromWebContents(contents);
     if (manager) {
       stream = manager->GetStreamContainer(embedder_parent_frame);
     }
@@ -156,7 +157,7 @@ bool TsPdfStreamDelegate::MaybeDeleteSandboxedStream(
     return false;
   }
 
-  auto* manager = pdf::PdfViewerStreamManager::FromWebContents(web_contents);
+  auto* manager = extensions::mime_handler::MimeHandlerStreamManager::FromWebContents(web_contents);
   if (!manager ||
       !manager->ContainsUnclaimedStreamInfo(frame_tree_node_id)) {
     return false;
@@ -179,7 +180,7 @@ bool TsPdfStreamDelegate::ShouldAllowPdfFrameNavigation(
     return true;
   }
 
-  auto* manager = pdf::PdfViewerStreamManager::FromWebContents(
+  auto* manager = extensions::mime_handler::MimeHandlerStreamManager::FromWebContents(
       navigation_handle->GetWebContents());
   if (!manager) {
     return true;
diff --git a/content/libtermsurf_chromium/ts_plugin_response_interceptor_url_loader_throttle.cc b/content/libtermsurf_chromium/ts_plugin_response_interceptor_url_loader_throttle.cc
index 3de46f1a83..8bc1e21673 100644
--- a/content/libtermsurf_chromium/ts_plugin_response_interceptor_url_loader_throttle.cc
+++ b/content/libtermsurf_chromium/ts_plugin_response_interceptor_url_loader_throttle.cc
@@ -1,3 +1,4 @@
+#include <memory>
 // Copyright 2025 TermSurf
 // Use of this source code is governed by a BSD-style license that can be
 // found in the LICENSE file.
@@ -13,7 +14,8 @@
 #include "base/numerics/safe_conversions.h"
 #include "base/unguessable_token.h"
 #include "base/uuid.h"
-#include "chrome/browser/pdf/pdf_viewer_stream_manager.h"
+#include "chrome/browser/pdf/pdf_handler_stream_delegate.h"
+#include "extensions/browser/mime_handler/mime_handler_stream_manager.h"
 #include "components/pdf/common/constants.h"
 #include "content/libtermsurf_chromium/ts_plugin_utils.h"
 #include "content/public/browser/browser_task_traits.h"
@@ -126,10 +128,11 @@ bool AddPdfStreamContainer(
 
   LOG(INFO) << "[termsurf-pdf] interceptor-manager-created "
             << "frame_tree_node_id=" << frame_tree_node_id;
-  pdf::PdfViewerStreamManager::Create(web_contents);
-  pdf::PdfViewerStreamManager::FromWebContents(web_contents)
+  extensions::mime_handler::MimeHandlerStreamManager::Create(web_contents);
+  extensions::mime_handler::MimeHandlerStreamManager::FromWebContents(web_contents)
       ->AddStreamContainer(frame_tree_node_id, internal_id,
-                           std::move(stream_container));
+                           std::move(stream_container),
+                           std::make_unique<pdf::PdfHandlerStreamDelegate>());
   LOG(INFO) << "[termsurf-pdf] stream-container-added frame_tree_node_id="
             << frame_tree_node_id << " internal_id=" << internal_id
             << " original_url=" << original_url
-- 
2.54.0

