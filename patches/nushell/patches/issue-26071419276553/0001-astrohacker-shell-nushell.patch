From 5e14c7ec243c5b37ea668e8a88c3c51024dfd4cd Mon Sep 17 00:00:00 2001
From: "Ryan X. Charles" <ryan@ryanxcharles.com>
Date: Tue, 14 Jul 2026 15:08:58 -0500
Subject: [PATCH 2/2] astrohacker: honor configured alt shell

Shift+Tab now follows SHANNON_ALT_MODE for bash or zsh.

Keep highlighting and binary mode tests aligned with the product config.
---
 crates/nu-cli/src/repl.rs | 48 ++++++++++++++++++++++++++++++++++-----
 1 file changed, 42 insertions(+), 6 deletions(-)

diff --git a/crates/nu-cli/src/repl.rs b/crates/nu-cli/src/repl.rs
index 98cbd99..286e56e 100644
--- a/crates/nu-cli/src/repl.rs
+++ b/crates/nu-cli/src/repl.rs
@@ -642,7 +642,7 @@ fn loop_iteration(ctx: LoopContext) -> (bool, Stack, Reedline) {
                 .get_env_var(engine_state, "SHANNON_MODE")
                 .and_then(|v| v.as_str().ok().map(str::to_string))
                 .unwrap_or_else(|| "nu".to_string());
-            if shannon_mode == "bash" {
+            if shannon_mode == "bash" || shannon_mode == "zsh" {
                 Box::new(crate::bash_highlight::BashHighlighter::new(&config))
                     as Box<dyn reedline::Highlighter>
             } else if shannon_mode != "nu" {
@@ -1338,16 +1338,52 @@ fn switch_shannon_mode(engine_state: &EngineState, stack: &mut Stack) {
         .get_env_var(engine_state, "SHANNON_MODE")
         .and_then(|v| v.as_str().ok().map(str::to_string))
         .unwrap_or_else(|| "nu".to_string());
-    let modes = ["nu", "bash"];
+    let alt = stack
+        .get_env_var(engine_state, "SHANNON_ALT_MODE")
+        .and_then(|v| v.as_str().ok().map(str::to_string))
+        .unwrap_or_else(|| "zsh".to_string());
+    stack.add_env_var(
+        "SHANNON_MODE".to_string(),
+        Value::string(next_shannon_mode(&current, &alt), Span::unknown()),
+    );
+}
+
+fn next_shannon_mode(current: &str, alt: &str) -> String {
+    let alt = match alt {
+        "bash" | "zsh" => alt,
+        _ => "zsh",
+    };
+    let modes = ["nu", alt];
     let next_idx = modes
         .iter()
         .position(|mode| *mode == current)
         .map(|idx| (idx + 1) % modes.len())
         .unwrap_or(0);
-    stack.add_env_var(
-        "SHANNON_MODE".to_string(),
-        Value::string(modes[next_idx], Span::unknown()),
-    );
+    modes[next_idx].to_string()
+}
+
+#[cfg(test)]
+mod shannon_mode_tests {
+    use super::next_shannon_mode;
+
+    #[test]
+    fn configured_alt_is_the_only_non_nu_mode() {
+        assert_eq!(next_shannon_mode("nu", "zsh"), "zsh");
+        assert_eq!(next_shannon_mode("zsh", "zsh"), "nu");
+        assert_ne!(next_shannon_mode("nu", "zsh"), "bash");
+
+        assert_eq!(next_shannon_mode("nu", "bash"), "bash");
+        assert_eq!(next_shannon_mode("bash", "bash"), "nu");
+        assert_ne!(next_shannon_mode("nu", "bash"), "zsh");
+    }
+
+    #[test]
+    fn missing_invalid_or_unknown_current_mode_recovers_safely() {
+        assert_eq!(next_shannon_mode("nu", ""), "zsh");
+        assert_eq!(next_shannon_mode("nu", "fish"), "zsh");
+        assert_eq!(next_shannon_mode("unknown", "bash"), "nu");
+        assert_eq!(next_shannon_mode("unknown", "zsh"), "nu");
+    }
 }
 
