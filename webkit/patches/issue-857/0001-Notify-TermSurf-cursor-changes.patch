From 66ff4abf2f6d9586361ecea7f1abd37cc89c92f7 Mon Sep 17 00:00:00 2001
From: Max Commits <maxcommits@ryanxcharles.com>
Date: Sun, 21 Jun 2026 14:57:56 -0500
Subject: [PATCH 1/5] Notify TermSurf cursor changes

Before the window guards say no,
The cursor tells us where to go.
A tiny note from WebKit's view,
Lets Surfari pass the shape through.
---
 Source/WebKit/UIProcess/mac/PageClientImplMac.mm | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/Source/WebKit/UIProcess/mac/PageClientImplMac.mm b/Source/WebKit/UIProcess/mac/PageClientImplMac.mm
index 6b0ea1cbf4..a1d1f8bfee 100644
--- a/Source/WebKit/UIProcess/mac/PageClientImplMac.mm
+++ b/Source/WebKit/UIProcess/mac/PageClientImplMac.mm
@@ -110,6 +110,9 @@ using namespace WebCore;
 
 WTF_MAKE_TZONE_ALLOCATED_IMPL(PageClientImpl);
 
+static NSString * const TermSurfCursorChangedNotification = @"TermSurfWebKitCursorChangedNotification";
+static NSString * const TermSurfCursorTypeKey = @"cursorType";
+
 PageClientImpl::PageClientImpl(NSView *view, WKWebView *webView)
     : PageClientImplCocoa(webView)
     , m_view(view)
@@ -328,6 +331,12 @@ void PageClientImpl::setCursor(const WebCore::Cursor& cursor)
     ASSERT(hasProcessPrivilege(ProcessPrivilege::CanCommunicateWithWindowServer));
     // FIXME: Would be nice to share this code with WebKit1's WebChromeClient.
 
+    if (RetainPtr webView = this->webView()) {
+        [[NSNotificationCenter defaultCenter] postNotificationName:TermSurfCursorChangedNotification
+                                                            object:webView.get()
+                                                          userInfo:@{ TermSurfCursorTypeKey : @((NSInteger)cursor.type()) }];
+    }
+
     // The Web process may have asked to change the cursor when the view was in an active window, but
     // if it is no longer in a window or the window is not active, then the cursor should not change.
     if (!isViewWindowActive())
