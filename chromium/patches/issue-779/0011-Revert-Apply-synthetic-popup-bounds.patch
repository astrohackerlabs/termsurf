-  OnWindowFrameInScreenChanged(synthetic_window_frame_in_screen);
-
-  LOG(INFO) << "[termsurf-popup-trace] synthetic bounds applied"
-            << " view_bounds=" << view_bounds_in_window_dip_.ToString()
-            << " window_frame=" << window_frame_in_screen_dip_.ToString()
