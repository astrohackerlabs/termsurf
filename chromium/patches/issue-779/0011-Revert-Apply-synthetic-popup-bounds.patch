-void RenderWidgetHostViewMac::SetTermSurfSyntheticWindowBounds(
-    const gfx::Rect& local_view_bounds,
-    const gfx::Rect& synthetic_window_frame_in_screen) {
-  LOG(INFO) << "[termsurf-popup-trace] applying synthetic bounds"
-            << " local_view=" << local_view_bounds.ToString()
-            << " synthetic_window="
-            << synthetic_window_frame_in_screen.ToString()
