@@ -449,24 +449,16 @@ void TsBrowserMainParts::ResizeTab(void* wc_handle,
         static_cast<int>(std::ceil(height / scale)));
     tab->shell->ResizeWebContentForTests(logical);
     if (screen_width > 0.0 && screen_height > 0.0) {
-      gfx::Rect synthetic_window_frame(
+      gfx::Rect screen_bounds(
           static_cast<int>(std::round(screen_x)),
           static_cast<int>(std::round(screen_y)),
           static_cast<int>(std::round(screen_width)),
           static_cast<int>(std::round(screen_height)));
-      gfx::Rect local_view_bounds(gfx::Point(), logical);
-#if BUILDFLAG(IS_MAC)
-      SetTermSurfSyntheticWindowBoundsOnView(view, local_view_bounds,
-                                             synthetic_window_frame);
-#else
-      view->SetBounds(synthetic_window_frame);
-#endif
-      LOG(INFO) << "[termsurf-popup-trace] ResizeTab bounds pixels="
+      view->SetBounds(screen_bounds);
+      LOG(INFO) << "[libtermsurf_chromium] ResizeTab bounds pixels="
                 << width << "x" << height
                 << " logical=" << logical.ToString()
-                << " local_view=" << local_view_bounds.ToString()
-                << " synthetic_window=" << synthetic_window_frame.ToString()
-                << " get_view_bounds=" << view->GetViewBounds().ToString()
+                << " screen=" << screen_bounds.ToString()
                 << " screen_scale=" << screen_scale
