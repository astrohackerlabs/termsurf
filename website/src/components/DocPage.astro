---
import Base from "../layouts/Base.astro";
import { getDocsNav } from "../lib/docs-nav.ts";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const nav = await getDocsNav();
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<Base title={`${title} — TermSurf`} description={description}>
  <div class="flex gap-8">
    <aside class="hidden w-48 shrink-0 md:block">
      <nav class="space-y-1 text-xs">
        {
          nav.map((group) => (
            <>
              {group.section && (
                <div class="text-foreground-dark mt-3 mb-1 font-bold">
                  {group.section}
                </div>
              )}
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "block py-0.5",
                    currentPath === item.href
                      ? "text-accent"
                      : "text-muted hover:text-foreground-dark",
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </>
          ))
        }
      </nav>
    </aside>
    <article class="prose-termsurf min-w-0 flex-1">
      <slot />
    </article>
  </div>
</Base>
