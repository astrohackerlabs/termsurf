---
import DocPage from "../../components/DocPage.astro";
import { getDocsNav } from "../../lib/docs-nav.ts";

// Generated section index: mirrors the sidebar (same getDocsNav() source) so it
// never drifts and only ever links built collection routes. See issue 834.
const nav = await getDocsNav();
---

<DocPage title="Docs">
  <h1>Documentation</h1>

  <p>
    TermSurf is a protocol for embedding web browsers inside terminal emulators
    — the terminal, the <code>web</code> TUI, and each browser engine are
    separate processes speaking a protobuf/Unix-socket protocol. Browse the
    sections below.
  </p>

  {
    nav.map((group) => (
      <section>
        <h2>{group.section ?? "Overview"}</h2>
        {group.items.length > 0 && (
          <ul>
            {group.items.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))}
          </ul>
        )}
        {group.subgroups.map((sub) => (
          <>
            <h3>{sub.subsection}</h3>
            <ul>
              {sub.items.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </>
        ))}
      </section>
    ))
  }
</DocPage>
